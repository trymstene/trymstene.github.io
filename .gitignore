public/assets/giphy-stickers/

# pixelarticons Pro — PURCHASED pack (one-time licence). The repo is public, so
# never commit the full set (that would redistribute a paid pack). Only the
# handful we actually use is committed, in src/icons/pixelart/.
public/assets/pixelarticons-pro-2.2.1/

# 📦 EVERY PURCHASED PIXEL PACK LIVES HERE — one rule, so a new pack needs no
# new rule. Drop the pack folder in public/assets/_packs/ and it is ignored
# automatically. These are BOUGHT packs whose licences forbid redistribution
# ("resell, repackage or redistribute … even if modified" / "as is OR
# transformed"), and this repo is PUBLIC and deploys to the live site, so the
# raw packs must reach neither. The generators bake ONLY the sprites we use
# into derived atlases under public/assets/beach/ — those are what ship.
#   tools/build-fish-atlas.py   → beach/fish.png    (Pixel Gnome Fishing Pack)
#   tools/build-shell-atlas.py  → beach/shells.png  (ShoreThings)
public/assets/_packs/

# Astro / Node
node_modules/
dist/
.astro/

__pycache__/

# Local secret configs (API tokens/keys) — NEVER commit. Catch-all + specifics.
tools/*.local.json
# GA4 pull — secrets, NEVER commit (service-account key + property id)
tools/ga4.local.json
tools/*service-account*.json
tools/*-ga4-key*.json
# Google service-account keys drop in as project-hash.json — catch them all
tools/trymstene-com-*.json
tools/*.iam.gserviceaccount.com.json
ad-pack/

