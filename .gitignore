ROADMAP.md

# Local-only upload pack for Giphy/Tenor (not for the website)
giphy-tenor-pack/
# Local-only Giphy upload staging — the gallery keeps its own tracked copies
# in public/assets/gallery-bananas/, so these are duplicates we don't deploy
public/assets/giphy-stickers/

# pixelarticons Pro — PURCHASED pack (one-time licence). The repo is public, so
# never commit the full set (that would redistribute a paid pack). Only the
# handful we actually use is committed, in src/icons/pixelart/.
public/assets/pixelarticons-pro-2.2.1/

# Pixel Gnome Fishing Pack — PURCHASED pack, same rule. Its licence is explicit:
# "You cannot resell, repackage, or redistribute the asset, even if modified."
# This repo is public AND deploys to the live site, so the raw pack must reach
# neither. tools/build-fish-atlas.py bakes ONLY the species we actually use into
# public/assets/beach/fish.png (a derived game asset) — that is what ships.
public/assets/Pixel Gnome Fishing Pack/

# Astro / Node
node_modules/
dist/
.astro/

__pycache__/

# Local secret configs (API tokens/keys) — NEVER commit. Catch-all + specifics.
tools/*.local.json
# GA4 pull — secrets, NEVER commit (service-account key + property id)
tools/ga4.local.json
tools/*service-account*.json
tools/*-ga4-key*.json
# Google service-account keys drop in as project-hash.json — catch them all
tools/trymstene-com-*.json
tools/*.iam.gserviceaccount.com.json
ad-pack/

# wrangler local dev state (miniflare caches, local DO sqlite)
.wrangler/

banana-3d/
