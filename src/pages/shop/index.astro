---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixelIcon from '../../components/PixelIcon.astro';
import { getProducts, money, colorHex } from '../../lib/shop.js';

const products = await getProducts();

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Dancing Banana Shop",
  "url": "https://trymstene.com/shop/",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": p.url,
      "name": p.title,
    })),
  },
};
---
<BaseLayout
  title="Shop — Dancing Banana Merch | Trym Stene"
  description="Official Dancing Banana merch — tees, posters, mugs and more, from the creator of the meme. Printed on demand, shipped worldwide."
  ogTitle="Shop — Dancing Banana Merch"
  ogImage="https://trymstene.com/assets/og/shop.png"
  ogDescription="Official Dancing Banana merch from the creator of the meme."
>
  <link rel="stylesheet" href="/css/shop.css" slot="head" />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(collectionSchema)} />

  <section class="hero shop-hero">
    <div class="hero__banana">
      <img src="/assets/banana-strut.png" alt="The Dancing Banana strutting"
           width="240" height="240"
           onerror="this.outerHTML='<div class=&quot;banana-fallback&quot;>🍌</div>';">
    </div>
    <p class="kicker">Official merch</p>
    <h1 class="hero__title">dancing banana<br>shop</h1>
    <p class="hero__tag" style="text-transform:none;font-weight:500;">Wear the banana — the original 1999 meme, on stuff you can actually own.</p>
    <ul class="shop-trust">
      <li>Printed on demand</li>
      <li>Ships worldwide</li>
      <li>Secure Shopify checkout</li>
      <li>By the guy who made the meme</li>
    </ul>
  </section>

  <section class="block block--yellow">
    <h2 class="sr-only">The collection</h2>
    {products.length ? (
      <div class="shop-grid">
        {products.map((p) => (
          <a class="project-card shop-card" href={`/shop/${p.handle}/`}>
            <img class="shop-card__img" src={p.featured} alt={p.title} loading="lazy" width="600" height="600" />
            <div class="project-card__body">
              <h3>{p.title}</h3>
              {p.colors.length > 1 && (
                <div class="shop-card__swatches" aria-label={`${p.colors.length} colours`}>
                  {p.colors.slice(0, 6).map((c) => (
                    <span class="shop-card__swatch" style={`background:${colorHex(c)}`} title={c}></span>
                  ))}
                  {p.colors.length > 6 && <span class="shop-card__more">+{p.colors.length - 6}</span>}
                </div>
              )}
              <div class="shop-card__foot">
                <p class="shop-card__price price-tag price-tag--sm"><small>from</small> {money(p.pmin, p.cur)}</p>
                <span class="shop-card__cta">View →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="shop-status">The shop is being stocked — check back soon! <PixelIcon name="banana" /></p>
    )}
    <p class="shop-polline">Printed on demand · ships worldwide · <a href="/shop/policies/">shipping, returns &amp; policies</a></p>
  </section>

  <section class="block">
    <p class="kicker">Or make your own</p>
    <h2>Design your own banana</h2>
    <p class="lead">Different thing: in the builder you give the banana shades, a hat and a caption, then get <em>that</em> one-of-a-kind banana as a real die-cut vinyl sticker — shipped free worldwide.</p>
    <a class="btn btn--dark" href="/make-a-banana/"><PixelIcon name="palette" /> Open the banana builder →</a>
  </section>

  <script>
    // funnel step clock (same sessionStorage key as the builder/PDPs): each
    // funnel event carries secs_since_prev so Pulse can average time-per-step
    const stepSecs = () => {
      const now = Date.now(); let prev = 0;
      try { prev = +(sessionStorage.getItem('fk-t') || 0); sessionStorage.setItem('fk-t', String(now)); } catch (e) {}
      const s = prev ? Math.round((now - prev) / 1000) : -1;
      return (s >= 0 && s <= 1800) ? s : undefined;
    };
    const withSecs = (p) => { const s = stepSecs(); if (s !== undefined) p.secs_since_prev = s; return p; };
    // funnel top: someone opened the shop's front page — the merch funnel's
    // first real step in Banana Pulse (before select_item / view_item)
    if (window.gtag) window.gtag('event', 'shop_view', withSecs({}));
    // funnel: which PLP card gets picked (pairs with view_item + begin_checkout
    // in /js/shop.js). gtag beacons survive the navigation.
    document.querySelectorAll('.shop-grid .shop-card').forEach((card) => {
      card.addEventListener('click', () => {
        const name = card.querySelector('h3')?.textContent?.trim();
        if (window.gtag && name) window.gtag('event', 'select_item', withSecs({ items: [{ item_name: name }] }));
      });
    });
  </script>
</BaseLayout>
