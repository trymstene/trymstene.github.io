---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixelIcon from '../../components/PixelIcon.astro';
import { getProducts, money, colorHex, shopTitle } from '../../lib/shop.js';

const products = await getProducts();

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Dancing Banana Shop",
  "url": "https://trymstene.com/shop/",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": p.url,
      "name": p.title,
    })),
  },
};
---
<BaseLayout
  title="Shop — Dancing Banana Merch | Trym Stene"
  description="Official Dancing Banana merch — tees, posters, mugs and more, from the creator of the meme. Printed on demand, shipped worldwide."
  ogTitle="Shop — Dancing Banana Merch"
  ogImage="https://trymstene.com/assets/og/shop.png"
  ogDescription="Official Dancing Banana merch from the creator of the meme."
>
  <link rel="stylesheet" href="/css/shop.css" slot="head" />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(collectionSchema)} />

  <section class="hero shop-hero">
    <div class="hero__banana">
      <img src="/assets/banana-strut.png" alt="The Dancing Banana strutting"
           width="240" height="240"
           onerror="this.outerHTML='<div class=&quot;banana-fallback&quot;>🍌</div>';">
    </div>
    <p class="kicker">Official merch</p>
    <h1 class="hero__title">dancing banana<br>shop</h1>
    <p class="hero__tag" style="text-transform:none;font-weight:500;">Wear the banana — the original 1999 meme, on stuff you can actually own.</p>
    <ul class="shop-trust">
      <li>Printed on demand</li>
      <li>Ships worldwide</li>
      <li>By the guy who made the meme</li>
    </ul>
  </section>

  <section class="block block--yellow">
    <p class="kicker">The collection</p>
    <h2>Wear the original</h2>
    <p class="lead">The real 1999 Dancing Banana, on things you’ll actually use. Secure checkout via Shopify.</p>
    {products.length ? (
      <div class="shop-grid">
        {products.map((p) => (
          <a class="project-card shop-card" href={`/shop/${p.handle}/`}>
            <img class="shop-card__img" src={p.featured} alt={p.title} loading="lazy" width="600" height="600" />
            <div class="project-card__body">
              <h3>{shopTitle(p.title)}</h3>
              {p.colors.length > 1 && (
                <div class="shop-card__swatches" aria-label={`${p.colors.length} colours`}>
                  {p.colors.slice(0, 6).map((c) => (
                    <span class="shop-card__swatch" style={`background:${colorHex(c)}`} title={c}></span>
                  ))}
                  {p.colors.length > 6 && <span class="shop-card__more">+{p.colors.length - 6}</span>}
                </div>
              )}
              <div class="shop-card__foot">
                <p class="shop-card__price"><span class="shop-card__from">from</span>{money(p.pmin, p.cur)}</p>
                <span class="shop-card__cta">View →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <p class="shop-status">The shop is being stocked — check back soon! <PixelIcon name="banana" /></p>
    )}
  </section>

  <section class="block">
    <p class="kicker">Or make your own</p>
    <h2>Put <em>your</em> banana on it</h2>
    <p class="lead">Add shades, a hat, a caption — build your own dancing banana and get it as a real vinyl sticker, shipped free worldwide.</p>
    <a class="btn btn--dark" href="/make-a-banana/"><PixelIcon name="palette" /> Open the banana builder →</a>
  </section>
</BaseLayout>
