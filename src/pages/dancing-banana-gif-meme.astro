---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hreflang from '../components/Hreflang.astro';
import LangSwitch from '../components/LangSwitch.astro';
import PixelIcon from '../components/PixelIcon.astro';
import remixes from '../data/remixes.json';

const title = "Dancing Banana GIF — Download the Original Meme (Free)";
const description = "The original Dancing Banana GIF — free to download (GIF + transparent PNG). Made in 1999 by its creator, Trym Stene. Grab it, make your own, or license it.";
const ogDescription = "The original Dancing Banana GIF, free to download. Made in 1999 by its creator, Trym Stene. Grab it, remix it, or license it.";

const creativeWork = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "@id": "https://trymstene.com/#banana-gif",
  "name": "The Dancing Banana GIF",
  "alternateName": "Peanut Butter Jelly Time banana",
  "dateCreated": "1999",
  "image": "https://trymstene.com/assets/dancing-banana-gif.gif",
  "contentUrl": "https://trymstene.com/assets/dancing-banana-gif.gif",
  "url": "https://trymstene.com/dancing-banana-gif-meme/",
  "creator": { "@id": "https://trymstene.com/#trym", "@type": "Person", "name": "Trym Stene", "url": "https://trymstene.com/" },
  "copyrightHolder": { "@id": "https://trymstene.com/#trym" },
  "copyrightYear": 1999
};

const faq = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the dancing banana meme?", "acceptedAnswer": { "@type": "Answer", "text": "The dancing banana is an animated pixel banana that waves its arms and dances. It is one of the internet's earliest memes, created by Trym Stene in 1999, and is also known as the banana meme or the Peanut Butter Jelly Time banana." } },
    { "@type": "Question", "name": "What does the dancing banana mean?", "acceptedAnswer": { "@type": "Answer", "text": "It began as a celebration emoji that Trym Stene posted whenever he finished something. Today it is used to express joy, silliness, or an 'it's time!' moment." } },
    { "@type": "Question", "name": "Who made the Dancing Banana GIF?", "acceptedAnswer": { "@type": "Answer", "text": "The Dancing Banana GIF was created by Trym Stene in 1999, animated in Animation Shop. It has since been cited by USA Today, Fandom and City AM." } },
    { "@type": "Question", "name": "When was the Dancing Banana created?", "acceptedAnswer": { "@type": "Answer", "text": "Around 1999." } },
    { "@type": "Question", "name": "Where can I download the Dancing Banana GIF?", "acceptedAnswer": { "@type": "Answer", "text": "Free on trymstene.com — as the original GIF or a transparent version, with no sign-up and no watermark." } },
    { "@type": "Question", "name": "Is the Dancing Banana the same as Peanut Butter Jelly Time?", "acceptedAnswer": { "@type": "Answer", "text": "They are related but not the same. Trym Stene made the Dancing Banana; The Buckwheat Boyz later set a Flash version to their song Peanut Butter Jelly Time. The song and that Flash are theirs; the banana is Trym Stene's. That version reached TV too: NBC's Ed showed it in 2002, and Family Guy featured it in 2005 with Brian in the banana suit." } },
    { "@type": "Question", "name": "What is the dancing banana called?", "acceptedAnswer": { "@type": "Answer", "text": "It goes by several names: the Dancing Banana, the banana meme, and the Peanut Butter Jelly Time banana. They all refer to the same animated pixel banana Trym Stene made in 1999." } },
    { "@type": "Question", "name": "Where did the dancing banana come from?", "acceptedAnswer": { "@type": "Answer", "text": "Trym Stene created it in 1999 as a celebration emoji to post on web forums. It spread from there, and a later Flash version set to the song Peanut Butter Jelly Time carried it worldwide." } },
    { "@type": "Question", "name": "Is the dancing banana copyrighted?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Trym Stene created the Dancing Banana in 1999 and holds the rights. It is free for personal and fun use; commercial use requires a license." } },
    { "@type": "Question", "name": "Can I use the Dancing Banana?", "acceptedAnswer": { "@type": "Answer", "text": "Free for personal and fun use. Commercial use requires a license from the creator." } }
  ]
};

// The GIF as a first-class ImageObject with license info → eligible for the
// "Licensable" badge in Google Images (where this page's impressions live).
// Additive; the CreativeWork entity above is untouched.
const bananaImage = {
  "@context": "https://schema.org",
  "@type": "ImageObject",
  "@id": "https://trymstene.com/#banana-gif-image",
  "contentUrl": "https://trymstene.com/assets/dancing-banana-gif.gif",
  "url": "https://trymstene.com/dancing-banana-gif-meme/",
  "name": "The Dancing Banana GIF",
  "caption": "The original Dancing Banana — an animated pixel GIF created by Trym Stene in 1999.",
  "encodingFormat": "image/gif",
  "width": 500,
  "height": 500,
  "creator": { "@id": "https://trymstene.com/#trym" },
  "copyrightHolder": { "@id": "https://trymstene.com/#trym" },
  "copyrightYear": 1999,
  "creditText": "Trym Stene",
  "acquireLicensePage": "https://trymstene.com/license-the-dancing-banana/",
  "license": "https://trymstene.com/license-the-dancing-banana/",
  "isBasedOn": { "@id": "https://trymstene.com/#banana-gif" }
};

// The author entity, finally DEFINED (every schema above references #trym by id
// but it was never a full node). E-E-A-T for the informational "dancing banana"
// query — tells Google the authoritative person behind the meme. Purely additive.
const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://trymstene.com/#trym",
  "name": "Trym Stene",
  "url": "https://trymstene.com/me/",
  "image": "https://trymstene.com/assets/trym-stene-profile-photo.jpg",
  "description": "Norwegian designer and creator of the Dancing Banana GIF (1999) — one of the internet's earliest memes.",
  "jobTitle": "Creator of the Dancing Banana",
  "sameAs": [
    "https://www.facebook.com/trymstene",
    "https://twitter.com/trymstene",
    "https://www.linkedin.com/in/trymstene/",
    "https://www.instagram.com/trymstene/"
  ]
};
---
<BaseLayout
  title={title}
  description={description}
  ogDescription={ogDescription}
  ogImage="https://trymstene.com/assets/og/gif.png"
  ogType="article"
>
  <Fragment slot="head">
    <Hreflang />
    <script type="application/ld+json" set:html={JSON.stringify(person)} />
    <script type="application/ld+json" set:html={JSON.stringify(creativeWork)} />
    <script type="application/ld+json" set:html={JSON.stringify(bananaImage)} />
    <script type="application/ld+json" set:html={JSON.stringify(faq)} />
  </Fragment>

  <style>
    .hero__cta { margin-top: 1.1rem; }
    /* the sticker moment — YELLOW so it reads as the offer, not another free link */
    .sticker-offer {
      display: flex; align-items: center; gap: 1.2rem;
      max-width: 640px; margin: 1.1rem auto 0; padding: 1rem 1.2rem;
      background: var(--banana); color: var(--ink);
      border: var(--line); box-shadow: var(--shadow);
      text-decoration: none; transition: transform 0.12s ease, box-shadow 0.12s ease;
    }
    .sticker-offer:hover, .sticker-offer:focus-visible { transform: translate(-2px, -2px); box-shadow: 7px 7px 0 #000; }
    .sticker-offer img { width: 116px; height: auto; flex: none; }
    .sticker-offer__copy { display: flex; flex-direction: column; align-items: flex-start; }
    .sticker-offer__k { font-size: 0.78rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.7; }
    .sticker-offer__h { font-size: 1.12rem; font-weight: 800; margin: 0.15rem 0 0.3rem; line-height: 1.2; }
    .sticker-offer__p { font-weight: 700; margin-bottom: 0.7rem; }
    .sticker-offer__btn { pointer-events: none; }
    @media (max-width: 560px) {
      .sticker-offer { flex-direction: column; text-align: center; }
      .sticker-offer__copy { align-items: center; }
    }
    /* the tip steps back — it shares the sticker's emotion at 1/30th the value */
    .dl-tip { font-size: 0.9rem; opacity: 0.7; }
    /* the formats line under the download buttons */
    .dl-formats { font-size: 0.88rem; opacity: 0.78; margin-top: 0.9rem; max-width: 60ch; margin-inline: auto; }
  </style>

  <!-- hero -->
  <section class="hero">
    <div class="hero__banana">
      <img src="/assets/dancing-banana-gif.gif" width="500" height="500" alt="The Dancing Banana — the original banana meme GIF, created by Trym Stene in 1999"
           onerror="this.outerHTML='<div class=&quot;banana-fallback&quot;>🍌</div>';">
    </div>
    <h1 class="hero__title">the dancing<br>banana</h1>
    <p class="hero__tag">A GIF I made in 1999 that never stopped dancing</p>
    <p class="hero__cta"><a class="btn btn--dark" href="#download"><PixelIcon name="download" /> Download the GIF ↓</a></p>
  </section>

  <!-- answer-first intro + jump menu -->
  <section class="block">
    <p class="lead" style="max-width:64ch;margin-inline:auto;font-size:1.2rem;">
      The <strong>Dancing Banana</strong> — also just called <strong>the banana meme</strong> — is an
      animated pixel GIF created by <strong>Trym Stene in 1999</strong>: a little banana waving its arms in
      celebration. One of the internet's earliest memes, later set to <em>"Peanut Butter Jelly Time."</em>
      Download it free below, make your own, or license it.
    </p>

    <nav class="jumpnav" aria-label="On this page">
      <a href="#download"><PixelIcon name="download" /> Download</a>
      <a href="#story">The story</a>
      <a href="/make-a-banana/" data-place="hub_jumpnav"><PixelIcon name="palette" /> Make your own</a>
      <a href="#remixes"><PixelIcon name="banana" /> Community remixes</a>
      <a href="#faq">FAQ</a>
      <a href="#license">License</a>
    </nav>
  </section>

  <!-- download hub -->
  <section class="block" id="download">
    <p class="kicker">Take it with you</p>
    <h2>Download the Dancing Banana GIF</h2>
    <p class="lead">It's the people's banana — free to download, share and embed. Every format: the original animated GIF, a <strong>transparent background</strong> version (GIF and PNG, no background), and a 2000px HD remaster.</p>
    <div class="grab">
      <img src="/assets/dancing-banana-transparent.gif" width="500" height="500" alt="The Dancing Banana meme GIF with a transparent background — free download">
      <div class="dl-buttons">
        <a class="btn btn--dark" href="/assets/dancing-banana-gif.gif" download="dancing-banana-trymstene.com.gif">Original GIF ↓</a>
        <a class="btn btn--dark" href="/assets/dancing-banana-transparent.gif" download="dancing-banana-transparent-trymstene.com.gif">Transparent GIF ↓</a>
        <a class="btn btn--light" href="/assets/dancing-banana-transparent.png" download="dancing-banana-transparent-trymstene.com.png">Transparent PNG ↓</a>
        <a class="btn btn--light" href="/assets/dancing-banana-hd.gif" download="dancing-banana-hd-trymstene.com.gif">HD remaster GIF (2000px) ↓</a>
      </div>
    </div>
    <p class="dl-formats">
      Need the <strong>dancing banana PNG</strong>? The transparent PNG is a single still frame with no background —
      right for avatars, print and thumbnails. The <strong>transparent GIF</strong> keeps the dance <em>and</em> the
      see-through background, so it drops onto any colour. All free, no signup, no watermark.
    </p>

    <!-- the sticker moment: the product, right where the traffic actually is -->
    <a class="sticker-offer" href="/make-a-banana/" data-place="hub_sticker">
      <img src="/assets/custom-banana-sticker-product.png" width="300" height="300" alt="A custom dancing banana printed as a real vinyl sticker" loading="lazy">
      <span class="sticker-offer__copy">
        <span class="sticker-offer__k">Take one home for real</span>
        <span class="sticker-offer__h">Your banana, on a real vinyl sticker</span>
        <span class="sticker-offer__p"><strong>from $14.99</strong> · free shipping worldwide</span>
        <span class="btn btn--dark sticker-offer__btn">Make &amp; order yours →</span>
      </span>
    </a>

    <p class="dl-door">It's yours <PixelIcon name="banana" /> — and it can also wear a hat. <a href="/make-a-banana/" data-place="post-dl-hub">Dress your own →</a></p>

    <p class="lead" style="margin-top:1.5rem;">
      Want it as a <a href="/dancing-banana-emoji/">dancing banana emoji</a> for Discord, Slack or Telegram? Grab the transparent version.
      Or put it on every screen you own with the <a href="/dancing-banana-wallpaper/">free wallpapers</a>.
    </p>

    <div class="embed">
      <label for="embedCode">Putting the banana on your site? Use this — it keeps a credit link back:</label>
      <textarea id="embedCode" readonly rows="3"></textarea>
      <button class="btn btn--light" id="copyEmbed" type="button">Copy embed code</button>
    </div>

    <p class="dl-tip" style="margin-top:2rem;">
      Rather just say thanks? You can <a href="https://buymeacoffee.com/trymstene" target="_blank" rel="noopener">buy the banana guy a coffee</a>. <PixelIcon name="coffee" />
    </p>
  </section>

  <!-- CTA: the builder — GIF-seekers become banana-makers -->
  <section class="block block--dark" id="make-your-own">
    <p class="kicker kicker--light">Free banana builder</p>
    <h2>Make your <em>own</em> dancing banana</h2>
    <div class="mkb-examples" aria-hidden="true">
      <img src="/assets/example-banana-1.png" width="250" height="328" alt="" loading="lazy">
      <img src="/assets/example-banana-2.png" width="315" height="349" alt="" loading="lazy">
      <img src="/assets/example-banana-3.png" width="319" height="395" alt="" loading="lazy">
    </div>
    <p class="lead">
      Hats, shades, moustaches, captions, disco mode — dress the banana up and it's yours.
      Download it as a <strong>free animated emoji or meme</strong>, or get it mailed to your door
      as a <strong>real vinyl sticker</strong>.
    </p>
    <p style="margin-top:1.2rem;">
      <a class="btn btn--light" href="/make-a-banana/" data-place="hub_cta"><PixelIcon name="palette" /> Open the banana builder →</a>
    </p>
    <p class="mkb-note">Stickers from $14.99 · free shipping worldwide · or meet the <a href="/banana-of-the-day/">banana of the day</a></p>
  </section>

  <!-- who made it / story -->
  <section class="block block--yellow" id="story">
    <p class="kicker">The story</p>
    <h2>Who made the Dancing Banana?</h2>
    <p class="lead">
      I did — <strong>Trym Stene</strong>, back in <strong>1999</strong>, on an AMD K6-2 running at a
      blistering 350MHz, using Animation Shop (the little tool bundled with Paint Shop Pro). It started as a
      "celebration" emoticon I'd post on web forums — and somehow it never stopped dancing.
    </p>
    <details class="story">
      <summary>Read the full story</summary>
      <p class="lead">
        I grew up in rural Norway, without many people around who were into the same things, so I made silly
        digital stuff to amuse myself and the people I met on internet forums and IRC. The banana became my
        little "celebration" emoji — I'd post it on the forums whenever I finished something new. I made other animations
        too, an angry toaster, a melting ice-cream cone with big sad eyes — but none of them had whatever the
        banana had.
      </p>
      <p class="lead">
        Before Flash took over, I actually made a bit of money drawing animated GIF ad-banners for people I
        met on IRC — about <strong>$25</strong> a pop (250 kroner), though cashing a foreign check ate a chunk
        of that. Then Flash arrived, <strong>The Buckwheat Boyz</strong> set a version to
        <strong>"Peanut Butter Jelly Time,"</strong> and the banana took on a life of its own — eventually
        even turning up in <strong>Family Guy</strong>.
      </p>
    </details>
  </section>

  <!-- FAQ -->
  <section class="block block--dark" id="faq">
    <p class="kicker kicker--light">The usual questions</p>
    <h2>Dancing Banana FAQ</h2>
    <div class="faq__item">
      <h3>What is the dancing banana meme?</h3>
      <p>It's an animated pixel banana that waves its arms and dances — one of the internet's first memes, created by Trym Stene in 1999. People also call it "the banana meme" or the "Peanut Butter Jelly Time banana."</p>
    </div>
    <div class="faq__item">
      <h3>What is the dancing banana called?</h3>
      <p>A few names for the same 1999 GIF: the <strong>Dancing Banana</strong>, "the <strong>banana meme</strong>," and — after the Flash version set to that song — the "<strong>Peanut Butter Jelly Time</strong> banana." All the same dancing pixel banana I made.</p>
    </div>
    <div class="faq__item">
      <h3>What does the dancing banana mean?</h3>
      <p>It started as a "celebration" emoji — I'd post it whenever I finished something. These days it's shorthand for pure joy, silliness, or "it's [something] time!" energy.</p>
    </div>
    <div class="faq__item">
      <h3>Who made the Dancing Banana GIF?</h3>
      <p>I did — Trym Stene. I animated it in 1999 in Animation Shop. I don't still have the original file as a smoking gun, but the story's been picked up by USA Today, Fandom, City AM and others.</p>
    </div>
    <div class="faq__item">
      <h3>When was the Dancing Banana created?</h3>
      <p>Around 1999. I made loads of GIFs in those years, but this one shone the brightest.</p>
    </div>
    <div class="faq__item">
      <h3>Where did the dancing banana come from?</h3>
      <p>From me — Trym Stene — in <strong>1999</strong>. I drew it as a little "celebration" emoji to post on web forums whenever I finished something. It spread from there, and a later Flash version set to "Peanut Butter Jelly Time" carried it worldwide.</p>
    </div>
    <div class="faq__item">
      <h3>Where can I download it?</h3>
      <p>Right here, free — as the <a href="#download">original GIF or a transparent version</a>. No sign-ups, no watermarks.</p>
    </div>
    <div class="faq__item">
      <h3>Is it the same as "Peanut Butter Jelly Time"?</h3>
      <p>Related, but not the same. I made the banana in 1999; later, others set it to The Buckwheat Boyz' song "Peanut Butter Jelly Time" in a Flash animation — the song and that Flash are their creators'. That version even escaped onto TV: NBC's <em>Ed</em> showed it in 2002, and in 2005 <em>Family Guy</em> put Brian in the banana suit. <a href="/peanut-butter-jelly-time/">Who made what →</a></p>
    </div>
    <div class="faq__item">
      <h3>Is the dancing banana copyrighted?</h3>
      <p>Yes — I created it in 1999 and hold the rights. It's free to enjoy and share for personal, non-commercial fun; commercial use needs a <a href="/license-the-dancing-banana/">licence</a>.</p>
    </div>
    <div class="faq__item">
      <h3>Can I use it?</h3>
      <p>For fun? Go wild. For commercial use? <a href="/license-the-dancing-banana/">Read this first.</a></p>
    </div>
  </section>

  <!-- press belt: outlets that covered the banana, uniform logo strip -->
  <section class="press-belt" aria-label="As featured in">
    <p class="press-belt__kicker">As featured in</p>
    <div class="press-belt__logos">
      <a href="https://eu.usatoday.com/story/news/nation-now/2014/04/02/peanut-butter-jelly-time/7194151/" target="_blank" rel="noopener" title="USA Today on Peanut Butter Jelly Time">
        <img src="/assets/press/usatoday.svg" alt="USA Today" height="30" loading="lazy" />
      </a>
      <a href="https://meme.fandom.com/wiki/Dancing_Banana" target="_blank" rel="noopener" title="Dancing Banana on Fandom">
        <img src="/assets/press/fandom.svg" alt="Fandom" height="30" loading="lazy" />
      </a>
      <a href="https://www.cityam.com/who-killed-the-gif-how-the-dancing-banana-got-peeled/" target="_blank" rel="noopener" title="City A.M.: Who killed the GIF?">
        <img src="/assets/press/cityam.svg" alt="City A.M." height="30" loading="lazy" />
      </a>
      <a href="https://familyguy.fandom.com/wiki/Peanut_Butter_Jelly_Time" target="_blank" rel="noopener" title="Family Guy: Brian's Peanut Butter Jelly Time (2005)">
        <img src="/assets/press/familyguy.svg" alt="Family Guy" height="34" loading="lazy" />
      </a>
      <a href="https://knowyourmeme.com/memes/peanut-butter-jelly-time" target="_blank" rel="noopener" title="Peanut Butter Jelly Time on Know Your Meme">
        <img src="/assets/press/kym.svg" alt="Know Your Meme" height="26" loading="lazy" />
      </a>
    </div>
  </section>

  <!-- licensing teaser -->
  <section class="block block--yellow" id="license">
    <p class="kicker">Want to use the banana?</p>
    <h2>Licensing</h2>
    <p class="lead">
      Free to enjoy, share and remix for fun. For <strong>commercial</strong> use you'll need a license —
      and yes, that includes crypto/token projects, on stricter terms. I license the original directly,
      no middlemen, quoted per project.
    </p>
    <a class="btn btn--dark" href="/license-the-dancing-banana/">How to license the banana →</a>
  </section>

  <!-- community remixes -->
  <section class="block" id="remixes">
    <p class="kicker">Thank you, internet</p>
    <h2>Community remixes</h2>
    <p class="lead">
      A huge thank you to the meme community for all the Dancing Banana remixes over the years — the
      warrior banana, the jedi banana, dancing Mario, all of them. The full <a href="/dancing-banana-remixes/">banana meme gallery</a> has
      {remixes.length} of them, rateable in bananas and free to download.
    </p>
    <div class="remix-grid">
      {['bananadance-warrior', 'bananadance-jedi', 'mariodance-pbj', 'dancing-banana-homer', 'bananadance-rainbow', 'bananadance-santa'].map((id) => (
        <a class="slot" href="/dancing-banana-remixes/" aria-label="Open the community remix gallery">
          <img src={'/assets/dancing-banana-community-remixes/' + id + '.gif'} alt="Dancing Banana community remix" loading="lazy"
               style="image-rendering:pixelated;width:64%;height:64%;object-fit:contain;" />
        </a>
      ))}
    </div>
    <p style="text-align:center;margin-top:1.4rem;">
      <a class="btn btn--dark" href="/dancing-banana-remixes/">Browse all {remixes.length} banana memes →</a>
    </p>
  </section>

  <!-- the hub is the home of the translated pages — the switch lives here,
       just above the shared footer -->
  <section class="block" style="padding-top:1.2rem;padding-bottom:1.2rem;">
    <LangSwitch current="en" label="Language" />
  </section>

  <script is:inline>
    (function(){
      var origin = location.origin;
      var page = origin + '/dancing-banana-gif-meme/';
      var gif = origin + '/assets/dancing-banana-gif.gif';
      var code = '<a href="' + page + '" title="The original Dancing Banana GIF by Trym Stene">\n  <img src="' + gif + '" alt="Dancing Banana" width="120" height="128">\n</a>';
      var ta = document.getElementById('embedCode');
      if (ta) ta.value = code;
      var btn = document.getElementById('copyEmbed');
      if (btn && ta) btn.addEventListener('click', function(){
        ta.select();
        var done = function(){ btn.textContent = 'Copied!'; setTimeout(function(){ btn.textContent = 'Copy embed code'; }, 1500); };
        if (navigator.clipboard) { navigator.clipboard.writeText(ta.value).then(done).catch(function(){ document.execCommand('copy'); done(); }); }
        else { document.execCommand('copy'); done(); }
      });
    })();
  </script>
</BaseLayout>
