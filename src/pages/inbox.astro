---
// 🍌 BANANA MAIL™ — the executive correspondence system. Trym's private inbox
// client for worker-contact: token-gated (fragment or localStorage, never in
// the page source), noindex, absent from the sitemap allowlist. Over-the-top
// corporate-mailroom theme on purpose — it's the admin room of a banana empire.
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'BANANA MAIL™';
const description = 'Authorized banana personnel only.';
---
<BaseLayout title={title} description={description} showFooter={false}>
  <meta name="robots" content="noindex" slot="head" />
  <style is:inline slot="head">
    .bm-wrap { max-width: 760px; margin: 0 auto; padding: 1.6rem 1rem 4rem; }
    .bm-letterhead {
      background: var(--ink); color: var(--paper); border: var(--line); box-shadow: var(--shadow);
      padding: 1.1rem 1.2rem 1rem; text-align: center; position: relative; overflow: hidden;
    }
    .bm-letterhead::before, .bm-letterhead::after { content: '🍌'; position: absolute; top: 0.9rem; font-size: 1.4rem; }
    .bm-letterhead::before { left: 1rem; } .bm-letterhead::after { right: 1rem; transform: scaleX(-1); }
    .bm-letterhead h1 { margin: 0; font-size: clamp(1.5rem, 6vw, 2.2rem); color: var(--banana); letter-spacing: 0.02em; }
    .bm-letterhead .bm-sub { font-size: 0.62rem; font-weight: 800; letter-spacing: 0.22em; text-transform: uppercase; opacity: 0.75; margin: 0.35rem 0 0; }
    .bm-letterhead .bm-est { font-size: 0.58rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--banana); opacity: 0.9; margin: 0.2rem 0 0; }

    /* the security checkpoint */
    .bm-gate { margin-top: 1.2rem; border: var(--line); background: var(--paper); box-shadow: 4px 4px 0 var(--ink); padding: 1.1rem; text-align: center; }
    .bm-gate p { margin: 0 0 0.8rem; font-size: 0.9rem; }
    .bm-gate .bm-gate__row { display: flex; gap: 0.6rem; max-width: 420px; margin-inline: auto; }
    .bm-gate input { flex: 1; min-width: 0; padding: 0.6rem 0.7rem; border: 3px solid var(--ink); font-family: inherit; font-size: 0.95rem; border-radius: 2px; }
    .bm-gate .bm-wrong { color: var(--hot); font-weight: 700; font-size: 0.8rem; margin-top: 0.6rem; }

    /* toolbar */
    .bm-bar { display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; margin: 1.2rem 0 0.9rem; }
    .bm-count { font-weight: 800; font-size: 0.85rem; margin-right: auto; }
    .bm-chip {
      border: 3px solid var(--ink); background: var(--paper); padding: 0.28rem 0.6rem;
      font-weight: 800; font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase;
      cursor: pointer; border-radius: 2px;
    }
    .bm-chip[aria-pressed="true"] { background: var(--ink); color: var(--banana); }
    .bm-chip--ghost { border-style: dashed; opacity: 0.75; }

    /* mail cards */
    .bm-mail { border: var(--line); background: var(--paper); box-shadow: 4px 4px 0 var(--ink); margin: 0 0 0.9rem; position: relative; }
    .bm-mail--unread { box-shadow: 4px 4px 0 var(--hot); }
    .bm-mail__head { width: 100%; display: block; text-align: left; background: none; border: none; font-family: inherit; padding: 0.8rem 0.9rem; cursor: pointer; }
    .bm-mail__top { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; font-size: 0.62rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; opacity: 0.65; }
    .bm-stamp {
      border: 2px solid var(--ink); padding: 0.1rem 0.4rem; border-radius: 2px; opacity: 1;
      background: var(--banana); transform: rotate(2deg); font-size: 0.58rem;
    }
    .bm-stamp--licensing { background: var(--hot); color: #fff; transform: rotate(-2deg); }
    .bm-mail__from { font-weight: 800; font-size: 0.98rem; margin: 0.35rem 0 0; word-break: break-word; }
    .bm-mail__from .bm-dot { display: inline-block; width: 9px; height: 9px; border-radius: 999px; background: var(--hot); margin-right: 0.4rem; vertical-align: 1px; }
    .bm-mail__peek { font-size: 0.82rem; opacity: 0.7; margin: 0.25rem 0 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .bm-mail__body { padding: 0 0.9rem 0.9rem; }
    .bm-mail__msg { white-space: pre-wrap; font-family: inherit; font-size: 0.92rem; line-height: 1.55; margin: 0.2rem 0 0.9rem; border-top: 3px dashed rgba(17,17,17,0.15); padding-top: 0.8rem; word-break: break-word; }
    .bm-mail__actions { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .bm-btn {
      border: 3px solid var(--ink); background: var(--paper); padding: 0.45rem 0.8rem;
      font-weight: 800; font-size: 0.78rem; cursor: pointer; border-radius: 2px; text-decoration: none; color: var(--ink);
    }
    .bm-btn--shred { background: var(--hot); color: #fff; }
    .bm-btn--shred[data-arm="1"] { background: #111; color: var(--hot); }
    .bm-mail--shredding { transition: transform 0.35s ease, opacity 0.35s ease; transform: translateX(40px) rotate(2deg); opacity: 0; }

    .bm-empty { text-align: center; padding: 2.5rem 1rem; border: 3px dashed rgba(17,17,17,0.3); border-radius: 4px; }
    .bm-empty .bm-big { font-size: 2rem; }
    .bm-empty p { margin: 0.4rem 0 0; font-weight: 700; opacity: 0.7; }

    .bm-fine { text-align: center; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.45; margin-top: 2rem; line-height: 1.8; }
    @media (max-width: 480px) { .bm-count { flex-basis: 100%; } }

    /* DEPARTMENTS — mail | gallery inbox, one roof */
    .bm-tabs { display: flex; gap: 0.5rem; margin-top: 1.2rem; }
    .bm-tab {
      flex: 1; border: var(--line); background: var(--paper); padding: 0.55rem 0.6rem;
      font-family: inherit; font-weight: 800; font-size: 0.8rem; letter-spacing: 0.06em;
      text-transform: uppercase; cursor: pointer; border-radius: 2px;
    }
    .bm-tab[aria-selected="true"] { background: var(--ink); color: var(--banana); }
    .bm-tab .bm-badge { display: inline-block; min-width: 1.2em; padding: 0 0.25em; border-radius: 999px; background: var(--hot); color: #fff; font-size: 0.72rem; margin-left: 0.3rem; }

    /* gallery submission cards */
    .bm-pend { border: var(--line); background: var(--paper); box-shadow: 4px 4px 0 var(--ink); margin: 0 0 0.9rem; padding: 0.8rem 0.9rem; display: flex; gap: 0.9rem; }
    .bm-pend__img {
      flex: 0 0 132px; width: 132px; height: 132px; border: 3px solid var(--ink);
      display: flex; align-items: center; justify-content: center; overflow: hidden;
      background: repeating-conic-gradient(#f4f1e8 0% 25%, #e4e0d2 0% 50%) 0 0 / 18px 18px;
    }
    .bm-pend__img img { max-width: 94%; max-height: 94%; }
    .bm-pend__meta { flex: 1; min-width: 0; }
    .bm-pend__meta input {
      width: 100%; box-sizing: border-box; border: 3px solid var(--ink); padding: 0.45rem 0.55rem;
      font-family: inherit; font-weight: 700; font-size: 0.9rem; border-radius: 2px;
    }
    .bm-pend__line { font-size: 0.68rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.6; margin: 0.4rem 0 0.6rem; }
    .bm-btn--hang { background: var(--banana); }
    .bm-gkey { margin-top: 1.2rem; border: var(--line); background: var(--paper); box-shadow: 4px 4px 0 var(--ink); padding: 1.1rem; text-align: center; }
    .bm-gkey p { margin: 0 0 0.8rem; font-size: 0.9rem; }
    .bm-gkey .bm-gate__row { display: flex; gap: 0.6rem; max-width: 460px; margin-inline: auto; }
    .bm-gkey input { flex: 1; min-width: 0; padding: 0.6rem 0.7rem; border: 3px solid var(--ink); font-family: inherit; font-size: 0.95rem; border-radius: 2px; }
    @media (max-width: 560px) { .bm-pend { flex-direction: column; } .bm-pend__img { width: 100%; flex-basis: auto; height: 180px; } }

    /* the LIVE catalogue — compact rows, built for hundreds */
    .bm-livetools { gap: 0.5rem; }
    .bm-livesearch { flex: 1 1 220px; min-width: 0; border: 3px solid var(--ink); padding: 0.45rem 0.6rem; font-family: inherit; font-size: 0.85rem; border-radius: 2px; }
    .bm-livesort { border: 3px solid var(--ink); padding: 0.4rem 0.45rem; font-family: inherit; font-weight: 700; font-size: 0.72rem; background: var(--paper); border-radius: 2px; }
    .bm-livenote { font-size: 0.68rem; opacity: 0.6; font-weight: 700; margin: 0 0 0.8rem; }
    .bm-live { display: flex; gap: 0.7rem; align-items: flex-start; border: var(--line); background: var(--paper); box-shadow: 3px 3px 0 var(--ink); padding: 0.6rem 0.7rem; margin-bottom: 0.6rem; }
    .bm-live__img {
      flex: 0 0 72px; width: 72px; height: 72px; border: 2px solid var(--ink);
      display: flex; align-items: center; justify-content: center; overflow: hidden;
      background: repeating-conic-gradient(#f4f1e8 0% 25%, #e4e0d2 0% 50%) 0 0 / 14px 14px;
    }
    .bm-live__img img { max-width: 94%; max-height: 94%; }
    .bm-live__meta { flex: 1; min-width: 0; display: grid; gap: 0.4rem; }
    .bm-live__meta input { width: 100%; box-sizing: border-box; border: 2px solid var(--ink); padding: 0.35rem 0.5rem; font-family: inherit; font-size: 0.82rem; border-radius: 2px; }
    .bm-live__row2 { display: flex; gap: 0.4rem; flex-wrap: wrap; }
    .bm-live__row2 input { flex: 1; min-width: 130px; }
    .bm-live__foot { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; font-size: 0.64rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase; opacity: 0.75; }
    .bm-live__foot a { color: var(--ink); }
    .bm-live__save { margin-left: auto; }
    .bm-live--dirty { box-shadow: 3px 3px 0 var(--hot); }
    @media (max-width: 560px) { .bm-live { flex-wrap: wrap; } }
  </style>

  <div class="bm-wrap">
    <header class="bm-letterhead">
      <h1>BANANA MAIL™</h1>
      <p class="bm-sub">Executive correspondence system</p>
      <p class="bm-est">First-class potassium post · est. 1999</p>
    </header>

    <div class="bm-gate" id="bmGate" hidden>
      <p><b>🛂 SECURITY CHECKPOINT</b><br>Authorized banana personnel only. Present your credentials.</p>
      <div class="bm-gate__row">
        <input id="bmToken" type="password" placeholder="inbox token" autocomplete="off" aria-label="Inbox token" />
        <button class="bm-btn" id="bmClockIn" type="button">Clock in →</button>
      </div>
      <p class="bm-wrong" id="bmWrong" hidden>❌ Credentials rejected. The bouncer remembers faces.</p>
    </div>

    <div id="bmApp" hidden>
      <div class="bm-tabs" role="tablist" aria-label="Departments">
        <button class="bm-tab" id="bmTabMail" role="tab" aria-selected="true" type="button">✉ Mail room</button>
        <button class="bm-tab" id="bmTabGal" role="tab" aria-selected="false" type="button">🖼 Gallery inbox<span class="bm-badge" id="bmGalBadge" hidden></span></button>
        <button class="bm-tab" id="bmTabRave" role="tab" aria-selected="false" type="button">🪩 Rave names</button>
      </div>

      <div id="bmPaneMail">
        <div class="bm-bar">
          <span class="bm-count" id="bmCount"></span>
          <span id="bmChips"></span>
          <button class="bm-chip bm-chip--ghost" id="bmReadAll" type="button">✓ mark all read</button>
        </div>
        <div id="bmList"></div>
      </div>

      <div id="bmPaneGal" hidden>
        <div class="bm-gkey" id="bmGkeyGate" hidden>
          <p><b>🖼 CURATION DESK</b><br>The gallery inbox needs its own key (it lives in tools/gallery.local.json).</p>
          <div class="bm-gate__row">
            <input id="bmGkey" type="password" placeholder="gallery key" autocomplete="off" aria-label="Gallery key" />
            <button class="bm-btn" id="bmGkeySave" type="button">Unlock →</button>
          </div>
        </div>

        <div class="bm-bar" id="bmGalModes" hidden>
          <button class="bm-chip" id="bmModePending" aria-pressed="true" type="button">📥 pending</button>
          <button class="bm-chip" id="bmModeLive" aria-pressed="false" type="button">🖼 live</button>
        </div>

        <div id="bmGalPending">
          <div class="bm-bar"><span class="bm-count" id="bmGalCount"></span></div>
          <div id="bmGalList"></div>
        </div>

        <div id="bmGalLive" hidden>
          <div class="bm-bar bm-livetools">
            <input class="bm-livesearch" id="bmLiveQ" type="search" placeholder="🔍 search title / creator / tag / slug…" aria-label="Search submissions" />
            <span id="bmLiveChips"></span>
            <select class="bm-livesort" id="bmLiveSort" aria-label="Sort">
              <option value="new">newest first</option>
              <option value="old">oldest first</option>
              <option value="az">title A–Z</option>
            </select>
          </div>
          <p class="bm-livenote">Edits save instantly to the index — the live pages pick them up on the next site build (any push, or tonight's cron).</p>
          <div id="bmLiveList"></div>
        </div>
      </div>

      <!-- 🪩 RAVE NAMES — the strike desk (Trym's quick swipe on floor names) -->
      <div id="bmPaneRave" hidden>
        <div class="bm-bar">
          <button class="bm-chip" id="bmRaveRefresh" type="button">↻ refresh</button>
          <input class="bm-livesearch" id="bmStrikeInput" type="search" placeholder="strike a word/fragment manually…" style="max-width:280px;" aria-label="Word or fragment to strike" />
          <button class="bm-chip" id="bmStrikeAdd" type="button">🔨 strike</button>
        </div>
        <p class="bm-livenote">Names pass the family filter at the door; this desk is the backstop for the clever ones.
          Striking hides the name floor-wide INSTANTLY (their banana falls back to its outfit-name) and blocks it going forward.</p>
        <div id="bmRaveList"><p class="bm-livenote">Press refresh to load the ledger.</p></div>
      </div>

      <p class="bm-fine">
        BANANA MAIL™ is a wholly owned subsidiary of the Banana World.<br>
        Unauthorized peeling is prohibited and punishable by dance-off.<br>
        <button class="bm-chip bm-chip--ghost" id="bmLogout" type="button" style="margin-top:0.5rem;">🚪 clock out</button>
      </p>
    </div>
  </div>

  <script>
    // Trym's editorial items (baked at build; runtime overrides merge on top
    // in the live desk so the inputs always show the CURRENT values)
    import editorialBase from '../data/gallery.json';
    import { parseDesign } from '../lib/sticker-core.js';
    import { memeGif } from '../lib/meme-gif.js';

    const API = new URLSearchParams(location.search).get('api') || 'https://banana-contact.trymstene.workers.dev';
    const READ_KEY = 'inbox-read-v1';
    const el = (id) => document.getElementById(id);

    let token = '';
    let mails = [];
    let topic = 'all';

    const readSet = () => { try { return new Set(JSON.parse(localStorage.getItem(READ_KEY) || '[]')); } catch (e) { return new Set(); } };
    const saveRead = (s) => { try { localStorage.setItem(READ_KEY, JSON.stringify([...s].slice(-500))); } catch (e) {} };

    function fmtDate(ts) {
      const d = new Date(ts);
      return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }) + ', ' +
        d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }

    function render() {
      const read = readSet();
      const list = el('bmList');
      list.textContent = '';
      const shown = mails.filter((m) => topic === 'all' || m.topic === topic);
      const unread = mails.filter((m) => !read.has(m.key)).length;
      el('bmCount').textContent = '📥 ' + mails.length + ' item' + (mails.length === 1 ? '' : 's') + ' of official correspondence' + (unread ? ' · ' + unread + ' unread' : '');

      // topic chips, built from the data
      const topics = ['all', ...new Set(mails.map((m) => m.topic || 'general'))];
      const chips = el('bmChips');
      chips.textContent = '';
      topics.forEach((t) => {
        const b = document.createElement('button');
        b.className = 'bm-chip';
        b.type = 'button';
        b.textContent = t;
        b.setAttribute('aria-pressed', String(t === topic));
        b.onclick = () => { topic = t; render(); };
        chips.appendChild(b);
      });

      if (!shown.length) {
        const d = document.createElement('div');
        d.className = 'bm-empty';
        d.innerHTML = '<div class="bm-big">🏝</div><p>Inbox zero. The bananas rest.</p>';
        list.appendChild(d);
        return;
      }

      shown.forEach((m) => {
        const isRead = read.has(m.key);
        const card = document.createElement('article');
        card.className = 'bm-mail' + (isRead ? '' : ' bm-mail--unread');

        const head = document.createElement('button');
        head.className = 'bm-mail__head';
        head.type = 'button';
        const top = document.createElement('div');
        top.className = 'bm-mail__top';
        const stamp = document.createElement('span');
        stamp.className = 'bm-stamp' + (m.topic === 'licensing' ? ' bm-stamp--licensing' : '');
        stamp.textContent = m.topic || 'general';
        top.appendChild(stamp);
        top.appendChild(document.createTextNode(' stamped ' + fmtDate(m.ts) + ' · agent ' + String(m.sender || '?').slice(0, 8)));
        const from = document.createElement('p');
        from.className = 'bm-mail__from';
        if (!isRead) { const dot = document.createElement('span'); dot.className = 'bm-dot'; from.appendChild(dot); }
        from.appendChild(document.createTextNode((m.name || 'anonymous banana') + (m.email ? ' <' + m.email + '>' : '')));
        const peek = document.createElement('p');
        peek.className = 'bm-mail__peek';
        peek.textContent = String(m.message || '').slice(0, 90);
        head.appendChild(top); head.appendChild(from); head.appendChild(peek);

        const body = document.createElement('div');
        body.className = 'bm-mail__body';
        body.hidden = true;
        const msg = document.createElement('pre');
        msg.className = 'bm-mail__msg';
        msg.textContent = m.message || '';
        const actions = document.createElement('div');
        actions.className = 'bm-mail__actions';
        if (m.email) {
          const reply = document.createElement('a');
          reply.className = 'bm-btn';
          reply.href = 'mailto:' + encodeURIComponent(m.email) + '?subject=' + encodeURIComponent('Re: your message to the banana guy 🍌');
          reply.textContent = '✉ reply';
          actions.appendChild(reply);
        }
        const shred = document.createElement('button');
        shred.className = 'bm-btn bm-btn--shred';
        shred.type = 'button';
        shred.textContent = '🗑 shred';
        shred.onclick = async () => {
          if (shred.dataset.arm !== '1') { shred.dataset.arm = '1'; shred.textContent = '⚠ shred, really?'; setTimeout(() => { shred.dataset.arm = ''; shred.textContent = '🗑 shred'; }, 3000); return; }
          shred.disabled = true; shred.textContent = 'shredding…';
          try {
            const r = await fetch(API + '/delete', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ token, keys: [m.key] }) });
            const d = await r.json();
            if (d.ok) {
              card.classList.add('bm-mail--shredding');
              setTimeout(() => { mails = mails.filter((x) => x.key !== m.key); render(); }, 360);
            } else { shred.disabled = false; shred.textContent = '🗑 shred'; }
          } catch (e) { shred.disabled = false; shred.textContent = '🗑 shred'; }
        };
        actions.appendChild(shred);
        body.appendChild(msg); body.appendChild(actions);

        head.onclick = () => {
          body.hidden = !body.hidden;
          if (!read.has(m.key)) { const s = readSet(); s.add(m.key); saveRead(s); card.classList.remove('bm-mail--unread'); const dt = from.querySelector('.bm-dot'); if (dt) dt.remove(); render0nly(); }
        };
        card.appendChild(head); card.appendChild(body);
        list.appendChild(card);
      });

      function render0nly() { // refresh just the counter without collapsing open mails
        const rd = readSet();
        const un = mails.filter((x) => !rd.has(x.key)).length;
        el('bmCount').textContent = '📥 ' + mails.length + ' item' + (mails.length === 1 ? '' : 's') + ' of official correspondence' + (un ? ' · ' + un + ' unread' : '');
      }
    }

    async function load() {
      const r = await fetch(API + '/messages?token=' + encodeURIComponent(token));
      if (r.status === 403) return false;
      mails = await r.json();
      return true;
    }

    async function boot() {
      // token: URL fragment (from the old bookmark redirect) → localStorage → ask
      const frag = new URLSearchParams(location.hash.slice(1));
      if (frag.get('gkey')) { // gallery key may ride the same bookmark fragment
        gkey = frag.get('gkey');
        try { localStorage.setItem('gallery-key', gkey); } catch (e) {}
      }
      if (frag.get('token')) {
        token = frag.get('token');
        history.replaceState(null, '', location.pathname); // never leave it visible
      } else {
        try { token = localStorage.getItem('inbox-token') || ''; } catch (e) {}
      }
      if (frag.get('gkey') && !frag.get('token')) history.replaceState(null, '', location.pathname);
      if (token && await load().catch(() => false)) {
        try { localStorage.setItem('inbox-token', token); } catch (e) {}
        el('bmApp').hidden = false;
        render();
        return;
      }
      token = '';
      el('bmGate').hidden = false;
    }

    el('bmClockIn').onclick = async () => {
      token = el('bmToken').value.trim();
      el('bmWrong').hidden = true;
      if (token && await load().catch(() => false)) {
        try { localStorage.setItem('inbox-token', token); } catch (e) {}
        el('bmGate').hidden = true;
        el('bmApp').hidden = false;
        render();
      } else {
        token = '';
        el('bmWrong').hidden = false;
      }
    };
    el('bmToken').addEventListener('keydown', (e) => { if (e.key === 'Enter') el('bmClockIn').click(); });

    el('bmReadAll').onclick = () => {
      const s = readSet();
      mails.forEach((m) => s.add(m.key));
      saveRead(s);
      render();
    };
    el('bmLogout').onclick = () => {
      try { localStorage.removeItem('inbox-token'); } catch (e) {}
      try { localStorage.removeItem('gallery-key'); } catch (e) {}
      location.reload();
    };

    // ── 🖼 THE CURATION DESK — the gallery inbox under the same roof ──
    const GAL = 'https://banana-share.trymstene.workers.dev';
    let gkey = '';
    try { gkey = localStorage.getItem('gallery-key') || ''; } catch (e) {}
    let galItems = null; // null = not loaded yet

    function setTab(which) { // 'mail' | 'gal' | 'rave'
      el('bmTabMail').setAttribute('aria-selected', String(which === 'mail'));
      el('bmTabGal').setAttribute('aria-selected', String(which === 'gal'));
      el('bmTabRave').setAttribute('aria-selected', String(which === 'rave'));
      el('bmPaneMail').hidden = which !== 'mail';
      el('bmPaneGal').hidden = which !== 'gal';
      el('bmPaneRave').hidden = which !== 'rave';
      if (which === 'gal') galBoot();
      if (which === 'rave') raveLoad();
    }
    el('bmTabMail').onclick = () => setTab('mail');
    el('bmTabGal').onclick = () => setTab('gal');
    el('bmTabRave').onclick = () => setTab('rave');

    // ── 🪩 THE RAVE NAMES DESK — Trym's quick swipe on floor names ──
    // Uses the SAME key value as the gallery desk (set RAVE_KEY on worker-rave
    // to the gallery.local.json key). Fails closed until the secret exists.
    const RAVE_API = 'https://banana-rave.trymstene.workers.dev';
    const rEsc = (s) => String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    async function raveLoad() {
      if (!gkey) { el('bmRaveList').innerHTML = '<p class="bm-livenote">Unlock the gallery desk first — this desk shares its key.</p>'; return; }
      let d;
      try {
        const r = await fetch(RAVE_API + '/names?key=' + encodeURIComponent(gkey));
        if (r.status === 403) { el('bmRaveList').innerHTML = '<p class="bm-livenote">403 — set the RAVE_KEY secret on worker-rave (same value as the gallery key).</p>'; return; }
        if (!r.ok) throw new Error(r.status);
        d = await r.json();
      } catch (e) { el('bmRaveList').innerHTML = '<p class="bm-livenote">Could not reach the floor — try again.</p>'; return; }
      const fmt = (t) => new Date(t).toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
      const live = new Set(d.live || []);
      el('bmRaveList').innerHTML =
        '<p class="bm-count">' + (d.live || []).length + ' named on the floor now · ' + (d.names || []).length + ' seen · ' + (d.strikes || []).length + ' struck</p>'
        + ((d.strikes || []).length
          ? '<p class="bm-livenote">🔨 struck: ' + d.strikes.map((s) => rEsc(s) + ' <button class="bm-chip bm-chip--ghost" data-unstrike="' + rEsc(s) + '">undo</button>').join(' · ') + '</p>'
          : '')
        + (d.names || []).map((x) => '<div class="bm-bar" style="justify-content:space-between;">'
          + '<span>' + (live.has(x.n) ? '🟢 ' : '') + '<b>' + rEsc(x.n) + '</b> <span style="opacity:0.55;font-size:0.75rem;">' + fmt(x.at) + '</span></span>'
          + '<button class="bm-chip" data-strike="' + rEsc(x.n) + '">🔨 strike</button></div>').join('')
        || '<p class="bm-livenote">No names seen yet — the floor is all outfit-names so far.</p>';
      el('bmRaveList').querySelectorAll('[data-strike]').forEach((b) => { b.onclick = () => raveStrike(b.dataset.strike, false); });
      el('bmRaveList').querySelectorAll('[data-unstrike]').forEach((b) => { b.onclick = () => raveStrike(b.dataset.unstrike, true); });
    }
    async function raveStrike(t, remove) {
      try {
        const r = await fetch(RAVE_API + '/strike?key=' + encodeURIComponent(gkey), {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ t, remove }),
        });
        if (!r.ok) { alert('strike failed (' + r.status + ')'); return; }
      } catch (e) { alert('strike failed'); return; }
      raveLoad();
    }
    el('bmRaveRefresh').onclick = raveLoad;
    el('bmStrikeAdd').onclick = () => { const v = el('bmStrikeInput').value.trim(); if (v) { raveStrike(v, false); el('bmStrikeInput').value = ''; } };

    // pending ↔ live sub-desks
    function setGalMode(live) {
      el('bmModePending').setAttribute('aria-pressed', String(!live));
      el('bmModeLive').setAttribute('aria-pressed', String(live));
      el('bmGalPending').hidden = live;
      el('bmGalLive').hidden = !live;
      if (live) liveBoot();
    }
    el('bmModePending').onclick = () => setGalMode(false);
    el('bmModeLive').onclick = () => setGalMode(true);

    async function galLoad() {
      const r = await fetch(GAL + '/gallery/pending-list?key=' + encodeURIComponent(gkey));
      if (!r.ok) return false;
      galItems = await r.json();
      return true;
    }
    async function galBoot() {
      if (gkey && galItems === null) {
        if (await galLoad().catch(() => false)) { el('bmGalModes').hidden = false; galRender(); return; }
        gkey = '';
      }
      if (!gkey) { el('bmGkeyGate').hidden = false; el('bmGalCount').textContent = ''; return; }
      el('bmGalModes').hidden = false;
      galRender();
    }
    el('bmGkeySave').onclick = async () => {
      gkey = el('bmGkey').value.trim();
      if (gkey && await galLoad().catch(() => false)) {
        try { localStorage.setItem('gallery-key', gkey); } catch (e) {}
        el('bmGkeyGate').hidden = true;
        el('bmGalModes').hidden = false;
        galRender();
      } else { gkey = ''; el('bmGkey').value = ''; el('bmGkey').placeholder = '❌ wrong key — try again'; }
    };
    el('bmGkey').addEventListener('keydown', (e) => { if (e.key === 'Enter') el('bmGkeySave').click(); });

    function galBadge() {
      const b = el('bmGalBadge');
      const n = galItems ? galItems.length : 0;
      b.hidden = !n;
      b.textContent = n;
    }
    function galRender() {
      const list = el('bmGalList');
      list.textContent = '';
      galBadge();
      el('bmGalCount').textContent = '🖼 ' + galItems.length + ' submission' + (galItems.length === 1 ? '' : 's') + ' awaiting curation';
      if (!galItems.length) {
        const d = document.createElement('div');
        d.className = 'bm-empty';
        d.innerHTML = '<div class="bm-big">🖼</div><p>Curation desk clear. The gallery rests.</p>';
        list.appendChild(d);
        return;
      }
      galItems.forEach((it) => {
        const card = document.createElement('article');
        card.className = 'bm-pend';
        const box = document.createElement('div');
        box.className = 'bm-pend__img';
        const img = document.createElement('img');
        img.src = GAL + '/gallery/pending/' + it.id + '.gif?key=' + encodeURIComponent(gkey);
        img.alt = '';
        box.appendChild(img);
        const meta = document.createElement('div');
        meta.className = 'bm-pend__meta';
        const titleIn = document.createElement('input');
        titleIn.value = it.title || '';
        titleIn.maxLength = 60;
        titleIn.placeholder = 'title — becomes the page';
        const tagsIn = document.createElement('input');
        tagsIn.maxLength = 120;
        tagsIn.placeholder = 'tags, comma-separated (monday, work, vibes…)';
        tagsIn.style.marginTop = '0.4rem';
        const line = document.createElement('p');
        line.className = 'bm-pend__line';
        line.textContent = (it.transparent ? 'sticker (transparent)' : 'gif (solid)') + ' · ' + it.kb + ' KB · by ' +
          (it.by || 'anonymous') + ' · ' + fmtDate(it.created);
        const actions = document.createElement('div');
        actions.className = 'bm-mail__actions';
        const hang = document.createElement('button');
        hang.className = 'bm-btn bm-btn--hang';
        hang.type = 'button';
        hang.textContent = '🖼 hang it';
        const bin = document.createElement('button');
        bin.className = 'bm-btn bm-btn--shred';
        bin.type = 'button';
        bin.textContent = '🗑 reject';
        async function moderate(action) {
          hang.disabled = bin.disabled = true;
          try {
            const r = await fetch(GAL + '/gallery/moderate?key=' + encodeURIComponent(gkey), {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ id: it.id, action, title: titleIn.value, tags: tagsIn.value }),
            });
            const d = await r.json();
            if (d.ok) {
              card.classList.add('bm-mail--shredding');
              setTimeout(() => { galItems = galItems.filter((x) => x.id !== it.id); galRender(); }, 360);
              return;
            }
            alert(d.error || 'failed');
          } catch (e) { alert('the desk is busy — try again'); }
          hang.disabled = bin.disabled = false;
        }
        hang.onclick = () => moderate('approve');
        bin.onclick = () => {
          if (bin.dataset.arm !== '1') { bin.dataset.arm = '1'; bin.textContent = '⚠ reject, really?'; setTimeout(() => { bin.dataset.arm = ''; bin.textContent = '🗑 reject'; }, 3000); return; }
          moderate('reject');
        };
        actions.appendChild(hang); actions.appendChild(bin);
        meta.appendChild(titleIn); meta.appendChild(tagsIn); meta.appendChild(line); meta.appendChild(actions);
        card.appendChild(box); card.appendChild(meta);
        list.appendChild(card);
      });
    }
    // ── the LIVE catalogue: BOTH lanes (Trym's editorial + community),
    //    search / filter / sort / edit — scales to 100s ──
    let liveItems = null;
    let liveFilter = 'all';
    async function liveLoad() {
      const [ap, ov] = await Promise.all([
        fetch(GAL + '/gallery/approved', { cache: 'no-store' }).then((r) => r.ok ? r.json() : []),
        fetch(GAL + '/gallery/overrides', { cache: 'no-store' }).then((r) => r.ok ? r.json() : {}).catch(() => ({})),
      ]);
      const mine = editorialBase.map((i) => ({
        lane: 'mine', key: i.id,
        title: (ov[i.id] && ov[i.id].title) || i.title,
        tags: (ov[i.id] && Array.isArray(ov[i.id].tags)) ? ov[i.id].tags : i.tags,
        kind: i.kind, img: '/assets/gallery-bananas/' + i.file,
        href: '/banana-memes/' + i.id + '/', ts: Date.parse(i.added) || 0, by: null,
      }));
      const comm = (ap || []).map((c) => ({
        lane: 'community', key: c.slug,
        title: c.title, tags: c.tags || [], by: c.by || '', params: c.params || '',
        kind: c.transparent ? 'sticker' : 'gif',
        img: GAL + '/gallery/gif/' + c.slug + '.gif?v=' + (c.updated || c.approved || c.created || 0),
        href: '/banana-memes/by/' + c.slug + '/', ts: c.approved || 0,
      }));
      liveItems = [...comm, ...mine];
      return true;
    }
    async function liveBoot() {
      if (liveItems === null) { if (!(await liveLoad().catch(() => false))) { liveItems = []; } }
      liveRender();
    }
    el('bmLiveQ').addEventListener('input', () => liveRender());
    el('bmLiveSort').addEventListener('change', () => liveRender());

    function liveRender() {
      const q = el('bmLiveQ').value.trim().toLowerCase();
      const sort = el('bmLiveSort').value;
      let shown = liveItems.filter((it) => {
        const hay = (it.title + ' ' + (it.by || '') + ' ' + it.key + ' ' + it.tags.join(' ')).toLowerCase();
        if (q && !hay.includes(q)) return false;
        if (liveFilter === 'untagged') return !it.tags.length;
        if (liveFilter === 'mine') return it.lane === 'mine';
        if (liveFilter === 'community') return it.lane === 'community';
        if (liveFilter === 'sticker') return it.kind === 'sticker';
        if (liveFilter === 'gif') return it.kind === 'gif';
        return true;
      });
      shown = shown.slice().sort((a, b) =>
        sort === 'old' ? a.ts - b.ts :
        sort === 'az' ? a.title.localeCompare(b.title) :
        b.ts - a.ts);

      // filter chips with live counts
      const chips = el('bmLiveChips');
      chips.textContent = '';
      const untagged = liveItems.filter((it) => !it.tags.length).length;
      [['all', 'all (' + liveItems.length + ')'],
       ['untagged', '🏷 untagged (' + untagged + ')'],
       ['mine', '🍌 mine'], ['community', '👥 community'],
       ['sticker', 'stickers'], ['gif', 'gifs']].forEach(([v, label]) => {
        const b = document.createElement('button');
        b.className = 'bm-chip';
        b.type = 'button';
        b.textContent = label;
        b.setAttribute('aria-pressed', String(liveFilter === v));
        b.onclick = () => { liveFilter = v; liveRender(); };
        chips.appendChild(b);
      });

      const list = el('bmLiveList');
      list.textContent = '';
      if (!shown.length) {
        const d = document.createElement('div');
        d.className = 'bm-empty';
        d.innerHTML = '<div class="bm-big">🔍</div><p>No bananas match.</p>';
        list.appendChild(d);
        return;
      }
      shown.forEach((it) => {
        const row = document.createElement('article');
        row.className = 'bm-live';
        const box = document.createElement('div');
        box.className = 'bm-live__img';
        const img = document.createElement('img');
        img.loading = 'lazy';
        img.src = it.img;
        img.alt = '';
        box.appendChild(img);

        const meta = document.createElement('div');
        meta.className = 'bm-live__meta';
        const titleIn = document.createElement('input');
        titleIn.value = it.title || '';
        titleIn.maxLength = 60;
        titleIn.placeholder = 'title';
        const row2 = document.createElement('div');
        row2.className = 'bm-live__row2';
        const tagsIn = document.createElement('input');
        tagsIn.value = it.tags.join(', ');
        tagsIn.maxLength = 120;
        tagsIn.placeholder = 'tags, comma-separated';
        row2.appendChild(tagsIn);
        let byIn = null;
        if (it.lane === 'community') {
          byIn = document.createElement('input');
          byIn.value = it.by || '';
          byIn.maxLength = 24;
          byIn.placeholder = 'creator (byline)';
          row2.appendChild(byIn);
        }

        const foot = document.createElement('div');
        foot.className = 'bm-live__foot';
        const view = document.createElement('a');
        view.href = it.href;
        view.target = '_blank';
        view.textContent = '↗ view';
        foot.appendChild(view);
        foot.appendChild(document.createTextNode(
          (it.lane === 'mine' ? '🍌 mine' : '👥 community') + ' · ' + it.kind + (it.ts ? ' · ' + fmtDate(it.ts) : '')));
        const save = document.createElement('button');
        save.className = 'bm-btn bm-live__save';
        save.type = 'button';
        save.textContent = '💾 save';
        const markDirty = () => row.classList.add('bm-live--dirty');
        titleIn.oninput = tagsIn.oninput = markDirty;
        if (byIn) byIn.oninput = markDirty;
        save.onclick = async () => {
          save.disabled = true; save.textContent = 'saving…';
          try {
            const payload = it.lane === 'mine'
              ? { eid: it.key, title: titleIn.value, tags: tagsIn.value }
              : { slug: it.key, title: titleIn.value, tags: tagsIn.value, by: byIn ? byIn.value : undefined };
            const r = await fetch(GAL + '/gallery/edit?key=' + encodeURIComponent(gkey), {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            const d = await r.json();
            if (d.ok && d.entry) {
              if (d.entry.title) { it.title = d.entry.title; titleIn.value = d.entry.title; }
              if (Array.isArray(d.entry.tags)) { it.tags = d.entry.tags; tagsIn.value = it.tags.join(', '); }
              if (d.entry.by !== undefined && byIn) { it.by = d.entry.by; byIn.value = it.by; }
              row.classList.remove('bm-live--dirty');
              save.textContent = '✓ saved';
              setTimeout(() => { save.textContent = '💾 save'; save.disabled = false; }, 1200);
              return;
            }
            alert(d.error || 'failed');
          } catch (e) { alert('the desk is busy — try again'); }
          save.disabled = false; save.textContent = '💾 save';
        };
        foot.appendChild(save);
        // RE-RENDER: re-bake this item's GIF from its stored params with the
        // current caption font (Anton) and overwrite it in R2. Pixel-identical
        // to what visitors download (shared meme-gif renderer).
        if (it.lane === 'community' && it.params) {
          const rr = document.createElement('button');
          rr.className = 'bm-btn'; rr.type = 'button'; rr.textContent = '🔁 re-render';
          rr.title = 'Re-bake the GIF from stored params with the current font (Anton)';
          rr.onclick = async () => {
            rr.disabled = true; rr.textContent = 'rendering…';
            try {
              const st = parseDesign(new URLSearchParams(it.params));
              const { blob } = await memeGif(st);
              rr.textContent = 'uploading…';
              const r = await fetch(GAL + '/gallery/replace?key=' + encodeURIComponent(gkey) + '&slug=' + encodeURIComponent(it.key), {
                method: 'POST', headers: { 'Content-Type': 'image/gif' }, body: blob });
              const d = await r.json();
              if (d.ok) {
                img.src = GAL + '/gallery/gif/' + it.key + '.gif?v=' + d.updated; // bust the preview
                rr.textContent = '✓ re-rendered';
                setTimeout(() => { rr.textContent = '🔁 re-render'; rr.disabled = false; }, 1500);
                return;
              }
              rr.textContent = 'error: ' + (d.error || '?');
            } catch (e) { console.error(e); rr.textContent = 'render failed'; }
            setTimeout(() => { rr.textContent = '🔁 re-render'; rr.disabled = false; }, 2200);
          };
          foot.appendChild(rr);
        }
        meta.appendChild(titleIn); meta.appendChild(row2); meta.appendChild(foot);
        row.appendChild(box); row.appendChild(meta);
        list.appendChild(row);
      });
    }

    // preload the badge so the tab shows the pending count on arrival
    if (gkey) galLoad().then((ok) => { if (ok) galBadge(); }).catch(() => {});

    boot();
  </script>
</BaseLayout>
