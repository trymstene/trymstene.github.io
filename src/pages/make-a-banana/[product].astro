---
// Custom product PDP — a product page for a banana designed in the builder.
// ONE route serves every sellable custom product (sticker, magnet, …); the
// list comes from shared/products.js so adding a product needs no new page.
// Same look as the official shop (.pdp / shop.css) so custom + shop feel like
// one store; the "product image" is rendered live from the design in the URL
// and checkout runs the custom pipeline (sticker-pdp.js → sticker-core.js).
// Transient per-design page → noindex.
import BaseLayout from '../../layouts/BaseLayout.astro';
import PixelIcon from '../../components/PixelIcon.astro';
import PRODUCTS from '../../../shared/products.js';
import { sizeTableForGuideId } from '../../lib/shop.js';

export function getStaticPaths() {
  // every catalog product gets a page (noindex anyway); a not-yet-live one
  // renders as a preview with the buy button replaced by a "soon" note, so
  // launching it later is just flipping `live` in shared/products.js
  return PRODUCTS.map((p) => ({ params: { product: p.key }, props: { p } }));
}
const { p } = Astro.props;
const nameLc = p.name.toLowerCase();
// apparel gets the SAME real-Printful size chart as the official shop
const sizeGuide = p.options ? sizeTableForGuideId(p.options.sizeGuideId, p.options.sizes) : null;
// cross-sell: the same design on every OTHER live product (manifest-driven —
// a new product automatically appears here). Design params attach client-side.
const others = PRODUCTS.filter((x) => x.live && x.key !== p.key);
---
<BaseLayout
  title={`Your custom Dancing Banana ${nameLc} | Trym Stene`}
  description={`Order the banana you just made as a real ${nameLc} — printed on demand and shipped worldwide with free shipping.`}
  robots="noindex,follow"
>
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/shop.css" />
    <style is:global>
      /* the PDP pose picker — same idea as the builder's freeze strip: you can
         still change your mind about the MOVE right up until you order.
         is:global because the strip's buttons are created by JS at runtime,
         so Astro's scoped-style attribute never lands on them */
      .pdp-poses__wrap { margin-top: 0.9rem; }
      .pdp-poses__label { margin: 0 0 0.5rem; font-size: 0.9rem; }
      .pdp-poses {
        display: flex; gap: 0.5rem; flex-wrap: nowrap; overflow-x: auto;
        scroll-snap-type: x proximity; -webkit-overflow-scrolling: touch; padding-bottom: 6px;
      }
      .pdp-poses button {
        flex: 0 0 auto; padding: 2px; background: #fff; border: 3px solid var(--ink, #111);
        cursor: pointer; line-height: 0; scroll-snap-align: start;
      }
      .pdp-poses button[aria-pressed="true"] {
        border-color: var(--hot, #ff2e88); box-shadow: 3px 3px 0 var(--ink, #111);
      }
      .pdp-poses canvas { width: 64px; height: 64px; image-rendering: pixelated; display: block; }
      .pdp-poses img { width: 64px; height: 64px; object-fit: cover; display: block; }
      /* mockup zoom: desktop hovers to magnify where the cursor points;
         touch taps to zoom, drags to look around, taps again to reset */
      .pdp-zoom { overflow: hidden; position: relative; }
      @media (hover: hover) { .pdp-zoom { cursor: zoom-in; } }
      .pdp-zoom canvas { transition: transform 0.15s ease-out; transform-origin: 50% 50%; }
      .pdp-zoom.zooming canvas { transition: none; }
      .pdp-zoom.zoomed { cursor: zoom-out; }
      .pdp-zoomhint {
        position: absolute; right: 10px; bottom: 10px; z-index: 3; pointer-events: none;
        background: var(--ink, #111); color: #ffe135; font-size: 0.72rem; font-weight: 800;
        letter-spacing: 0.04em; padding: 0.35rem 0.6rem; opacity: 0.92;
        transition: opacity 0.9s ease;
      }
      .pdp-zoomhint.fade { opacity: 0; }
      /* apparel options: colour swatches + size chips (tee) */
      .pdp-opts { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.45rem; }
      .pdp-swatch {
        width: 40px; height: 40px; padding: 0; border: 3px solid var(--ink, #111);
        cursor: pointer; box-shadow: 2px 2px 0 rgba(17,17,17,.35);
      }
      .pdp-swatch[aria-pressed="true"] {
        outline: 3px solid var(--hot, #ff2e88); outline-offset: 2px;
      }
      .pdp-sizebtn {
        font: inherit; font-weight: 800; min-width: 46px; min-height: 40px;
        background: #fff; color: var(--ink, #111); border: 3px solid var(--ink, #111);
        cursor: pointer; padding: 0.3rem 0.6rem;
      }
      .pdp-sizebtn[aria-pressed="true"] {
        background: var(--ink, #111); color: #ffe135; box-shadow: 3px 3px 0 rgba(17,17,17,.35);
      }
    </style>
  </Fragment>

  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Home</a><span>›</span><a href="/make-a-banana/">Make a Banana</a><span>›</span><b>Your {nameLc}</b>
  </nav>

  <main class="pdp" id="pdpRoot" data-product={p.key}>
    <div class="pdp__gallery">
      <div class="pdp-zoom" id="pdpZoom">
        <canvas id="pdpMock" class="pdp__main" width="900" height="900" aria-label={`Preview of your banana as a real ${nameLc}`}></canvas>
      </div>
      {p.options && (
        <div class="pdp-poses" id="pdpStyles" role="group" aria-label="Mockup style" style="margin-top:0.7rem;">
          <button type="button" data-mstyle="woman" aria-pressed="true" aria-label="On a model">
            <img src="/assets/tee/tee-woman-white.jpg" alt="" loading="lazy"></button>
          <button type="button" data-mstyle="man" aria-pressed="false" aria-label="On another model">
            <img src="/assets/tee/tee-man-white.jpg" alt="" loading="lazy"></button>
          <button type="button" data-mstyle="flat" aria-pressed="false" aria-label="Flat">
            <img src="/assets/tee/tee-flat-white.jpg" alt="" loading="lazy"></button>
        </div>
      )}
      <div class="pdp-poses__wrap">
        <p class="pdp-poses__label"><strong>Pick your pose</strong> — the move that gets printed</p>
        <div class="pdp-poses" id="pdpPoses" role="group" aria-label="Pick your pose"></div>
      </div>
      <p style="margin:0.9rem 0 0;font-size:0.9rem;">
        <a id="pdpBack" href="/make-a-banana/"><PixelIcon name="palette" /> Back to editing</a>
      </p>
    </div>

    <div class="pdp__info">
      <h1>Your custom {nameLc}</h1>
      <p class="pdp__tag">The exact banana you just made — printed and mailed to your door.</p>
      <div class="pdp-pricetags">
        <p class="pdp__price price-tag" id="pdpPrice"><small>from</small> ${p.priceHint}</p>
        <span class="price-tag price-tag--ship">🌍 free worldwide shipping</span>
      </div>
      <p class="pdp__note" id="pdpNote">Tax included where applicable</p>

      <div class="pdp-field">
        <div class="pdp-field__label">What you get</div>
        <p id="pdpCut" style="margin:0;font-weight:500;">
          {p.options
            ? `${p.material} — your banana printed big on the front`
            : `${p.size} ${p.material}, die-cut along your design’s outline`}
        </p>
        <p id="pdpHint" hidden style="margin:0.5rem 0 0;font-size:0.85rem;font-weight:700;color:var(--hot);"></p>
      </div>

      {p.options && (
        <div class="pdp-field">
          <div class="pdp-field__label">Colour</div>
          <div class="pdp-opts" id="pdpColors">
            {p.options.colors.map((c, i) => (
              <button type="button" class="pdp-swatch" data-color={c.id} data-hex={c.hex}
                aria-pressed={i === 0 ? 'true' : 'false'} title={c.label} aria-label={c.label}
                style={`background:${c.hex}`}></button>
            ))}
          </div>
          <div class="pdp-field__label" style="margin-top:0.9rem;">Size <span style="font-weight:500;opacity:.7;">(unisex)</span>
            {sizeGuide && <span style="font-weight:500;"> — <a href="#size-guide">size guide</a></span>}</div>
          <div class="pdp-opts" id="pdpSizes">
            {p.options.sizes.map((s) => (
              <button type="button" class="pdp-sizebtn" data-size={s}
                aria-pressed={s === 'M' ? 'true' : 'false'}>{s}</button>
            ))}
          </div>
        </div>
      )}

      {p.live ? (
        <button class="btn btn--dark pdp-buy" id="pdpBuy"><PixelIcon name="tag" size="1.3em" /> Order — to checkout</button>
      ) : (
        <button class="btn btn--dark pdp-buy" disabled style="opacity:.55;cursor:default;">Landing any day now 🍌</button>
      )}
      <p class="pdp-stock" id="pdpStock"></p>

      {others.length > 0 && (
        <p class="pdp-xsell">
          Same banana, different thing:
          {others.map((o) => (
            <a class="pdp-xsell__link" data-xsell href={`/make-a-banana/${o.key}/`}>as a {o.name.toLowerCase()} (${o.priceHint}) →</a>
          ))}
        </p>
      )}

      <ul class="pdp-trust">
        <li>Checked by the banana guy himself before it ships</li>
        <li>{p.size} {p.material}, printed on demand</li>
        <li>Free shipping worldwide</li>
        <li>Free replacement if it arrives wrong — <a href="/shop/policies/">shipping &amp; returns</a></li>
        <li>Made by the creator of the original 1999 Dancing Banana</li>
      </ul>

      {sizeGuide && (
        <details id="size-guide" class="pdp-details">
          <summary>Size guide &amp; measurements</summary>
          <div class="pdp-details__body" set:html={sizeGuide}></div>
        </details>
      )}
    </div>
  </main>

  <section class="block">
    <p class="kicker">Keep going</p>
    <h2>More banana</h2>
    <p class="lead">
      <a href="/make-a-banana/"><PixelIcon name="palette" /> Back to the builder</a> ·
      <a href="/shop/">Official merch</a> ·
      <a href="/dancing-banana-gif-meme/">The story &amp; free GIF</a>
    </p>
  </section>

  <script>
    import '../../scripts/sticker-pdp.js';
  </script>
</BaseLayout>
