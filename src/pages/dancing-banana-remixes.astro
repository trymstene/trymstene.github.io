---
// The community remix gallery — 268 dancing-banana remixes made by the
// internet over 25+ years, honoured properly: categorised, rated in bananas,
// every one downloadable. Data comes from tools/build-remix-gallery.py.
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelIcon from '../components/PixelIcon.astro';
import remixesBase from '../data/remixes.json';
import remixMeta from '../data/remix-meta.json';

// merge the curated overlay (slug / corrected title / blurb) into each remix so
// the cards can link to real detail pages and the modal can render from data
const metaById = Object.fromEntries(remixMeta.map((m) => [m.id, m]));
const remixes = remixesBase.map((r) => {
  const m = metaById[r.id] || {};
  return { ...r, slug: m.slug, title: m.title || r.title, blurb: m.blurb };
});

// Targets the "banana meme(s)" COLLECTION intent (199k impr/16mo cluster the
// single-GIF hub can't fully serve). Distinct from the hub, which owns the head
// term "banana meme" (singular/origin); this spoke owns the browse-many intent
// and is tied to the hub as a part-of entity below → no cannibalisation.
const title = `${remixes.length} Banana Memes — Dancing Banana GIFs by the Internet`;
const description = `${remixes.length} banana memes: Dancing Banana GIF remixes the internet has made since 1999 — warrior bananas, Mario, Homer, dancing tacos. Browse, rate and download them free.`;
const counts = remixes.reduce((a, r) => { a[r.cat] = (a[r.cat] || 0) + 1; return a; }, {});
// SSR every card as a real <img> so crawlers + Google Images (and no-JS
// visitors) see actual banana-meme content, not an empty grid — the whole
// image-pack play depends on these being crawlable. The gallery JS wipes and
// rebuilds the grid on load for the interactive (paginated) version.
const SSR = remixes;

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Dancing Banana GIF", "item": "https://trymstene.com/dancing-banana-gif-meme/" },
    { "@type": "ListItem", "position": 2, "name": "Banana Memes", "item": "https://trymstene.com/dancing-banana-remixes/" }
  ]
};
const gallery = {
  "@context": "https://schema.org",
  "@type": "ImageGallery",
  "@id": "https://trymstene.com/dancing-banana-remixes/#gallery",
  "url": "https://trymstene.com/dancing-banana-remixes/",
  "name": `Banana Memes — ${remixes.length} Dancing Banana GIFs by the Internet`,
  "description": description,
  "about": { "@id": "https://trymstene.com/#banana-gif" },
  "isPartOf": { "@id": "https://trymstene.com/#banana-gif" },
  "creator": { "@type": "Person", "name": "Trym Stene", "url": "https://trymstene.com/" }
};
const CATS = [
  ['all', 'All', remixes.length],
  ['banana', 'Banana remixes', counts.banana || 0],
  ['characters', 'Characters', counts.characters || 0],
  ['food', 'Food', counts.food || 0],
  ['wild', 'Wildcards', counts.wild || 0],
];
---

<BaseLayout
  title={title}
  description={description}
  ogTitle="Banana Memes — the Dancing Banana Remix Gallery"
  ogDescription={`${remixes.length} dancing banana memes by the internet, since 1999. Rate them in bananas.`}
  ogImage="https://trymstene.com/assets/og/gif.png"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />
    <script type="application/ld+json" set:html={JSON.stringify(gallery)} />
  </Fragment>
  <style is:inline slot="head">
    .rmx-filters { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin: 1.6rem 0 0.4rem; }
    .rmx-chip {
      background: var(--paper); color: var(--ink); border: 3px solid var(--ink); cursor: pointer;
      font-weight: 800; font-size: 0.85rem; padding: 0.45rem 0.9rem; border-radius: 2px;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .rmx-chip[aria-pressed="true"] { background: var(--ink); color: var(--banana); }
    .rmx-sort { margin: 0.6rem auto 0; display: flex; gap: 0.5rem; justify-content: center; align-items: center; font-size: 0.85rem; font-weight: 700; }
    .rmx-sort select { border: 3px solid var(--ink); background: var(--paper); font: inherit; padding: 0.3rem 0.5rem; }
    .rmx-grid {
      display: grid; gap: 1rem; margin-top: 1.6rem;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      max-width: 1160px; margin-left: auto; margin-right: auto;
    }
    .rmx-card {
      background: var(--paper); border: 3px solid var(--ink); box-shadow: 5px 5px 0 #000;
      display: flex; flex-direction: column; text-align: center;
    }
    .rmx-card .rmx-box {
      aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
      background: #fff; border-bottom: 3px solid var(--ink); overflow: hidden;
    }
    .rmx-card img { image-rendering: pixelated; width: 72%; height: 72%; object-fit: contain; }
    .rmx-card h3 { font-size: 0.8rem; margin: 0.5rem 0.4rem 0.15rem; line-height: 1.25; min-height: 2em; display: flex; align-items: center; justify-content: center; }
    .rmx-stars { display: flex; justify-content: center; gap: 2px; padding: 0.1rem 0 0; }
    .rmx-stars button {
      background: none; border: 0; cursor: pointer; font-size: 1rem; line-height: 1; padding: 2px;
      filter: grayscale(1) opacity(0.35); touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .rmx-stars button.on { filter: none; }
    .rmx-count { font-size: 0.68rem; opacity: 0.65; font-weight: 700; min-height: 1em; }
    .rmx-dl {
      margin: 0.45rem 0.45rem 0.45rem; font-size: 0.72rem; font-weight: 800; text-decoration: none;
      border: 2px solid var(--ink); padding: 0.3rem 0; color: var(--ink); background: var(--banana);
    }
    .rmx-more { margin: 1.6rem auto 0; display: block; }
    .rmx-note { font-size: 0.85rem; opacity: 0.75; margin-top: 1rem; }
    @media (max-width: 640px) {
      .rmx-grid { grid-template-columns: repeat(auto-fill, minmax(128px, 1fr)); gap: 0.7rem; }
    }

    /* card is now a link to the detail page (crawlable); JS opens it as a modal */
    .rmx-open { text-decoration: none; color: var(--ink); display: block; }
    .rmx-open .rmx-box { transition: transform 0.1s ease; }
    .rmx-open:hover .rmx-box { transform: translateY(-2px); }

    /* URL-addressable modal */
    .rmx-modal { position: fixed; inset: 0; z-index: 60; display: flex; align-items: center; justify-content: center; padding: 1rem; }
    .rmx-modal[hidden] { display: none; }
    .rmx-modal__backdrop { position: absolute; inset: 0; background: rgba(17, 17, 17, 0.66); }
    .rmx-modal__card {
      position: relative; z-index: 1; background: var(--paper); border: var(--line); box-shadow: 8px 8px 0 #000;
      width: min(460px, 100%); max-height: 90vh; overflow-y: auto; text-align: center; padding: 1.5rem 1.4rem 1.3rem;
    }
    .rmx-modal__x {
      position: absolute; top: 0.5rem; right: 0.5rem; width: 34px; height: 34px; display: grid; place-items: center;
      background: var(--paper); border: 2px solid var(--ink); cursor: pointer; color: var(--ink); border-radius: 2px;
    }
    .rmx-modal__x:hover { background: var(--banana); }
    .rmx-modal__box {
      display: flex; align-items: center; justify-content: center; background: #fff;
      border: 2px solid var(--ink); min-height: 200px; padding: 1.2rem; margin-bottom: 1rem;
    }
    .rmx-modal__box img { image-rendering: pixelated; }
    .rmx-modal__title { font-size: 1.7rem; margin: 0 0 0.4rem; }
    .rmx-modal__stars { justify-content: center; }
    .rmx-modal__count { margin: 0.2rem 0 0; }
    .rmx-modal__blurb { font-size: 0.9rem; line-height: 1.5; margin: 0.9rem auto; max-width: 42ch; }
    .rmx-modal__actions { display: flex; flex-wrap: wrap; gap: 0.6rem; }
    .rmx-modal__actions .btn { flex: 1; min-width: 160px; }
    .rmx-modal__foot { font-size: 0.8rem; margin: 0.9rem 0 0; }
    .rmx-modal__foot a { color: var(--ink); opacity: 0.75; }
    body.rmx-modal-open { overflow: hidden; }
  </style>

  <section class="hero">
    <div class="hero__banana">
      <img src="/assets/dancing-banana-community-remixes/bananadance-warrior.gif" width="40" height="44" style="image-rendering:pixelated;width:120px;height:auto;"
           alt="The warrior banana — a community remix of the Dancing Banana" />
    </div>
    <p class="kicker">Thank you, internet</p>
    <h1 class="hero__title" style="font-size:clamp(2rem,8vw,3.6rem);">the banana meme<br>collection</h1>
    <p class="hero__tag" style="text-transform:none;font-weight:500;">{remixes.length} dancing banana remixes the internet made, since 1999</p>
  </section>

  <section class="block">
    <p class="lead" style="max-width:64ch;margin-inline:auto;">
      I made one banana. <strong>The internet made all of these.</strong> Warrior bananas, jedi bananas,
      dancing tacos, Mario, Homer — {remixes.length} banana memes collected over 25 years of the
      <a href="/dancing-banana-gif-meme/">original dancing banana</a> living its own life.
      Rate your favourites in bananas, and take any of them home. Made one of these
      (or have one I've missed)? <a href="/contact/">Send it my way</a> — credit where credit's due.
    </p>

    <div class="rmx-filters" id="rmxFilters" role="group" aria-label="Filter remixes">
      {CATS.map(([id, label, n]) => (
        <button class="rmx-chip" data-cat={id} aria-pressed={id === 'all' ? 'true' : 'false'}>{label} · {n}</button>
      ))}
    </div>
    <div class="rmx-sort">
      <label for="rmxSort">Sort</label>
      <select id="rmxSort">
        <option value="top">Top rated</option>
        <option value="az">A → Z</option>
        <option value="lucky">I'm feeling lucky</option>
      </select>
    </div>

    <div class="rmx-grid" id="rmxGrid">
      {SSR.map((r) => (
        <div class="rmx-card">
          <a class="rmx-open" href={`/dancing-banana-remixes/${r.slug}/`}>
            <div class="rmx-box">
              <img src={`/assets/remix-thumbs/${r.id}.png`} width={r.w} height={r.h} loading="lazy"
                   alt={`${r.title} — a dancing banana meme`} />
            </div>
            <h3>{r.title}</h3>
          </a>
          <a class="rmx-dl" href={`/assets/dancing-banana-community-remixes/${r.id}.gif`}
             download={`dancing-banana-remix-${r.id}-trymstene.com.gif`}>Download ↓</a>
        </div>
      ))}
    </div>
    <button class="btn btn--dark rmx-more" id="rmxMore" hidden>Show more ↓</button>
    <p class="rmx-note" style="text-align:center;">
      All remixes are fan works shared here non-commercially, with love. Want to add yours to the pile?
      <a href="/make-a-banana/" data-place="remixes">Dress a banana</a> or <a href="/forge/">forge a pixel from scratch</a>.
    </p>
  </section>

  <!-- URL-addressable modal: opened by JS over the gallery, but every card is a
       real <a href> to a static /dancing-banana-remixes/<slug>/ page for crawlers
       and deep links. The modal just mirrors that page's content in an overlay. -->
  <div class="rmx-modal" id="rmxModal" hidden role="dialog" aria-modal="true" aria-labelledby="rmxModalTitle">
    <div class="rmx-modal__backdrop" data-close></div>
    <div class="rmx-modal__card" role="document">
      <button class="rmx-modal__x" id="rmxModalClose" aria-label="Close" data-close><PixelIcon name="close" size="1em" /></button>
      <div class="rmx-modal__box"><img id="rmxModalImg" alt="" /></div>
      <h2 class="rmx-modal__title" id="rmxModalTitle"></h2>
      <div class="rmx-stars rmx-modal__stars" id="rmxModalStars" role="group"></div>
      <p class="rmx-count rmx-modal__count" id="rmxModalCount"></p>
      <p class="rmx-modal__blurb" id="rmxModalBlurb"></p>
      <div class="rmx-modal__actions">
        <a class="btn btn--dark" id="rmxModalDl"><PixelIcon name="download" /> Download the GIF</a>
        <a class="btn btn--light" href="/make-a-banana/" data-place="remix_modal"><PixelIcon name="palette" /> Make your own →</a>
      </div>
      <p class="rmx-modal__foot"><a id="rmxModalPage" href="#">Open full page ↗</a></p>
    </div>
  </div>

  <script type="application/json" id="rmxData" set:html={JSON.stringify(remixes)} />
  <script>
    import '../scripts/remix-gallery.js';
  </script>
</BaseLayout>
