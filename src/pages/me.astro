---
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelIcon from '../components/PixelIcon.astro';

const title = "Me — Trym Stene, the banana guy";
const description = "Trym Stene — 40, Oslo-based Lead SEO & CRO specialist by day, web comedian and music producer by night, and the guy who made the Dancing Banana GIF in 1999.";
const ogDescription = "Lead SEO by day, web comedian by night, the banana guy since 1999.";

// profile page anchored to the same Person entity the rest of the site cites
const profileSchema = {
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "@id": "https://trymstene.com/#trym",
    "name": "Trym Stene",
    "url": "https://trymstene.com/",
    "image": "https://trymstene.com/assets/trym-stene-profile-photo.jpg",
    "jobTitle": "Lead SEO & CRO Specialist",
    "description": "Norwegian creator of the Dancing Banana GIF (1999). Lead SEO & CRO specialist, web comedian, and music producer as Sentry.",
    "knowsAbout": ["SEO", "CRO", "web comedy", "music production", "internet memes"]
  }
};
---
<BaseLayout
  title={title}
  description={description}
  ogTitle="Me — Trym Stene"
  ogDescription={ogDescription}
  ogType="profile"
  ogImage="https://trymstene.com/assets/trym-stene-profile-photo.jpg"
  showFooter={false}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(profileSchema)} />
  <!-- hero -->
  <section class="hero">
    <p class="kicker">The guy behind the fruit</p>
    <h1 class="hero__title">hello, I'm Trym</h1>
    <p class="hero__tag">Lead SEO &nbsp;·&nbsp; web comedian &nbsp;·&nbsp; music producer</p>
  </section>

  <!-- bio -->
  <section class="block block--dark">
    <div class="split">
      <div class="split__media">
        <img src="/assets/trym-stene-profile-photo.jpg" alt="Trym Stene" loading="lazy">
      </div>
      <div class="split__text">
        <p class="kicker kicker--light">Short version</p>
        <h2>40, from Oslo, mildly internet-famous for a fruit.</h2>
        <p class="lead">
          By day I'm <strong>Lead SEO &amp; CRO Specialist at Telenor</strong>, with 20+ years of building
          websites and making content behind me — with stops at Starcom/Publicis, NHO, Storebrand and
          Webhuset along the way.
        </p>
        <p class="lead">
          By night I make the internet laugh and noise in the studio as
          <a href="https://www.djsentry.com" target="_blank" rel="noopener">Sentry</a>. And once, in 1999,
          I drew a dancing banana that got a little out of hand.
        </p>
      </div>
    </div>
  </section>

  <!-- timeline -->
  <section class="block block--yellow">
    <p class="kicker">A few things I've made</p>
    <h2>The longer version</h2>
    <div class="faq__item">
      <h3>1999 — The Dancing Banana</h3>
      <p>
        A celebratory forum emoticon that escaped into the wild and became one of the internet's first
        memes. <a href="/dancing-banana-gif-meme/">The full story →</a>
      </p>
    </div>
    <div class="faq__item">
      <h3>~2010 — Hack The Planet</h3>
      <p>Co-founded a small game studio and built a web-based hacker game that reached ~2,000 active players before we pulled the plug.</p>
    </div>
    <div class="faq__item">
      <h3>2013 — Anonymous satire</h3>
      <p>
        Launched an anonymous account mocking Norway's social-media and communications industry. It got
        loud enough to make the press. <a href="/projects/">See the projects →</a>
      </p>
    </div>
    <div class="faq__item">
      <h3>Always — Silly little web projects &amp; music</h3>
      <p>
        Fake municipalities, Netflix parodies, a corona-to-meatball browser extension, and electronic music
        as Sentry. <a href="/projects/">Projects →</a> · <a href="https://www.djsentry.com" target="_blank" rel="noopener">Music ↗</a>
      </p>
    </div>
  </section>

  <!-- contact -->
  <footer class="block block--dark" id="contact">
    <p class="kicker kicker--light">Say hello</p>
    <h2>Contact</h2>
    <p class="lead">
      Work, jokes, music, or licensing the banana — email
      <a href="mailto:trym@trymstene.com">trym@trymstene.com</a>.
    </p>
    <div class="socials">
      <a href="https://www.facebook.com/trymstene" target="_blank" rel="noopener">Facebook</a>
      <a href="https://twitter.com/trymstene" target="_blank" rel="noopener">X</a>
      <a href="https://www.linkedin.com/in/trymstene/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="https://soundcloud.com/sentryofficial" target="_blank" rel="noopener">SoundCloud</a>
      <a href="https://www.instagram.com/trymstene/" target="_blank" rel="noopener">Instagram</a>
      <a href="https://open.spotify.com/artist/3mPwC4BdfC6fxNg8pIlA4F" target="_blank" rel="noopener">Spotify</a>
    </div>
    <p class="copyright">© <span id="year">2026</span> Trym Stene · the banana guy <PixelIcon name="banana" /></p>
  </footer>
</BaseLayout>
