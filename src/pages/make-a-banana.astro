---
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelIcon from '../components/PixelIcon.astro';

const title = "Make Your Own Dancing Banana | Trym Stene";
const description = "Customize the original Dancing Banana — add shades, hats, captions and dance moves, then download it or share your creation. Free banana builder by the guy who made the meme.";
const ogDescription = "Add shades, hats, captions and dance moves to the original Dancing Banana, then download or share it.";
---
<BaseLayout
  title={title}
  description={description}
  ogTitle="Make Your Own Dancing Banana"
  ogDescription={ogDescription}
  showFooter={false}
>
  <style is:inline slot="head">
    .bb-wrap { max-width: 1000px; margin: 0 auto; padding: 2.5rem 1.2rem 4rem; }
    .bb-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    @media (min-width: 820px) { .bb-grid { grid-template-columns: 1fr 1fr; align-items: start; } }

    /* stage — sticky so you never tweak blind */
    .bb-stagewrap { position: sticky; top: 72px; z-index: 40; background: var(--paper); padding-bottom: 0.6rem; }
    .bb-stage {
      position: relative;
      aspect-ratio: 1 / 1;
      border: var(--line);
      box-shadow: var(--shadow);
      overflow: hidden;
      background: var(--banana);
    }
    .bb-stage canvas { display: block; width: 100%; height: 100%; }
    @media (max-width: 819px) { .bb-stage { width: min(100%, 44vh); margin-inline: auto; } }
    .bb-pause {
      position: absolute; right: 10px; bottom: 10px; width: 42px; height: 42px;
      border: 3px solid var(--ink); background: var(--paper); border-radius: 2px;
      font-size: 1.05rem; line-height: 1; cursor: pointer; box-shadow: 2px 2px 0 var(--ink);
    }
    .bb-pause:hover { transform: translate(-1px, -1px); box-shadow: 3px 3px 0 var(--ink); }

    /* transparent background = checkerboard so it's obvious there's no bg */
    .bb-stage--transparent {
      background-color: #fff;
      background-image:
        linear-gradient(45deg, #e4e4e4 25%, transparent 25%),
        linear-gradient(-45deg, #e4e4e4 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #e4e4e4 75%),
        linear-gradient(-45deg, transparent 75%, #e4e4e4 75%);
      background-size: 26px 26px;
      background-position: 0 0, 0 13px, 13px -13px, -13px 0;
    }
    .bb-swatch--none {
      background-color: #fff;
      background-image:
        linear-gradient(45deg, #bbb 25%, transparent 25%),
        linear-gradient(-45deg, #bbb 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #bbb 75%),
        linear-gradient(-45deg, transparent 75%, #bbb 75%);
      background-size: 12px 12px;
      background-position: 0 0, 0 6px, 6px -6px, -6px 0;
    }

    /* controls */
    .bb-controls { display: flex; flex-direction: column; gap: 1.2rem; }
    .bb-random { width: 100%; font-size: 1.05rem; }
    .bb-row label { display:block; font-weight: 700; margin-bottom: 0.4rem; font-size: 0.95rem; }
    .bb-input, .bb-select {
      width: 100%; padding: 0.6rem 0.7rem; border: 3px solid var(--ink);
      font-family: inherit; font-size: 1rem; background: var(--paper); border-radius: 2px;
    }
    /* neo-brutalist range slider (faster to the right ⚡) */
    .bb-slider { -webkit-appearance: none; appearance: none; width: 100%; height: 28px; background: transparent; cursor: pointer; }
    .bb-slider::-webkit-slider-runnable-track { height: 10px; background: var(--ink); border-radius: 2px; }
    .bb-slider::-webkit-slider-thumb {
      -webkit-appearance: none; width: 26px; height: 26px; margin-top: -8px;
      background: var(--banana); border: 3px solid var(--ink); border-radius: 2px;
      box-shadow: 2px 2px 0 var(--ink);
    }
    .bb-slider::-moz-range-track { height: 10px; background: var(--ink); border-radius: 2px; }
    .bb-slider::-moz-range-thumb {
      width: 20px; height: 20px; background: var(--banana);
      border: 3px solid var(--ink); border-radius: 2px; box-shadow: 2px 2px 0 var(--ink);
    }
    .bb-slider:focus-visible { outline: 3px solid var(--hot); outline-offset: 2px; }
    .bb-speedends { display: flex; justify-content: space-between; font-size: 0.78rem; opacity: 0.65; font-weight: 700; margin-top: 0.15rem; }
    .bb-swatches { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .bb-swatch { width: 34px; height: 34px; border: 3px solid var(--ink); border-radius: 2px; cursor: pointer; padding: 0; }
    .bb-swatch[aria-pressed="true"] { box-shadow: 0 0 0 3px var(--hot); }
    .bb-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .bb-chip {
      border: 3px solid var(--ink); background: var(--paper); padding: 0.4rem 0.8rem;
      font-weight: 700; cursor: pointer; border-radius: 2px; font-size: 0.9rem;
    }
    .bb-chip[aria-pressed="true"] { background: var(--ink); color: var(--banana); }
    .bb-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; }
    .bb-note { font-size: 0.82rem; opacity: 0.7; margin: 0.6rem 0 0; }
    .bb-card .btn + .bb-note { margin-top: 0.9rem; }
    .bb-toast {
      position: fixed; left: 50%; bottom: 24px; transform: translateX(-50%) translateY(20px);
      background: var(--ink); color: var(--banana); font-weight: 700; padding: 0.7rem 1.2rem;
      border-radius: 4px; opacity: 0; transition: all 0.25s ease; pointer-events: none; z-index: 80;
    }
    .bb-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ---- "Take it with you" output cards ---- */
    .bb-outputs { margin-top: 3rem; text-align: center; }
    .bb-outputs h2 { font-size: clamp(1.6rem, 5vw, 2.4rem); margin: 0.2rem 0 1.2rem; }
    .bb-cards { display: grid; grid-template-columns: 1fr; gap: 1.2rem; text-align: left; }
    @media (min-width: 820px) { .bb-cards { grid-template-columns: 1fr 1fr; align-items: start; } }
    .bb-card { border: var(--line); background: var(--paper); box-shadow: var(--shadow); padding: 1.3rem; }
    .bb-card h3 { margin: 0 0 0.5rem; font-size: 1.35rem; display: flex; align-items: center; gap: 0.5rem; }
    .bb-card p { margin: 0 0 1rem; font-size: 0.95rem; }
    .bb-card .btn {
      width: 100%; min-height: 54px; font-size: 1.08rem;
      display: inline-flex; align-items: center; justify-content: center; gap: 0.55rem;
      text-align: center; padding: 0.85rem 1rem;
    }
    /* second download block (meme image) under a dashed divider */
    .bb-dl2 { margin-top: 1.15rem; padding-top: 1.15rem; border-top: 3px dashed rgba(17,17,17,0.18); }
    /* the BUY card: hot shadow so the money maker pops */
    .bb-card--buy { box-shadow: 8px 8px 0 var(--hot); }
    .bb-minimock { display: block; width: 100%; max-width: 340px; height: auto; margin: 0 auto 0.9rem; border: var(--line); }
    /* cheesy supermarket sale banners: price in a pixel starburst, shipping
       in a hot pill — both slightly tilted like hanging posters */
    .bb-deal { display: flex; flex-direction: column; align-items: center; margin: -0.3rem 0 0.8rem; }
    .bb-burst {
      width: min(300px, 94%); aspect-ratio: 48 / 34; flex: none;
      background: url('/assets/price-burst.svg') center/contain no-repeat;
      display: grid; place-items: center;
      transform: rotate(-4deg);
      image-rendering: pixelated;
    }
    .bb-burst span {
      font-family: "Archivo Black", system-ui, sans-serif;
      font-size: 1.8rem; letter-spacing: -0.5px; transform: rotate(1deg);
      max-width: 150px; text-align: center; line-height: 1;
    }
    /* the pill hangs over the burst's lower edge, one line, a bit off-centre —
       organic sale-poster look, not grid-perfect */
    .bb-shippill {
      background: var(--hot); color: #fff; border: 3px solid var(--ink);
      box-shadow: 3px 3px 0 var(--ink);
      padding: 0.45rem 0.85rem; white-space: nowrap;
      font-weight: 800; font-size: 0.78rem; line-height: 1;
      text-transform: uppercase; letter-spacing: 0.05em;
      transform: rotate(-3deg);
      margin: -1.4rem 0 0 3rem;
      position: relative; z-index: 1;
    }
    .bb-trust { margin: 0 0 1.1rem; padding-left: 1.15rem; font-size: 0.92rem; display: grid; gap: 0.35rem; }
    .bb-trust li { margin: 0; }

    /* shared frame picker: one "freeze the moment" strip feeds BOTH cards */
    .bb-freeze { max-width: 760px; margin: 0 auto 1.4rem; }
    .bb-freeze p { margin: 0 0 0.8rem; font-size: 0.95rem; }
    .bb-freeze .bb-frames { justify-content: center; margin-bottom: 0; }

    /* fake chat row — compact, one line, both sizes inline */
    .bb-chat { background: #313338; border-radius: 8px; padding: 0.6rem 0.8rem; margin-bottom: 1rem; border: 3px solid var(--ink); }
    .bb-chat__msg { display: flex; gap: 0.6rem; align-items: center; }
    .bb-chat__avatar { flex: none; width: 32px; height: 32px; border-radius: 50%; background: var(--banana); color: var(--ink); display: grid; place-items: center; font-size: 1rem; }
    .bb-chat__meta { color: #f2c94c; font-weight: 700; font-size: 0.8rem; }
    .bb-chat__meta span { color: #949ba4; font-weight: 500; font-size: 0.7rem; margin-left: 0.4rem; }
    .bb-chat__text { color: #dbdee1; font-size: 0.88rem; margin: 0.1rem 0 0; display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; }
    .bb-chat__text canvas { vertical-align: middle; }


    /* sticker preview modal */
    .bb-modal {
      position: fixed; inset: 0; z-index: 90;
      background: rgba(17,17,17,0.55);
      display: grid; place-items: center; padding: 1rem;
    }
    .bb-modal[hidden] { display: none; }
    .bb-modal__box {
      background: var(--paper); border: var(--line); box-shadow: var(--shadow);
      padding: 1.3rem; max-width: 460px; width: 100%; max-height: 92vh; overflow: auto;
    }
    .bb-modal__box h3 { margin: 0 0 0.8rem; font-size: 1.3rem; }
    .bb-modal__box canvas { display: block; width: 100%; height: auto; border: var(--line); }
    .bb-modal .bb-actions .btn { flex: 1; text-align: center; }

    /* frame picker — freeze a moment of the dance */
    .bb-frames { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
    .bb-frame { width: 72px; height: 72px; padding: 2px; border: 3px solid var(--ink); background: #fff; cursor: pointer; border-radius: 2px; line-height: 0; }
    .bb-frame canvas { width: 100%; height: 100%; }
    @media (hover: hover) { .bb-frame:hover { transform: translateY(-2px); } }
    .bb-frame[aria-pressed="true"] { outline: 3px solid var(--hot); outline-offset: 1px; }
    @media (max-width: 400px) { .bb-frame { width: 64px; height: 64px; } }
  </style>

  <section class="hero" style="padding-bottom:1.5rem;">
    <p class="kicker">Free banana toy</p>
    <h1 class="hero__title" style="font-size:clamp(2rem,8vw,4rem);">make your own<br>dancing banana</h1>
    <p class="hero__tag" style="text-transform:none;font-weight:500;">Shades, hats, captions, dance moves. Build one, share it, slap it on a sticker.</p>
  </section>

  <div class="bb-wrap">
    <div class="bb-grid">
      <!-- PREVIEW: the banana always dances -->
      <div class="bb-stagewrap">
        <div class="bb-stage bb-stage--transparent" id="bbStage">
          <canvas id="bbCanvas" width="720" height="720" aria-label="Your dancing banana"></canvas>
          <button class="bb-pause" id="bbPause" aria-label="Pause the dance">⏸</button>
        </div>
      </div>

      <!-- CONTROLS -->
      <div class="bb-controls">
        <button class="btn btn--dark bb-random" id="bbRandom"><PixelIcon name="dice" /> Surprise me</button>
        <div class="bb-row">
          <label>Background</label>
          <div class="bb-swatches" id="bbSwatches"></div>
        </div>
        <div class="bb-row">
          <label for="bbTopText">Top caption</label>
          <input class="bb-input" id="bbTopText" maxlength="40" placeholder="e.g. HELLO YES">
        </div>
        <div class="bb-row">
          <label for="bbBottomText">Bottom caption</label>
          <input class="bb-input" id="bbBottomText" maxlength="40" placeholder="e.g. IT'S THE BANANA GUY">
        </div>
        <div class="bb-row">
          <label>Shades</label>
          <div class="bb-chips" id="bbGlassesChips"></div>
        </div>
        <div class="bb-row">
          <label>Hat</label>
          <div class="bb-chips" id="bbHatChips"></div>
        </div>
        <div class="bb-row">
          <label>Extras</label>
          <div class="bb-chips" id="bbExtrasChips"></div>
        </div>
        <div class="bb-row">
          <label>Effects</label>
          <div class="bb-chips" id="bbEffectChips"></div>
        </div>
        <div class="bb-row">
          <label for="bbSpeed">Dance speed</label>
          <input class="bb-slider" type="range" id="bbSpeed" min="0.35" max="1.6" step="0.05" value="1.15">
          <div class="bb-speedends" aria-hidden="true"><span>chill</span><span>banana overdrive <PixelIcon name="bolt" /></span></div>
        </div>
        <div class="bb-actions">
          <button class="btn btn--light" id="bbShare"><PixelIcon name="link" /> Copy share link</button>
        </div>
      </div>
    </div>

    <!-- TAKE IT WITH YOU -->
    <section class="bb-outputs" aria-labelledby="bbTakeTitle">
      <p class="kicker">Done building?</p>
      <h2 id="bbTakeTitle">Take it with you</h2>
      <div class="bb-freeze">
        <p><strong>Freeze your favourite moment of the dance</strong> — it's the one on your meme image and your sticker:</p>
        <div class="bb-frames" id="bbFrames"></div>
      </div>
      <div class="bb-cards">
        <div class="bb-card">
          <h3><PixelIcon name="download" size="1.5em" /> Download it — free</h3>
          <p>As an animated <strong>chat emoji</strong> — transparent, cropped tight, drops straight into Discord, Slack or Twitch. Here's yours at actual chat size:</p>
          <div class="bb-chat" aria-hidden="true">
            <div class="bb-chat__msg">
              <span class="bb-chat__avatar"><PixelIcon name="banana" /></span>
              <div>
                <div class="bb-chat__meta">banana_guy <span>today at 19:99</span></div>
                <p class="bb-chat__text">check out my new emoji <canvas id="bbEmoji32" width="32" height="32"></canvas> <canvas id="bbEmoji48" width="48" height="48"></canvas></p>
              </div>
            </div>
          </div>
          <button class="btn btn--dark" id="bbDownloadGif"><PixelIcon name="chat" size="1.4em" /> Download emoji GIF</button>
          <p class="bb-note">Captions are left off the emoji — they're too tiny to read at chat size.</p>
          <div class="bb-dl2">
            <p>Or as a <strong>full-size meme image</strong> — captions, background and the moment you froze above:</p>
            <button class="btn btn--light" id="bbDownloadPng"><PixelIcon name="download" size="1.4em" /> Download image (PNG)</button>
          </div>
        </div>
        <div class="bb-card bb-card--buy">
          <h3><PixelIcon name="tag" size="1.5em" /> Get it as a real sticker</h3>
          <p>Your banana, printed and mailed to your door. Live preview of the moment you froze:</p>
          <canvas id="bbMiniMock" class="bb-minimock" aria-label="Live preview of your printed sticker"></canvas>
          <div class="bb-deal">
            <div class="bb-burst"><span id="bbPrice">149 kr</span></div>
            <div class="bb-shippill">Free shipping worldwide</div>
          </div>
          <ul class="bb-trust">
            <li>3″×3″ (7.5 cm) durable vinyl — die-cut along your design (square if you picked a background)</li>
            <li>Printed on demand and checked by the banana guy himself before it ships</li>
            <li>From the creator of the original 1999 Dancing Banana</li>
          </ul>
          <button class="btn btn--dark" id="bbOrderSticker"><PixelIcon name="tag" size="1.4em" /> Order my sticker</button>
        </div>
      </div>
    </section>
  </div>

  <!-- sticker order preview: see YOUR sticker before paying -->
  <div class="bb-modal" id="bbOrderModal" hidden>
    <div class="bb-modal__box" role="dialog" aria-modal="true" aria-labelledby="bbModalTitle">
      <h3 id="bbModalTitle">Your sticker</h3>
      <canvas id="bbMockup" aria-label="Preview of your printed sticker"></canvas>
      <p class="bb-note" style="margin-top:0.8rem;"><span id="bbModalCut">3″×3″ (7.5 cm) vinyl sticker</span> — <strong id="bbModalPrice">149 kr, free shipping worldwide</strong>. Checked by the banana guy himself before it's printed.</p>
      <div class="bb-actions" style="margin-top:1rem;">
        <button class="btn btn--dark" id="bbOrderConfirm">Looks good — to checkout</button>
        <button class="btn btn--light" id="bbOrderCancel">Back to editing</button>
      </div>
    </div>
  </div>

  <div class="bb-toast" id="bbToast">Copied!</div>

  <footer class="block block--dark">
    <p class="kicker kicker--light">The original</p>
    <h2>Made by the banana guy</h2>
    <p class="lead">This is the real 1999 Dancing Banana. <a href="/dancing-banana-gif-meme/">Read its story →</a> · <a href="/license-the-dancing-banana/">License it →</a></p>
    <p class="copyright">© <span id="year">2026</span> Trym Stene · the banana guy <PixelIcon name="banana" /></p>
  </footer>

  <script>
    import '../scripts/banana-builder.js';
  </script>
</BaseLayout>
