---
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelIcon from '../components/PixelIcon.astro';

const title = "Trym Stene — hello yes, it's the banana guy";
const description = "Trym Stene — the guy who made the Dancing Banana GIF back in 1999. This is where the banana lives: the full story, make your own, join the live rave, and the official shop.";
const ogDescription = "The guy who made the Dancing Banana GIF. The story, the builder, the rave, the shop.";

// Entity / authorship: establishes Trym Stene as the verified creator for search + AI
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://trymstene.com/#website",
      "url": "https://trymstene.com/",
      "name": "Trym Stene",
      "description": "Trym Stene — the creator of the Dancing Banana GIF (1999). The banana's home: story, builder, live rave, and official shop.",
      "inLanguage": "en",
      "publisher": { "@id": "https://trymstene.com/#trym" }
    },
    {
      "@type": "Person",
      "@id": "https://trymstene.com/#trym",
      "name": "Trym Stene",
      "url": "https://trymstene.com/",
      "image": "https://trymstene.com/assets/trym-stene-profile-photo.jpg",
      "description": "Norwegian creator of the Dancing Banana GIF (1999). Lead SEO & CRO specialist, web comedian, and music producer as Sentry.",
      "jobTitle": "Lead SEO & CRO Specialist",
      "sameAs": [
        "https://www.facebook.com/trymstene",
        "https://twitter.com/trymstene",
        "https://www.linkedin.com/in/trymstene/",
        "https://www.instagram.com/trymstene/",
        "https://soundcloud.com/sentryofficial",
        "https://open.spotify.com/artist/3mPwC4BdfC6fxNg8pIlA4F"
      ]
    }
  ]
};

const marqueeText = "the dancing banana  ·  since 1999  ·  the rave is open  ·  make your own  ·  licensing enquiries welcome  ·  ".repeat(5);
---
<BaseLayout title={title} description={description} ogDescription={ogDescription}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />

  <!-- scrolling marquee banner -->
  <div class="marquee" slot="banner" aria-hidden="true">
    <div class="marquee__track">
      <span>{marqueeText}</span>
      <span>{marqueeText}</span>
    </div>
  </div>

  <!-- hero -->
  <section class="hero">
    <div class="hero__banana">
      <img src="/assets/dancing-banana-gif.gif" alt="The Dancing Banana GIF, created by Trym Stene in 1999"
           onerror="this.outerHTML='<div class=&quot;banana-fallback&quot;>🍌</div>';">
    </div>
    <h1 class="hero__title">hello yes,<br>it's the <span class="wobble">banana</span> guy</h1>
    <p class="hero__tag">Welcome in. This is where the dancing banana lives — since 1999, still dancing.</p>
    <div class="hero__cta">
      <a class="btn btn--dark" href="/rave/">🪩 Join the rave →</a>
      <a class="btn btn--light" href="/make-a-banana/" data-place="hero"><PixelIcon name="palette" /> Make a banana</a>
    </div>
  </section>

  <!-- the doors -->
  <section class="block" id="doors">
    <p class="kicker">Pick a door</p>
    <h2>The banana is a place now.</h2>
    <div class="doors">
      <a class="door" href="/dancing-banana-gif-meme/">
        <span class="door__verb">grab the GIF</span>
        <p>The original 1999 banana, free to take home — plus how it became Peanut Butter Jelly Time.</p>
        <span class="door__live">dancing since 1999</span>
      </a>
      <a class="door" href="/make/" data-place="home-door">
        <span class="door__verb">make a banana</span>
        <p>Dress your own banana — or forge a brand-new pixel emoji from scratch.</p>
        <span class="door__live">two workbenches, open late</span>
      </a>
      <a class="door door--dance" href="/rave/">
        <span class="door__verb">join the rave</span>
        <p>Every visitor's banana on one floor, dancing in perfect sync. Right now.</p>
        <span class="door__live"><span class="door__dot"></span><span id="raveCount">the floor is open</span></span>
      </a>
      <a class="door" href="/shop/">
        <span class="door__verb">hit the shop</span>
        <p>Stickers, mugs and tees — straight from the banana's home.</p>
        <span class="door__live">ships worldwide</span>
      </a>
    </div>
    <p class="doors__daily">On the decks today: <a href="/banana-of-the-day/">the banana of the day →</a></p>
  </section>

  <!-- banana hook -->
  <section class="block block--yellow" id="banana">
    <p class="kicker">Yes, THAT banana</p>
    <h2>I accidentally made the internet's favourite fruit.</h2>
    <p class="lead">
      Back in <strong>1999</strong>, on an AMD K6-2 running at a screaming 350MHz, I made a little
      dancing banana GIF. It became <strong>Peanut Butter Jelly Time</strong>, it cameo'd in
      <strong>Family Guy</strong>, and it's been bouncing across the internet ever since.
    </p>
    <p class="lead">
      The full story — the remixes, the FAQ, and how to <strong>license</strong> the banana
      (spoiler: not for your crypto coin) — lives on its own page.
    </p>
    <a class="btn btn--dark" href="/dancing-banana-gif-meme/">Read the full banana story →</a>
  </section>

  <!-- the host -->
  <section class="block" id="about">
    <div class="split">
      <div class="split__media">
        <img src="/assets/trym-stene-profile-photo.jpg" alt="Trym Stene" loading="lazy">
      </div>
      <div class="split__text">
        <p class="kicker">Your host</p>
        <h2>Me</h2>
        <p class="lead">
          I'm Trym Stene — a Norwegian who does SEO for a living, makes jokes on the internet for fun,
          and produces music as <a href="https://www.djsentry.com" target="_blank" rel="noopener">Sentry</a>.
          One time in 1999 I drew a fruit and it got a little out of hand.
        </p>
        <p class="lead">
          <a href="/contact/">Say hello →</a>
        </p>
        <a class="btn btn--dark" href="/me/">More about me →</a>
      </div>
    </div>
  </section>

  <script>
    // proof of life on the dance door — fail silently, never block the page
    fetch('https://banana-rave.trymstene.workers.dev/count')
      .then((r) => r.json())
      .then((d) => {
        const el = document.getElementById('raveCount');
        if (el && typeof d.count === 'number' && d.count > 0) {
          el.textContent = d.count === 1 ? '1 banana on the floor' : `${d.count} bananas on the floor`;
        }
      })
      .catch(() => {});
  </script>
</BaseLayout>
