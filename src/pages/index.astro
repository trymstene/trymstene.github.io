---
import BaseLayout from '../layouts/BaseLayout.astro';
// Phase-1 scaffold check — real homepage content lands in Phase 2.
---
<BaseLayout title="Scaffold check — Trym Stene" description="Validating the Astro pipeline on the real design.">
  <section class="hero">
    <p class="kicker">Scaffold check</p>
    <h1 class="hero__title">it<br>works</h1>
    <p class="hero__tag" style="text-transform:none;font-weight:500;">Astro + shared components + global CSS, rendering on the real neo-brutalist design.</p>
  </section>

  <section class="block block--yellow">
    <p class="kicker">The goods</p>
    <h2>Section in banana yellow</h2>
    <p class="lead">If this is styled — yellow block, hard borders, Nunito logo, two-tone nav — the pipeline is good.</p>
    <a class="btn btn--dark" href="/shop/">Test button →</a>
  </section>
</BaseLayout>
