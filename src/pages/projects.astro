---
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelIcon from '../components/PixelIcon.astro';

const title = "Projects — satirical web experiments | Trym Stene";
const description = "Satirical web projects by Trym Stene — fake municipalities, a Netflix parody, a corona-to-meatball Chrome extension, digital-mailbox satire, and a country album about corporate despair.";
const ogDescription = "Satirical web experiments, fake municipalities, and a country album about office despair.";
---
<BaseLayout
  title={title}
  description={description}
  ogTitle="Projects — Trym Stene"
  ogImage="https://trymstene.com/assets/og/projects.png"
  ogDescription={ogDescription}
>
  <!-- hero -->
  <section class="hero">
    <h1 class="hero__title">projects</h1>
    <p class="hero__tag">Satirical web experiments, fake municipalities &amp; a country album about office despair</p>
  </section>

  <!-- grid -->
  <section class="block block--yellow">
    <div class="cards">

      <!-- Corporate Rangers (no external link yet) -->
      <a class="project-card" href="https://open.spotify.com/artist/6o8Td2bXOhcE5xtsBsYNiF" target="_blank" rel="noopener">
        <img class="project-card__img" src="/assets/projects/corporate-rangers.jpg" alt="The Corporate Rangers" loading="lazy">
        <div class="project-card__body">
          <h3>The Corporate Rangers</h3>
          <p>A six-track country meltdown from the heart of corporate despair — boot-stomping anthems about printers, pointless meetings, and coffee that tastes like regret.</p>
          <span class="project-card__go">Listen on Spotify ↗</span>
        </div>
      </a>

      <!-- Brevkassen -->
      <a class="project-card" href="https://lekeplass.com/brevkassen/" target="_blank" rel="noopener">
        <img class="project-card__img" src="/assets/projects/brevkassen.jpg" alt="Brevkassen" loading="lazy">
        <div class="project-card__body">
          <h3>Brevkassen</h3>
          <p>Norwegian satire about the digital mailbox you forgot you had — and the quiet pile of unread official messages growing inside it.</p>
          <span class="project-card__go">Visit ↗</span>
        </div>
      </a>

      <!-- Sosiale Medier-Eliten / Someliten -->
      <div class="project-card">
        <div class="project-card__redacted">█ ANONYMOUS █<br>2013–2015</div>
        <div class="project-card__body">
          <h3>Sosiale Medier-Eliten</h3>
          <p>An anonymous meme project skewering social-media gurus and communication advisors. The Norwegian press dubbed it "bransjens Charlie Hebdo."</p>
          <span class="project-card__tag">Anonymous · 2013–2015</span>
        </div>
      </div>

      <!-- Trymflix -->
      <a class="project-card" href="https://lekeplass.com/projects/trymflix/" target="_blank" rel="noopener">
        <img class="project-card__img" src="/assets/projects/trymflix.png" alt="Trymflix" loading="lazy">
        <div class="project-card__body">
          <h3>Trymflix.com</h3>
          <p>A Netflix parody built mostly as an excuse to play with jQuery UI.</p>
          <span class="project-card__go">Visit ↗</span>
        </div>
      </a>

      <!-- Karbonadify -->
      <a class="project-card" href="https://chromewebstore.google.com/detail/karbonadify/dmnefnajildhaohggehgniogjiklanco" target="_blank" rel="noopener">
        <img class="project-card__img" src="/assets/projects/karbonadify.jpg" alt="Karbonadify Chrome extension" loading="lazy">
        <div class="project-card__body">
          <h3>Karbonadify</h3>
          <p>A Chrome extension that swaps every "corona" and "COVID-19" on news sites for "karbonade" — a Norwegian meat patty. Peaked at a proud ~100 installs.</p>
          <span class="project-card__go">Get the extension ↗</span>
        </div>
      </a>

      <!-- Fjesdal Kommune -->
      <div class="project-card">
        <img class="project-card__img" src="/assets/projects/fjesdal-kommune.jpg" alt="Fjesdal Kommune" loading="lazy">
        <div class="project-card__body">
          <h3>Fjesdal Kommune</h3>
          <p>A fictional Norwegian municipality that seems perfectly normal — until you start reading about its business sector and local services.</p>
          <span class="project-card__tag">Offline</span>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
