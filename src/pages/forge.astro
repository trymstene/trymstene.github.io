---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Emoji Maker & Animated GIF Maker — Free Pixel Emotes | Pixel Forge';
const description = 'Free emoji maker & animated GIF maker in your browser: draw pixel art frame by frame, remix existing GIFs, preview at real chat size, export transparent GIFs and PNGs sized for Discord (128px), Twitch (112px), Slack and Telegram. No account, no watermark.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'The Pixel Forge',
  alternateName: ['Emoji Maker', 'Pixel Emote Maker', 'Animated GIF Maker', 'GIF Drawing Tool'],
  url: 'https://trymstene.com/forge/',
  applicationCategory: 'DesignApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  creator: { '@id': 'https://trymstene.com/#trym' },
  featureList: 'Pixel drawing tools, brush sizes, custom colours, GIF import and remix, frame-by-frame animation, onion skinning, live chat-size preview, transparent GIF and PNG export sized for Discord, Twitch, Slack and Telegram',
  description: 'A deliberately simple pixel-art emoji and emote maker, from the creator of the 1999 Dancing Banana GIF.',
};

// ONE source for the FAQ: the visible section and the FAQPage JSON-LD both
// render from this list, so the markup can never drift from the page content
const FAQ = [
  { q: 'Is the Pixel Forge emoji maker free?',
    a: 'Yes — completely free, no account, no watermark. Draw in the browser and download transparent GIFs or PNGs ready for Discord, Twitch, Slack and Telegram.' },
  { q: 'Can I draw an animated GIF from scratch?',
    a: 'Yes — that is the whole idea. Most GIF makers only convert videos or stitch photos together; the Forge is a GIF drawing tool. You draw every frame in pixels, set the timing per frame, and export a real animated GIF.' },
  { q: 'Can I make animated Discord emojis with it?',
    a: 'Yes. Draw up to 16 frames with per-frame timing and export a transparent animated GIF at 128×128 pixels — exactly what Discord custom emojis require.' },
  { q: 'Can I make Twitch emotes with it?',
    a: 'Yes. Export at 112×112 pixels with a transparent background and Twitch auto-generates the 56px and 28px sizes when you upload.' },
  { q: 'Are the GIFs transparent?',
    a: 'Yes, every export supports transparency. Anything you leave unpainted stays see-through, so your emote floats over any chat background — no white box around it.' },
  { q: 'Can I import an existing GIF and remix it?',
    a: 'Yes. Import any GIF and it lands on the grid frame by frame, ready to redraw — including the original 1999 Dancing Banana, which is one click away.' },
  { q: 'Do I need an account or an app?',
    a: 'No. It runs entirely in your browser — nothing to install, no sign-up, no watermark. Finished pieces land on your Banana Pass so you can come back to them.' },
  { q: 'Why pixel art for emotes?',
    a: 'Emotes render at 28–32 pixels in chat, where fine detail turns to mush. Pixel art drawn on a small grid stays crisp and readable — the same reason the 1999 Dancing Banana still works everywhere.' },
];
const faqLD = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ.map((f) => ({
    '@type': 'Question', name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout
  title={title}
  description={description}
  ogTitle="The Pixel Forge 🎨"
  ogDescription="The dancing banana was drawn in a tool like this in 1999. Here it is, rebuilt. Make the next one."
  ogImage="https://trymstene.com/assets/og/builder.png"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqLD)} />
  <style is:inline slot="head">
    .fg-wrap { max-width: 1100px; margin: 0 auto; padding: 1.6rem 1rem 2.5rem; }
    .fg-head h1 { margin: 0 0 0.3rem; }
    .fg-head p { margin: 0 0 1.4rem; opacity: 0.8; max-width: 62ch; }

    /* LAYOUT — work on the left (canvas + frames), tools on the right,
       ordered by how often a hand actually reaches for them */
    .fg-grid { display: grid; gap: 1.2rem; grid-template-columns: 1fr; }
    @media (min-width: 920px) {
      .fg-grid { grid-template-columns: minmax(0, 1fr) 300px; align-items: start; }
      .fg-stagecol { grid-column: 1; grid-row: 1; }
      .fg-export { grid-column: 1; grid-row: 2; margin-top: 0; } /* hugs the frames — no void under wide imports */
      .fg-side { grid-column: 2; grid-row: 1 / span 2; }
    }

    .fg-stagecard { position: relative; border: var(--line); background: var(--paper); box-shadow: var(--shadow); padding: 0.8rem; }
    #fgCanvas { display: block; width: 100%; height: auto; image-rendering: pixelated; touch-action: none; cursor: crosshair; }
    /* items-mode status as a quick toast pinned to the top of the canvas */
    .fg-toast {
      position: absolute; top: calc(0.8rem + 10px); left: 50%; z-index: 6;
      transform: translate(-50%, -6px); pointer-events: none;
      max-width: calc(100% - 2rem); text-align: center; text-wrap: balance;
      padding: 0.4rem 0.85rem; border-radius: 14px;
      font-weight: 800; font-size: 0.85rem; letter-spacing: 0.01em;
      background: var(--ink); color: var(--paper); box-shadow: 0 5px 16px rgba(0,0,0,0.28);
      opacity: 0; transition: opacity 0.28s ease, transform 0.28s ease;
    }
    .fg-toast.is-on { opacity: 1; transform: translate(-50%, 0); }
    /* the "draw your item" invite is a standing prompt (banana yellow), the
       "rides the …" confirmations flash by (ink) */
    .fg-toast.is-sticky { background: var(--banana); color: var(--ink); box-shadow: 0 5px 16px rgba(0,0,0,0.16); }
    @media (prefers-reduced-motion: reduce) { .fg-toast { transition: opacity 0.28s ease; transform: translate(-50%, 0); } }

    .fg-side { display: grid; gap: 1rem; align-content: start; }
    .fg-panel { border: var(--line); background: var(--paper); box-shadow: var(--shadow-sm, 4px 4px 0 var(--ink)); padding: 0.9rem; }
    .fg-panel h3 { margin: 0 0 0.6rem; font-size: 0.95rem; }

    .fg-tools { display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center; }
    .fg-tools + .fg-tools, .fg-toolgrid + .fg-tools { margin-top: 0.65rem; }
    .fg-toolgrid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.6rem; }
    .fg-toolgrid > button {
      border: 3px solid var(--ink); background: var(--paper); padding: 0.5rem 0.4rem;
      font-weight: 700; cursor: pointer; font-size: 0.85rem;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .fg-toolgrid > button[aria-pressed="true"] { background: var(--ink); color: var(--banana); }
    .fg-tools > button {
      border: 3px solid var(--ink); background: var(--paper); padding: 0.45rem 0.65rem;
      font-weight: 700; cursor: pointer; font-size: 0.85rem;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .fg-tools > button[aria-pressed="true"] { background: var(--ink); color: var(--banana); }
    .fg-tools > button[disabled] { opacity: 0.4; cursor: default; }
    .fg-lab { flex-basis: 100%; font-size: 0.66rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.55; }

    /* COMPACT TOOLBAR — icon-only tools, popovers for brush + colour (MS-Paint-ish) */
    .fg-bar { position: relative; padding: 0.7rem; }
    .fg-toolrow { display: flex; flex-wrap: wrap; gap: 0.4rem; align-items: center; }
    .fg-tool {
      width: 40px; height: 40px; display: inline-flex; align-items: center; justify-content: center;
      border: 3px solid var(--ink); background: var(--paper); cursor: pointer; font-size: 1.05rem; padding: 0;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .fg-tool[aria-pressed="true"] { background: var(--ink); color: var(--banana); }
    .fg-tool[disabled] { opacity: 0.4; cursor: default; }
    .fg-tool--wide { width: auto; min-width: 50px; gap: 0.28rem; font-weight: 800; font-size: 0.9rem; padding: 0 0.4rem; }
    .fg-brushdot { width: 8px; height: 8px; border-radius: 50%; background: currentColor; display: inline-block; }
    .fg-colorbtn { background: #ffe135; box-shadow: inset 0 0 0 3px var(--paper); }
    .fg-vsep { width: 3px; align-self: stretch; background: rgba(17, 17, 17, 0.14); margin: 3px 0.12rem; }
    .fg-pop {
      position: absolute; z-index: 20; left: 0.7rem; right: 0.7rem; margin-top: 0.5rem;
      border: 3px solid var(--ink); background: var(--paper); box-shadow: 5px 5px 0 var(--ink); padding: 0.75rem;
    }
    .fg-pop[hidden] { display: none; }
    .fg-pop > label { display: block; margin-bottom: 0.45rem; }
    .fg-pop input[type="range"] { width: 100%; }
    /* the un-boxed Items controls (the tab already says "Items Workshop") */
    .fg-itemsbar { display: flex; flex-direction: column; gap: 0.6rem; }
    .fg-itemsbar .btn { width: 100%; }

    /* PALETTE — material-style: 8 hue mains, one shades strip, your colours */
    .fg-mains { display: grid; grid-template-columns: repeat(8, 1fr); gap: 0.4rem; }
    .fg-swatch { aspect-ratio: 1; border: 3px solid var(--ink); cursor: pointer; padding: 0; }
    .fg-swatch[aria-pressed="true"] { outline: 3px solid var(--hot, #ff4d6d); outline-offset: 1px; }
    .fg-main--active:not([aria-pressed="true"]) { outline: 3px dashed rgba(17, 17, 17, 0.4); outline-offset: 1px; }
    .fg-shades { display: flex; gap: 0.35rem; margin-top: 0.55rem; min-height: 27px; }
    .fg-shades .fg-swatch { flex: 0 0 27px; height: 27px; aspect-ratio: auto; border-width: 2px; }
    .fg-customs { display: flex; gap: 0.35rem; margin-top: 0.55rem; flex-wrap: wrap; align-items: center; }
    .fg-customs .fg-swatch { flex: 0 0 27px; height: 27px; aspect-ratio: auto; border-width: 2px; border-radius: 50%; } /* round = yours */
    .fg-customs > button.fg-palbtn {
      border: 3px solid var(--ink); background: var(--paper); padding: 0.3rem 0.55rem;
      font-weight: 700; cursor: pointer; font-size: 0.78rem;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .fg-hiddeninput { position: absolute; width: 1px; height: 1px; opacity: 0; overflow: hidden; clip-path: inset(50%); }
    .fg-importnote { font-size: 0.72rem; opacity: 0.65; margin: 0.5rem 0 0; }

    /* 🍌 ITEMS WORKSHOP — a mode toggle that reuses the same canvas + tools */
    .fg-modebar { display: flex; gap: 0.6rem; margin: 0 0 1.1rem; }
    .fg-modetab {
      flex: 1; border: 3px solid var(--ink); background: var(--paper); padding: 0.65rem 0.5rem;
      font-weight: 800; font-size: 0.98rem; cursor: pointer; box-shadow: 4px 4px 0 var(--ink);
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .fg-modetab[aria-pressed="true"] { background: var(--banana); box-shadow: inset 3px 3px 0 rgba(17, 17, 17, 0.16); }
    .fg-riding { font-size: 0.82rem; font-weight: 800; color: #0e9fb5; margin: 0.35rem 0 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; }
    #fgItemsSave { width: 100%; }
    /* which controls each mode shows */
    .fg-itemsonly { display: none; }
    body.fg-mode-items .fg-itemsonly { display: block; }
    body.fg-mode-items .fg-emojionly { display: none; }

    /* the killer feature: your emoji at REAL chat size, live */
    .fg-chat { background: #313338; color: #dbdee1; padding: 0.7rem 0.8rem; border-radius: 6px; font-size: 0.85rem; }
    .fg-chat__meta { font-weight: 700; color: #fffdf5; margin-bottom: 0.2rem; }
    .fg-chat__meta span { font-weight: 400; font-size: 0.7rem; opacity: 0.55; margin-left: 0.4rem; }
    .fg-chat p { margin: 0; display: flex; align-items: center; gap: 0.35rem; }
    #fgPreview { image-rendering: pixelated; width: 32px; height: 32px; }

    /* collapsed setup: once-per-session stuff stays out of the way */
    details.fg-panel > summary { cursor: pointer; font-weight: 800; font-size: 0.95rem; list-style: none; }
    details.fg-panel > summary::-webkit-details-marker { display: none; }
    details.fg-panel > summary::after { content: '＋'; float: right; }
    details.fg-panel[open] > summary::after { content: '−'; }
    details.fg-panel[open] > summary { margin-bottom: 0.6rem; }

    /* ANIMATE — frames live right under the canvas */
    .fg-framesrow { margin-top: 1rem; }
    .fg-frames { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .fg-frame { position: relative; border: 3px solid var(--ink); background: #f4f1e8; cursor: pointer; line-height: 0; }
    .fg-frame canvas { width: 56px; height: 56px; image-rendering: pixelated; }
    .fg-frame span { position: absolute; left: 2px; top: 2px; font-size: 0.6rem; font-weight: 800; line-height: 1; background: var(--paper); padding: 1px 3px; }
    .fg-frame--cur { outline: 3px solid var(--hot, #ff4d6d); outline-offset: 1px; }
    .fg-framectl { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; margin-top: 0.6rem; }
    .fg-framectl button { border: 3px solid var(--ink); background: var(--paper); font-weight: 700; padding: 0.4rem 0.6rem; cursor: pointer; }
    .fg-framectl button[disabled] { opacity: 0.4; cursor: default; }
    .fg-framectl button[aria-pressed="true"] { background: var(--ink); color: var(--banana); }
    #fgDelay { width: 5rem; border: 3px solid var(--ink); padding: 0.35rem 0.4rem; font: inherit; }
    #fgFrameInfo { font-size: 0.8rem; opacity: 0.7; }

    .fg-export { margin-top: 1.6rem; }
    .fg-exphead { margin: 0 0 0.5rem; font-size: 0.95rem; }
    .fg-exprow { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.7rem; }
    .fg-exprow .btn { font-size: 0.82rem; padding: 0.55rem 0.8rem; }
    /* ── the under-tool landing sections: visual, wide, to the point ── */
    .fg-story, .fg-exports, .fg-steps, .fg-drawgif, .fg-faq { margin-top: 2.4rem; }
    .fg-story { border-top: var(--line); padding-top: 1.8rem; }
    .fg-story h2, .fg-exports h2, .fg-steps h2, .fg-faq h2 { margin: 0 0 0.7rem; font-size: 1.25rem; }
    .fg-story p { max-width: 74ch; line-height: 1.6; margin: 0; }

    /* platform export cards — the size IS the headline */
    .fg-expgrid { display: grid; gap: 0.8rem; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
    .fg-exp {
      display: block; text-decoration: none; color: var(--ink);
      border: var(--line); background: var(--paper); box-shadow: var(--shadow-sm, 4px 4px 0 var(--ink));
      padding: 0.85rem 0.95rem;
    }
    .fg-exp:hover { background: var(--banana); }
    .fg-exp b { display: block; font-size: 1.45rem; line-height: 1.1; }
    .fg-exp span { display: block; font-weight: 800; font-size: 0.85rem; margin-top: 0.15rem; }
    .fg-exp small { display: block; font-size: 0.74rem; opacity: 0.65; margin-top: 0.15rem; }

    /* numbered step tiles — big pixel numbers, one line each */
    .fg-stepgrid { display: grid; gap: 0.8rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    .fg-step {
      display: flex; gap: 0.75rem; align-items: flex-start;
      border: var(--line); background: var(--paper); box-shadow: var(--shadow-sm, 4px 4px 0 var(--ink));
      padding: 0.85rem 0.95rem;
    }
    .fg-step b {
      flex: 0 0 auto; width: 2rem; height: 2rem; display: grid; place-items: center;
      background: var(--ink); color: var(--banana); font-size: 1.15rem;
    }
    .fg-step span { font-size: 0.88rem; line-height: 1.5; }

    /* the draw-a-GIF callout — one loud banana band */
    .fg-drawgif {
      border: var(--line); background: var(--banana); box-shadow: var(--shadow);
      padding: 1.2rem 1.4rem;
    }
    .fg-drawgif h2 { margin: 0 0 0.5rem; font-size: 1.25rem; }
    .fg-drawgif p { max-width: 74ch; line-height: 1.6; margin: 0; }

    /* pixel-fact strip — ink cards, banana numbers */
    .fg-facts { display: grid; gap: 0.8rem; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); margin-top: 2.4rem; }
    .fg-fact { border: var(--line); background: var(--ink); color: var(--paper); box-shadow: var(--shadow); padding: 0.9rem 1rem; font-size: 0.85rem; line-height: 1.5; }
    .fg-fact b { display: block; font-size: 1.7rem; color: var(--banana); margin-bottom: 0.25rem; }

    /* visible FAQ — real content, same text the FAQPage markup carries */
    .fg-faqgrid { display: grid; gap: 0.6rem; align-items: start; }
    @media (min-width: 760px) { .fg-faqgrid { grid-template-columns: 1fr 1fr; } }
    .fg-faq details { border: var(--line); background: var(--paper); box-shadow: var(--shadow-sm, 4px 4px 0 var(--ink)); padding: 0.65rem 0.9rem; }
    .fg-faq summary { font-weight: 800; cursor: pointer; font-size: 0.95rem; }
    .fg-faq details > p { margin: 0.5rem 0 0.2rem; line-height: 1.6; font-size: 0.92rem; }

    /* doors to the rest of the site */
    .fg-doorswrap { margin-top: 2.4rem; border-top: var(--line); padding-top: 1.6rem; }
    .fg-doorswrap h2 { margin: 0 0 0.9rem; font-size: 1.25rem; }
    .fg-doors { display: grid; gap: 0.8rem; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); }
    .fg-doors a { display: block; border: var(--line); background: var(--paper); box-shadow: var(--shadow-sm, 4px 4px 0 var(--ink)); padding: 0.8rem 0.9rem; text-decoration: none; color: inherit; }
    .fg-doors a:hover b { text-decoration: underline; }
    .fg-doors b { display: block; margin-bottom: 0.25rem; }
    .fg-doors span { font-size: 0.83rem; opacity: 0.75; line-height: 1.5; display: block; }
    .fg-signrow { display: flex; gap: 0.6rem; margin-top: 0.7rem; }
    .fg-signrow[hidden] { display: none; }
    .fg-signrow input {
      flex: 1; min-width: 0; padding: 0.55rem 0.7rem; border: 3px solid var(--ink);
      font-family: inherit; font-size: 0.95rem; background: var(--paper); border-radius: 2px;
    }
    #fgDone { margin-top: 0.8rem; border: 3px solid var(--ink); background: var(--banana); padding: 0.7rem 0.9rem; font-size: 0.9rem; }
    #fgDone a { font-weight: 700; }

    /* the banana-themed confirm — no stock dialogs in this house */
    #fgModal { position: fixed; inset: 0; z-index: 60; background: rgba(17, 17, 17, 0.55);
      display: flex; align-items: center; justify-content: center; padding: 1rem; }
    #fgModal[hidden] { display: none; }
    .fg-modalcard { position: relative; background: var(--paper); border: 3px solid var(--ink);
      border-top: 10px solid var(--banana); box-shadow: 8px 8px 0 var(--ink);
      max-width: 360px; width: 100%; padding: 1.1rem 1.2rem; transform: rotate(-0.6deg); }
    .fg-modalcard h3 { margin: 0 0 0.4rem; padding-right: 2.6rem; }
    .fg-modalcard p { margin: 0 0 0.9rem; line-height: 1.5; font-size: 0.92rem; }
    .fg-modalnana { position: absolute; top: -34px; right: 10px; width: 38px; height: auto;
      image-rendering: pixelated; transform: rotate(6deg); }
    .fg-modalrow { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    #fgModalAlt[hidden] { display: none; } /* .btn sets display — hidden must still win */

    @media (max-width: 919px) {
      .fg-frame canvas { width: 48px; height: 48px; }
      .fg-panel { padding: 0.8rem; }
    }
  </style>

  <div class="fg-wrap">
    <div class="fg-head">
      <h1>the pixel forge — free emoji, emote &amp; GIF maker</h1>
      <p>
        In 1999 I drew a dancing banana in a tool about this simple — and it took over the internet.
        Here's that tool, rebuilt. Pencil, fill, frames, one great palette. <strong>Make the next one.</strong>
      </p>
    </div>

    <div class="fg-modebar" role="tablist" aria-label="What do you want to make?">
      <button class="fg-modetab" data-mode="emoji" aria-pressed="true" title="Make an emoji, emote or GIF">🎨 Emoji / GIF</button>
      <button class="fg-modetab" data-mode="items" aria-pressed="false" title="Make a wearable item the banana can wear at the rave">🍌 Items Workshop</button>
    </div>

    <div class="fg-grid">
      <div class="fg-stagecol">
        <div class="fg-stagecard">
          <div class="fg-toast fg-itemsonly" id="fgCanvasToast" role="status" aria-live="polite"></div>
          <canvas id="fgCanvas" width="512" height="512" aria-label="Pixel drawing canvas"></canvas>
        </div>
        <div class="fg-framesrow fg-emojionly">
          <div class="fg-frames" id="fgFrames"></div>
          <div class="fg-framectl">
            <button id="fgPlay" title="Play the animation on the big canvas (Space)" aria-pressed="false">▶ Play</button>
            <button id="fgAdd" title="New empty frame">+ frame</button>
            <button id="fgDup" title="Duplicate this frame">⧉</button>
            <button id="fgDel" title="Delete this frame">🗑</button>
            <button id="fgClear" title="Wipe this frame clean">🧹</button>
            <button id="fgMoveL" title="Move this frame earlier">◀</button>
            <button id="fgMoveR" title="Move this frame later">▶</button>
            <button id="fgOnion" title="Ghost of the previous frame (O)">👻</button>
            <label for="fgDelay" style="font-size:0.8rem;">delay</label>
            <input id="fgDelay" type="number" min="50" max="1000" step="10" value="120"> <span style="font-size:0.8rem;opacity:0.7;">ms</span>
            <span id="fgFrameInfo"></span>
          </div>
        </div>
      </div>

      <div class="fg-side">
        <div class="fg-panel fg-bar">
          <div class="fg-toolrow" role="toolbar" aria-label="Tools">
            <button class="fg-tool" data-tool="pencil" title="Pencil (B)" aria-label="Pencil" aria-pressed="true">✏️</button>
            <button class="fg-tool" data-tool="eraser" title="Eraser (E)" aria-label="Eraser">🧽</button>
            <button class="fg-tool" data-tool="fill" title="Fill (F)" aria-label="Fill">🪣</button>
            <button class="fg-tool" data-tool="picker" title="Pick a colour (I)" aria-label="Pick colour">💉</button>
            <span class="fg-vsep"></span>
            <button class="fg-tool fg-tool--wide" id="fgBrushBtn" title="Brush size" aria-label="Brush size"><span class="fg-brushdot"></span><b id="fgBrushLbl">1</b></button>
            <button class="fg-tool fg-colorbtn" id="fgColorBtn" title="Colour — click to choose" aria-label="Choose a colour"></button>
            <span class="fg-vsep"></span>
            <button class="fg-tool" id="fgUndo" title="Undo (Ctrl+Z)" aria-label="Undo">↩</button>
            <button class="fg-tool" id="fgRedo" title="Redo (Ctrl+Y)" aria-label="Redo">↪</button>
            <button class="fg-tool" id="fgFlipH" title="Flip horizontally" aria-label="Flip horizontally">⇋</button>
            <button class="fg-tool" id="fgFlipV" title="Flip vertically" aria-label="Flip vertically">⇵</button>
            <button class="fg-tool" id="fgShL" title="Nudge left" aria-label="Nudge left">←</button>
