---
// 🍌🏪 THE BANANA STAND — Banana World's shop (banana-stand-plan).
// S0.5 PREVIEW: noindexed, unlinked, absent from the sitemap allowlist.
// TWO SCENES, old-videogame style (Trym's spec 21 Jul):
//   1. THE ROOM — zoomed out: your own dancing banana walks in at the bottom
//      and you steer it up to the little kiosk (tap to walk / WASD).
//   2. THE COUNTER — walk up to the keeper and the scene CUTS to the close-up:
//      big shopkeeper, upper body behind a wooden desk, options open.
// Stock, coins on the floor and buying come in later stages.
import BaseLayout from '../layouts/BaseLayout.astro';
import { COIN_SVGS } from '../data/coin-art.js';

const title = 'The Banana Stand';
const description = 'There is always money in the banana stand.';
---
<BaseLayout title={title} description={description} showFooter={false}>
  <meta name="robots" content="noindex" slot="head" />
  <link rel="preload" as="image" href="/assets/banana-dance.png?v=6" slot="head" />
  <style is:inline slot="head">
    body { background: #0d0b14; }
    .bs-wrap { max-width: 560px; margin: 0 auto; padding: 0.6rem 0.8rem 2.5rem; color: #fffdf5; }
    .bs-sign {
      font-family: "Archivo Black", sans-serif; text-align: center;
      color: #ffe135; font-size: clamp(1.4rem, 6.4vw, 2.2rem); line-height: 1.05;
      margin: 0.7rem 0 0.15rem; letter-spacing: 0.02em;
      text-shadow: 0 0 12px rgba(255, 225, 53, 0.55), 0 0 30px rgba(255, 225, 53, 0.25);
    }
    .bs-sign .bs-flick { animation: bsFlicker 7s steps(1) infinite; }
    @keyframes bsFlicker { 0%, 92%, 96% { opacity: 1; } 93%, 95% { opacity: 0.25; text-shadow: none; } }
    .bs-tag { text-align: center; margin: 0 0 0.8rem; font-size: 0.82rem; opacity: 0.6; }

    /* ======= SCENE 1: the park (outdoors, zoomed out) ======= */
    .bs-room {
      position: relative; aspect-ratio: 4 / 3; max-height: 420px; overflow: hidden;
      border: 4px solid #000; box-shadow: 8px 8px 0 #000; cursor: pointer;
      background: url('/assets/banana-stand/park.png') center / 100% 100% no-repeat;
      image-rendering: pixelated;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    /* the STAND — the hut sprite; the keeper (player-sized) stands BEHIND its
       transparent window, over a dark interior */
    .bs-stand {
      position: absolute; left: 50%; top: 1.5%; transform: translateX(-50%);
      width: 27.5%; z-index: 2;
    }
    .bs-stand__body { position: relative; overflow: hidden; } /* clips the keeper's feet inside the hut (the bubble lives OUTSIDE this wrapper) */
    .bs-stand img { display: block; width: 100%; height: auto; image-rendering: pixelated; position: relative; z-index: 2; }
    .bs-stand__inner { /* the dark inside of the hut, seen through the window */
      position: absolute; left: 22%; top: 35%; width: 56%; height: 31%;
      background: #241d33; z-index: 0;
    }
    .bs-stand canvas {
      position: absolute; left: 50%; top: 24%; transform: translateX(-50%);
      width: 78%; height: auto; image-rendering: pixelated; z-index: 1;
    }
    /* the keeper's floor bubble — Barty-style call-outs over the kiosk */
    .bs-minibubble {
      position: absolute; left: 50%; bottom: calc(100% + 10px); transform: translateX(-50%);
      width: max-content; max-width: 200%;
      background: #fffdf5; color: #111; border: 3px solid #000;
      box-shadow: 4px 4px 0 #000; padding: 0.35rem 0.6rem; font-size: 0.8rem;
      font-weight: 700; opacity: 0; transition: opacity 0.2s ease; pointer-events: none;
    }
    .bs-minibubble.is-on { opacity: 1; }
    .bs-minibubble::after {
      content: ''; position: absolute; left: 50%; bottom: -9px; margin-left: -5px;
      border: 5px solid transparent; border-top-color: #000;
    }
    /* your banana */
    .bs-me { position: absolute; z-index: 3; width: 74px; margin-left: -37px; pointer-events: none; }
    .bs-me canvas { width: 100%; height: auto; image-rendering: pixelated; display: block; }
    /* birds flying by — two wing frames flapping, hidden for reduced motion */
    .bs-bird { position: absolute; left: -10%; z-index: 4; pointer-events: none; }
    .bs-bird svg { display: block; width: 100%; height: auto; image-rendering: pixelated; animation: bsFlapA 0.44s steps(1) infinite; }
    .bs-bird svg + svg { position: absolute; inset: 0; animation-name: bsFlapB; }
    @keyframes bsFlapA { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }
    @keyframes bsFlapB { 0%, 49% { opacity: 0; } 50%, 100% { opacity: 1; } }
    .bs-bird--1 { top: 9%; width: 16px; animation: bsFly 17s linear infinite; }
    .bs-bird--2 { top: 15%; width: 12px; animation: bsFly 23s linear 7s infinite; }
    @keyframes bsFly {
      0% { left: -10%; transform: translateY(0); }
      25% { transform: translateY(-7px); }
      50% { transform: translateY(3px); }
      75% { transform: translateY(-6px); }
      100% { left: 110%; transform: translateY(0); }
    }
    /* the ducks: drifting back and forth across the pond, turning at the ends */
    .bs-duck { position: absolute; z-index: 1; pointer-events: none; }
    .bs-duck svg { display: block; width: 100%; height: auto; image-rendering: pixelated; }
    .bs-duck--1 { left: 73%; top: 69%; width: 11px; animation: bsPaddle 11s ease-in-out infinite; }
    .bs-duck--2 { left: 84%; top: 76%; width: 10px; animation: bsPaddle 14s ease-in-out 3s infinite reverse; }
    .bs-duck--3 { left: 79%; top: 72%; width: 8px; animation: bsPaddle 9s ease-in-out 6s infinite; }
    @keyframes bsPaddle {
      0% { transform: translateX(0) scaleX(1); }
      48% { transform: translateX(26px) scaleX(1); }
      50% { transform: translateX(26px) scaleX(-1); }
      98% { transform: translateX(0) scaleX(-1); }
      100% { transform: translateX(0) scaleX(1); }
    }
    @media (prefers-reduced-motion: reduce) { .bs-bird { display: none; } .bs-duck { animation: none; } }
    .bs-hint {
      position: absolute; left: 50%; bottom: 6%; transform: translateX(-50%); z-index: 4;
      background: rgba(0, 0, 0, 0.55); border: 2px solid #000; color: #fffdf5;
      font-size: 0.78rem; padding: 0.3rem 0.65rem; pointer-events: none; white-space: nowrap;
      transition: opacity 0.4s ease;
    }
    .bs-hint.is-off { opacity: 0; }

    /* wallet HUD — videogame corner chip */
    .bs-hud {
      position: absolute; top: 8px; right: 8px; z-index: 5;
      display: flex; align-items: center; gap: 0.35rem;
      background: rgba(0, 0, 0, 0.55); border: 2px solid #000;
      padding: 0.2rem 0.5rem; font-weight: 800; font-size: 0.85rem; color: #ffe135;
    }
    .bs-hud svg { width: 20px; height: auto; image-rendering: pixelated; }

    /* ======= SCENE 2: the counter (zoomed in) ======= */
    .bs-shop[hidden] { display: none; }
    .bs-kiosk { position: relative; border: 4px solid #000; box-shadow: 8px 8px 0 #000; background: #17121f; }
    .bs-awning { display: flex; height: 26px; }
    .bs-awning span { flex: 1; }
    .bs-awning span:nth-child(odd) { background: #ffe135; }
    .bs-awning span:nth-child(even) { background: #241d33; }
    /* inside the stand: dark yellowish banana-stand planks behind the keeper */
    .bs-window {
      position: relative;
      background:
        linear-gradient(rgba(0, 0, 0, 0.30), rgba(0, 0, 0, 0.06) 45%),
        repeating-linear-gradient(90deg, #6b5617 0 24px, #4a3a0d 24px 27px, #63500f 27px 51px, #4a3a0d 51px 54px);
      height: clamp(170px, 38vw, 218px); overflow: hidden;
    }
    /* the keeper is BIG — only his upper body clears the desk */
    .bs-keeper {
      appearance: none; background: none; border: 0; padding: 0; cursor: pointer;
      display: block; width: min(400px, 92%); margin: 0 auto;
    }
    .bs-keeper canvas { display: block; width: 100%; height: auto; image-rendering: pixelated; margin-top: -13%; }
    /* the bubble docks top-RIGHT (anchored to the KIOSK, over the awning) —
       the keeper's head lives center-frame, so this column is always clear */
    .bs-bubble {
      position: absolute; right: 2.5%; top: 6px; z-index: 3;
      max-width: 39%; background: #fffdf5; color: #111; border: 3px solid #000;
      box-shadow: 4px 4px 0 #000; padding: 0.32rem 0.55rem; font-size: 0.74rem;
      font-weight: 700; opacity: 0; transition: opacity 0.2s ease; pointer-events: none;
    }
    .bs-bubble.is-on { opacity: 1; }
    .bs-bubble::after {
      content: ''; position: absolute; left: 14%; bottom: -9px;
      border: 5px solid transparent; border-top-color: #000;
    }
    .bs-counter {
      height: 74px; border-top: 4px solid #000; position: relative;
      background: repeating-linear-gradient(90deg, #3a2b18 0 26px, #2c2113 26px 52px);
    }
    .bs-counter::before {
      content: ''; position: absolute; inset: 0 0 auto; height: 8px;
      background: #4a3820; border-bottom: 3px solid #000;
    }
    /* your coin wallet, sitting on the left end of the desk */
    .bs-deskwallet {
      position: absolute; left: 4%; top: 54%; transform: translateY(-50%); z-index: 2;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .bs-deskwallet svg {
      width: 42px; height: auto; image-rendering: pixelated;
      filter: drop-shadow(2px 3px 0 rgba(0, 0, 0, 0.45));
    }
    .bs-deskwallet b {
      font-family: "Archivo Black", sans-serif; color: #ffe135; font-size: 1.2rem;
      text-shadow: 2px 2px 0 #000;
    }
    .bs-hooks { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.7rem; margin-top: 1rem; }
    .bs-hook {
      appearance: none; border: 3px solid #000; background: #17121f; color: #fffdf5;
      box-shadow: 5px 5px 0 #000; cursor: pointer; padding: 0.7rem 0.4rem 0.55rem;
      display: grid; justify-items: center; gap: 0.35rem; min-height: 86px;
      font-family: inherit; transition: transform 0.08s ease;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .bs-hook:active { transform: translate(2px, 2px); box-shadow: 3px 3px 0 #000; }
    .bs-hook svg { width: 22px; height: auto; image-rendering: pixelated; opacity: 0.85; }
    .bs-hook small {
      border: 2px solid #000; background: #ffe135; color: #111; font-weight: 800;
      font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase;
      padding: 0.1rem 0.4rem; transform: rotate(-2deg);
    }
    .bs-hook:nth-child(even) small { transform: rotate(2deg); }

    /* the buttons under each scene */
    .bs-foot { display: flex; gap: 0.8rem; margin-top: 1rem; flex-wrap: wrap; }
    .bs-btn {
      flex: 1 1 160px; display: grid; place-items: center; text-align: center;
      border: 3px solid #000; background: #ffe135; color: #111; font-weight: 800;
      box-shadow: 5px 5px 0 #000; padding: 0.8rem; text-decoration: none;
      font-family: inherit; font-size: 1rem; cursor: pointer;
    }
    .bs-btn--dark { background: #17121f; color: #fffdf5; }
    .bs-btn:active { transform: translate(2px, 2px); box-shadow: 3px 3px 0 #000; }

    /* the scene CUT: a hard black blink, like a cartridge game */
    .bs-cut {
      position: fixed; inset: 0; background: #000; z-index: 60; pointer-events: none;
      opacity: 0; transition: opacity 0.12s steps(2);
    }
    .bs-cut.is-on { opacity: 1; }

    @media (prefers-reduced-motion: reduce) {
      .bs-sign .bs-flick { animation: none; }
      .bs-cut { transition: none; }
    }
  </style>

  <div class="bs-wrap">
    <h1 class="bs-sign">THE BANANA <span class="bs-flick">STAND</span></h1>
    <p class="bs-tag">there's always money in the banana stand</p>

    <!-- ======= SCENE 1: the room ======= -->
    <div id="bsScene1">
      <div class="bs-room" id="bsRoom">
        <div class="bs-hud"><Fragment set:html={COIN_SVGS.coin} /><span id="bsWallet">0</span></div>
        <div class="bs-stand" id="bsMini">
          <div class="bs-minibubble" id="bsRoomBubble" role="status" aria-live="polite"></div>
          <div class="bs-stand__body">
            <div class="bs-stand__inner" aria-hidden="true"></div>
            <canvas id="bsMiniCv" width="150" height="150" aria-hidden="true"></canvas>
            <img src="/assets/banana-stand/hut.png" alt="" aria-hidden="true" />
          </div>
        </div>
        <span class="bs-bird bs-bird--1" aria-hidden="true">
          <svg viewBox="0 0 10 4" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges"><rect x="1" y="0" width="1" height="1" fill="#2b2b2b"/><rect x="8" y="0" width="1" height="1" fill="#2b2b2b"/><rect x="2" y="1" width="1" height="1" fill="#2b2b2b"/><rect x="7" y="1" width="1" height="1" fill="#2b2b2b"/><rect x="3" y="2" width="1" height="1" fill="#2b2b2b"/><rect x="6" y="2" width="1" height="1" fill="#2b2b2b"/><rect x="4" y="3" width="2" height="1" fill="#2b2b2b"/></svg>
          <svg viewBox="0 0 10 4" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges"><rect x="4" y="0" width="2" height="1" fill="#2b2b2b"/><rect x="3" y="1" width="1" height="1" fill="#2b2b2b"/><rect x="6" y="1" width="1" height="1" fill="#2b2b2b"/><rect x="2" y="2" width="1" height="1" fill="#2b2b2b"/><rect x="7" y="2" width="1" height="1" fill="#2b2b2b"/><rect x="1" y="3" width="1" height="1" fill="#2b2b2b"/><rect x="8" y="3" width="1" height="1" fill="#2b2b2b"/></svg>
        </span>
        <span class="bs-bird bs-bird--2" aria-hidden="true">
          <svg viewBox="0 0 10 4" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges"><rect x="1" y="0" width="1" height="1" fill="#3a3a3a"/><rect x="8" y="0" width="1" height="1" fill="#3a3a3a"/><rect x="2" y="1" width="1" height="1" fill="#3a3a3a"/><rect x="7" y="1" width="1" height="1" fill="#3a3a3a"/><rect x="3" y="2" width="1" height="1" fill="#3a3a3a"/><rect x="6" y="2" width="1" height="1" fill="#3a3a3a"/><rect x="4" y="3" width="2" height="1" fill="#3a3a3a"/></svg>
          <svg viewBox="0 0 10 4" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges"><rect x="4" y="0" width="2" height="1" fill="#3a3a3a"/><rect x="3" y="1" width="1" height="1" fill="#3a3a3a"/><rect x="6" y="1" width="1" height="1" fill="#3a3a3a"/><rect x="2" y="2" width="1" height="1" fill="#3a3a3a"/><rect x="7" y="2" width="1" height="1" fill="#3a3a3a"/><rect x="1" y="3" width="1" height="1" fill="#3a3a3a"/><rect x="8" y="3" width="1" height="1" fill="#3a3a3a"/></svg>
        </span>
        <span class="bs-duck bs-duck--1" aria-hidden="true"><svg viewBox="0 0 8 5" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges"><rect x="0" y="2" width="1" height="1" fill="#fffdf5"/><rect x="1" y="2" width="5" height="2" fill="#fffdf5"/><rect x="5" y="0" width="2" height="2" fill="#ffe135"/><rect x="7" y="1" width="1" height="1" fill="#ff9128"/><rect x="6" y="0" width="1" height="1" fill="#111111"/></svg></span>
        <span class="bs-duck bs-duck--2" aria-hidden="true"><svg viewBox="0 0 8 5" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges"><rect x="0" y="2" width="1" height="1" fill="#fffdf5"/><rect x="1" y="2" width="5" height="2" fill="#fffdf5"/><rect x="5" y="0" width="2" height="2" fill="#ffe135"/><rect x="7" y="1" width="1" height="1" fill="#ff9128"/><rect x="6" y="0" width="1" height="1" fill="#111111"/></svg></span>
        <span class="bs-duck bs-duck--3" aria-hidden="true"><svg viewBox="0 0 8 5" xmlns="http://www.w3.org/2000/svg" shape-rendering="crispEdges"><rect x="0" y="2" width="1" height="1" fill="#fffdf5"/><rect x="1" y="2" width="5" height="2" fill="#fffdf5"/><rect x="5" y="0" width="2" height="2" fill="#ffe135"/><rect x="7" y="1" width="1" height="1" fill="#ff9128"/><rect x="6" y="0" width="1" height="1" fill="#111111"/></svg></span>
        <div class="bs-me" id="bsMe"><canvas id="bsMeCv" width="150" height="150" aria-hidden="true"></canvas></div>
        <div class="bs-hint" id="bsHint">walk up to the stand — tap the grass or use WASD</div>
      </div>
      <div class="bs-foot">
        <a class="bs-btn bs-btn--dark" href="/rave/" data-place="stand">🪩 leave — back to the club</a>
      </div>
    </div>

    <!-- ======= SCENE 2: the counter ======= -->
    <div id="bsScene2" class="bs-shop" hidden>
      <div class="bs-kiosk">
        <div class="bs-bubble" id="bsBubble" role="status" aria-live="polite"></div>
        <div class="bs-awning" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
        <div class="bs-window">
          <button class="bs-keeper" id="bsKeeper" aria-label="The shopkeeper">
            <canvas id="bsKeeperCv" width="360" height="360" aria-hidden="true"></canvas>
          </button>
        </div>
        <div class="bs-counter">
          <div class="bs-deskwallet" aria-label="Your bananacoins">
            <Fragment set:html={COIN_SVGS.coin} />
            <b id="bsDeskWallet">0</b>
          </div>
        </div>
      </div>

      <div class="bs-hooks" id="bsHooks">
        {[1, 2, 3, 4, 5, 6].map(() => (
          <button class="bs-hook" type="button">
            <svg viewBox="0 0 7 8" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><rect x="3" y="0" width="1" height="1" fill="#8a8296"/><rect x="2" y="1" width="1" height="1" fill="#8a8296"/><rect x="4" y="1" width="1" height="1" fill="#8a8296"/><rect x="2" y="2" width="1" height="1" fill="#8a8296"/><rect x="4" y="2" width="1" height="1" fill="#8a8296"/><rect x="4" y="3" width="1" height="1" fill="#8a8296"/><rect x="3" y="4" width="2" height="1" fill="#8a8296"/><rect x="2" y="5" width="1" height="1" fill="#8a8296"/><rect x="5" y="5" width="1" height="1" fill="#8a8296"/><rect x="3" y="6" width="2" height="1" fill="#8a8296"/></svg>
            <small>soon</small>
          </button>
        ))}
      </div>

      <div class="bs-foot">
        <button class="bs-btn bs-btn--dark" id="bsBack" type="button">↓ step back from the counter</button>
        <a class="bs-btn" href="/rave/" data-place="stand">🪩 back to the club →</a>
      </div>
    </div>
  </div>

  <div class="bs-cut" id="bsCut" aria-hidden="true"></div>

  <script>
    import '../scripts/banana-stand.js';
  </script>
</BaseLayout>
