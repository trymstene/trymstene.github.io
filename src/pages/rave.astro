---
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelIcon from '../components/PixelIcon.astro';

const title = 'The Banana Rave — everyone dances together';
const description = 'A live dance floor where every visitor’s custom banana dances in perfect sync. Join the rave, drop an emote, outlast the others. Silent disco until Sentry finishes the remix.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'The Banana Rave',
  url: 'https://trymstene.com/rave/',
  applicationCategory: 'EntertainmentApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  creator: { '@id': 'https://trymstene.com/#trym' },
  description: 'A realtime dance floor for custom dancing bananas, from the creator of the original 1999 GIF.',
};
---
<BaseLayout
  title={title}
  description={description}
  ogTitle="The Banana Rave 🪩"
  ogDescription="Every visitor's banana, dancing together in perfect sync. Right now. Join the floor."
  ogImage="https://trymstene.com/assets/og/builder.png"
  showFooter={false}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <style is:inline slot="head">
    /* isolate = nothing inside the rave (raver z-indexes, drop flash) can ever
       paint over the sticky nav / slide menu (iOS Safari bug Trym caught) */
    .rv-hall { background: #0d0b14; color: #fffdf5; padding: 1.6rem 1rem 2.5rem; position: relative; isolation: isolate; z-index: 0; }
    .rv-head { max-width: 1100px; margin: 0 auto 1rem; display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.6rem 1.4rem; }
    .rv-head h1 { margin: 0; font-size: clamp(1.6rem, 5vw, 2.6rem); color: #ffe135; }
    .rv-live { color: #37d67a; font-weight: 700; }
    .rv-status { font-size: 0.85rem; opacity: 0.85; }
    .rv-sub { max-width: 1100px; margin: 0 auto 1.2rem; font-size: 0.92rem; opacity: 0.75; }

    .rv-stagewrap { max-width: 1100px; margin: 0 auto; display: grid; gap: 1rem; grid-template-columns: 1fr; }
    @media (min-width: 980px) { .rv-stagewrap { grid-template-columns: 1fr 240px; align-items: start; } }

    /* the floor: pixel checkerboard that pulses */
    .rv-club { position: relative; border: 4px solid #ffe135; box-shadow: 8px 8px 0 #000; overflow: hidden; }
    /* the stage: Sentry-style DJ desk front-centre, speakers flanking,
       earned companions dancing on a line behind the DJ */
    .rv-booth { position: relative; background: #17121f; border-bottom: 4px solid #0d0b14; min-height: 164px; }
    .rv-stage {
      position: absolute; left: 0; right: 0; bottom: 42px;
      display: flex; justify-content: center; align-items: flex-end; gap: 10px; z-index: 1;
    }
    .rv-stage .rv-raver { position: relative; transform: none; left: auto; top: auto; }
    .rv-stage__gap { flex: none; width: 104px; } /* the DJ stands here — keep the middle clear */
    .rv-stage .rv-raver canvas { width: 58px !important; height: 58px !important; }
    .rv-djgroup { position: absolute; left: 50%; bottom: 0; transform: translateX(-50%); width: 150px; z-index: 2; }
    .rv-djgroup canvas { width: 96px; height: 96px; display: block; margin: 0 auto -36px; position: relative; z-index: 1; }
    .rv-desk {
      position: relative; z-index: 2; height: 40px;
      background: #241a38; border: 3px solid #0d0b14; box-shadow: inset 0 4px 0 #2f2250;
    }
    .rv-desk::before, .rv-desk::after { content: ''; position: absolute; top: 7px; width: 6px; height: 6px; background: #b388ff; box-shadow: 0 10px 0 #37d67a; }
    .rv-desk::before { left: 8px; }
    .rv-desk::after { right: 8px; }
    .rv-desk__label {
      position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
      background: #ffe135; color: #111; font-weight: 800; font-size: 0.58rem;
      letter-spacing: 0.08em; padding: 0.18rem 0.45rem; text-transform: uppercase; white-space: nowrap;
    }
    .rv-speaker { position: absolute; bottom: 0; width: 50px; height: 68px; z-index: 2; shape-rendering: crispEdges; }
    .rv-speaker--l { left: calc(50% - 134px); }
    .rv-speaker--r { right: calc(50% - 134px); }
    body.rv-drop .rv-speaker { animation: rvPump 0.24s steps(2) infinite; transform-origin: bottom center; }
    @keyframes rvPump { 50% { transform: scaleY(1.07) scaleX(1.05); } }
    @media (prefers-reduced-motion: reduce) {
      body.rv-drop .rv-speaker, .rv-mnote, .rv-beam, .rv-dropflash span { animation: none; }
      .rv-pyro { display: none !important; }
      .rv-mnote { opacity: 0.5; }
    }
    .rv-sign { position: absolute; top: 8px; right: 12px; font-size: 0.6rem; color: #b388ff; opacity: 0.7; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; }

    /* stage production: notes drift from the speakers; beams sweep always;
       pyro fountains fire during THE DROP (which now flashes ABOVE the DJ) */
    .rv-mnote { /* NOT .rv-note — that's the panel's text note */
      position: absolute; bottom: 44px; font-size: 0.95rem; color: #b388ff; opacity: 0;
      z-index: 3; pointer-events: none; animation: rvNote 2.6s linear infinite;
    }
    .rv-mnote--1 { left: calc(50% - 152px); }
    .rv-mnote--2 { left: calc(50% - 118px); color: #4db8ff; animation-delay: 1.2s; }
    .rv-mnote--3 { right: calc(50% - 152px); animation-delay: 0.6s; }
    .rv-mnote--4 { right: calc(50% - 118px); color: #4db8ff; animation-delay: 1.8s; }
    @keyframes rvNote {
      0% { transform: translateY(0); opacity: 0; }
      15% { opacity: 1; }
      100% { transform: translateY(-48px); opacity: 0; }
    }
    .rv-beam {
      position: absolute; top: 0; width: 44px; height: 100%; z-index: 0; pointer-events: none;
      background: linear-gradient(rgba(255, 225, 53, 0.14), transparent 80%);
      clip-path: polygon(38% 0, 62% 0, 100% 100%, 0 100%);
      transform-origin: 50% 0; animation: rvBeam 3.4s steps(7) infinite alternate;
    }
    .rv-beam--l { left: 16%; }
    .rv-beam--r { right: 16%; animation-delay: 1.7s; }
    body.rv-drop .rv-beam { animation-duration: 0.5s; background: linear-gradient(rgba(255, 77, 109, 0.3), transparent 80%); }
    @keyframes rvBeam { from { transform: rotate(-26deg); } to { transform: rotate(26deg); } }
    .rv-pyro {
      position: absolute; bottom: 0; width: 6px; height: 62px; z-index: 1; pointer-events: none;
      display: none; transform-origin: bottom;
      background: linear-gradient(to top, transparent, #ff9f1c 30%, #ffe135 70%, #fffdf5);
    }
    body.rv-drop .rv-pyro { display: block; animation: rvPyro 0.45s steps(5) infinite; }
    .rv-pyro--1 { left: 7%; }
    .rv-pyro--2 { left: 24%; animation-delay: 0.15s; }
    .rv-pyro--3 { right: 24%; animation-delay: 0.3s; }
    .rv-pyro--4 { right: 7%; animation-delay: 0.1s; }
    @keyframes rvPyro {
      0% { transform: scaleY(0.15); }
      60% { transform: scaleY(1); opacity: 1; }
      100% { transform: scaleY(0.7); opacity: 0.55; }
    }

    .rv-floor { position: relative; height: min(62vh, 560px); overflow: hidden; background: #161022; }
    /* the world layer: ravers + checkerboard live here so the camera (translate+scale)
       moves the floor WITH the crowd; screen-space chrome (drop flash, zoom btn) stays outside */
    .rv-world {
      position: absolute; inset: 0; transform-origin: 0 0;
      background:
        repeating-conic-gradient(#161022 0% 25%, #1d1530 0% 50%) 0 0 / 96px 96px;
      image-rendering: pixelated;
      will-change: transform; /* the follow-cam pans this layer every frame — keep it on the compositor */
    }
    body.rv-drop .rv-world {
      background:
        repeating-conic-gradient(#2a1650 0% 25%, #451d66 0% 50%) 0 0 / 96px 96px;
      animation: rvStrobe 0.24s steps(2) infinite;
    }
    @keyframes rvStrobe { 50% { filter: hue-rotate(140deg) brightness(1.25); } }
    @media (prefers-reduced-motion: reduce) { body.rv-drop .rv-world { animation: none; } }
    /* the bar, tucked into the BOTTOM-LEFT corner of the world — down = nearer, so
       you "come up to the bar" by dancing toward the viewer. Only the top of the
       countertop peeks in (the rest bleeds off the corner). Barty — full
       bottom-of-floor dancer size — stands on the NEAR side of the counter,
       mirrored to face the stage; the floor edge crops his lower half. */
    /* z 300 > any raver (they cap at 100 + y = ~192): a banana overlapping the bar
       is standing further away on the floor, so the counter must cover it */
    .rv-bar { position: absolute; left: -18px; bottom: -52px; width: 205px; z-index: 300; pointer-events: none; }
    .rv-counter { display: block; width: 100%; height: auto; position: relative; z-index: 2; }
    /* Barty is ABSOLUTE — fully independent of the counter. He was in flow before,
       so raising him shrank the bottom-anchored block and the DESK sank instead
       (Trym caught it in devtools: the desk followed him). top adjusts ONLY him. */
    #rvBarman {
      position: absolute; top: -91px; left: 14px; width: 150px; height: 150px;
      z-index: 3; image-rendering: pixelated;
    }
    .rv-counterbeer { position: absolute; width: 32px; height: auto; left: 62%; top: -24px; z-index: 4; }
    /* Barty's special of the window: the cocktail sits where the beer sits —
       38% landed ON Barty and overflowed him (Trym, iOS). Beer + special never
       show at the same time (happy hour vs specials window), so they share the spot. */
    .rv-special { position: absolute; width: 26px; left: 62%; top: -26px; z-index: 4; line-height: 0; animation: rvItemBob 0.8s steps(2) infinite; filter: drop-shadow(0 0 6px rgba(120, 235, 255, 0.5)); }
    .rv-special[hidden] { display: none; }
    .rv-special svg { width: 100%; height: auto; image-rendering: pixelated; }
    .rv-bubble {
      position: absolute; bottom: calc(100% + 54px); left: 46%; transform: translateX(-50%);
      min-width: 150px; max-width: 210px; z-index: 5; text-align: center;
      background: #fffdf5; color: #111; border: 3px solid #111; box-shadow: 3px 3px 0 #000;
      font-size: 0.58rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase;
      line-height: 1.5; padding: 0.4rem 0.5rem;
    }
    /* stepped pixel tail pointing down at Barty (two shrinking steps, no rotation) */
    .rv-bubble::before {
      content: ''; position: absolute; top: 100%; left: 30px; width: 14px; height: 6px;
      background: #fffdf5; border-left: 3px solid #111; border-right: 3px solid #111;
    }
    .rv-bubble::after {
      content: ''; position: absolute; top: calc(100% + 6px); left: 34px; width: 6px; height: 6px;
      background: #fffdf5; border-left: 3px solid #111; border-right: 3px solid #111; border-bottom: 3px solid #111;
    }

    /* floor life: light trails, the wandering spotlight, the lost vinyl */
    .rv-trails { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 5; pointer-events: none; image-rendering: pixelated; }
    .rv-spot {
      position: absolute; width: 200px; height: 160px; transform: translate(-50%, -50%);
      z-index: 8; pointer-events: none;
      background: radial-gradient(closest-side, rgba(255, 225, 53, 0.3), rgba(255, 225, 53, 0.12) 55%, transparent 72%);
    }
    .rv-spot[hidden] { display: none; }
    .rv-lit canvas { filter: drop-shadow(0 0 10px #ffe135) drop-shadow(0 0 3px #fffdf5); }
    .rv-raver--me.rv-lit canvas { filter: drop-shadow(0 0 6px #ffe135) drop-shadow(0 0 12px #fffdf5); }
    /* floor items (vinyl, hot sauce): a soft glow + beat-bob so they beg to be grabbed */
    .rv-item {
      position: absolute; width: 36px; height: 36px; transform: translate(-50%, -50%);
      z-index: 9; image-rendering: pixelated; pointer-events: none;
      filter: drop-shadow(0 0 7px rgba(255, 225, 53, 0.45));
      animation: rvItemBob 0.8s steps(2) infinite;
    }
    .rv-item--tall { width: 26px; height: 39px; }
    .rv-item--gold { width: 40px; height: 40px; filter: drop-shadow(0 0 10px rgba(255, 225, 53, 0.85)) drop-shadow(0 0 3px #fffdf5); }
    .rv-item svg { width: 100%; height: 100%; }
    /* conveyor item sizes by kind (sprites have different aspect ratios) */
    .rv-item[data-kind="sauce"], .rv-item[data-kind="fizz"], .rv-item[data-kind="zap"], .rv-item[data-kind="balloon"] { width: 26px; height: 39px; }
    .rv-item[data-kind="candy"] { width: 38px; height: 26px; }
    .rv-item[data-kind="pizza"] { width: 32px; height: 32px; }
    .rv-item[data-kind="zap"] { filter: drop-shadow(0 0 8px rgba(120, 235, 255, 0.7)); }
    /* the twinkle: the next item announces its spot 4s early — race it */
    .rv-twinkle { position: absolute; width: 8px; height: 8px; margin: -4px 0 0 -4px; z-index: 8; pointer-events: none; background: #fffdf5; box-shadow: 0 -10px #ffe135, 0 10px #ffe135, -10px 0 #ffe135, 10px 0 #ffe135, 0 0 10px #fffdf5; animation: rvTwinkle 0.5s steps(2) infinite; }
    .rv-twinkle[hidden] { display: none; }
    @keyframes rvTwinkle { 50% { transform: scale(0.45) rotate(45deg); opacity: 0.5; } }
    /* THE WAVE hop (applied inline with per-banana delay) + chain glow + zap glow */
    @keyframes rvWaveHop { 30% { transform: translateY(-20px); } 60% { transform: translateY(-3px); } }
    .rv-raver.rv-chainglow canvas { filter: drop-shadow(0 0 8px #ffd23f) drop-shadow(0 0 16px #ff9128); }
    .rv-raver.rv-zapfx canvas { filter: drop-shadow(0 0 7px #78ebff); }
    @keyframes rvItemBob { 50% { transform: translate(-50%, -62%) scale(1.1); } }
    /* pickup juice: a pixel ring + four stars burst where the item was grabbed */
    .rv-pop { position: absolute; width: 60px; height: 60px; transform: translate(-50%, -50%); z-index: 520; pointer-events: none; }
    .rv-pop__ring {
      position: absolute; inset: 16px; border: 4px solid #ffe135;
      animation: rvPopRing 0.55s steps(4) forwards;
    }
    .rv-pop__s {
      position: absolute; left: 50%; top: 50%; width: 6px; height: 6px; margin: -3px 0 0 -3px;
      background: #fffdf5; box-shadow: 0 0 6px #ffe135;
      animation: rvPopStar 0.75s steps(5) forwards;
    }
    @keyframes rvPopRing {
      0% { transform: scale(0.35); opacity: 1; }
      70% { transform: scale(1.15); opacity: 0.8; }
      100% { transform: scale(1.35); opacity: 0; }
    }
    @keyframes rvPopStar {
      0% { transform: translate(0, 0); opacity: 1; }
      100% { transform: translate(var(--dx), var(--dy)); opacity: 0; }
    }
    /* the fistbump: two gloves slide in, BUMP (pixel spark), drift up and fade */
    .rv-five { position: absolute; width: 74px; height: 40px; transform: translate(-50%, -50%); z-index: 500; pointer-events: none; animation: rvFiveWrap 1.5s steps(6) forwards; }
    .rv-five span { position: absolute; left: 50%; top: 50%; width: 32px; line-height: 0; }
    .rv-five svg { width: 100%; height: auto; image-rendering: pixelated; filter: drop-shadow(0 0 4px #ffe135); }
    .rv-five__l { animation: rvBumpL 0.8s steps(4) forwards; }
    .rv-five__r { animation: rvBumpR 0.8s steps(4) forwards; }
    .rv-five::after { /* the impact star — a crisp pixel plus, no glyphs */
      content: ''; position: absolute; left: 50%; top: 50%; width: 6px; height: 6px; margin: -3px 0 0 -3px;
      background: #ffe135; box-shadow: 0 -9px #ffe135, 0 9px #ffe135, -9px 0 #ffe135, 9px 0 #ffe135, 0 0 8px #ffe135;
      opacity: 0; animation: rvBumpSpark 1.5s steps(3) forwards;
    }
    @keyframes rvBumpL {
      0% { transform: translate(-34px, -50%); }
      45% { transform: translate(-27px, -50%); }
      55% { transform: translate(-30px, -50%); }
      100% { transform: translate(-28px, -50%); }
    }
    @keyframes rvBumpR {
      0% { transform: translate(6px, -50%) scaleX(-1); }
      45% { transform: translate(-1px, -50%) scaleX(-1); }
      55% { transform: translate(2px, -50%) scaleX(-1); }
      100% { transform: translate(0px, -50%) scaleX(-1); }
    }
    @keyframes rvBumpSpark {
      0%, 40% { opacity: 0; transform: scale(0.4); }
      50% { opacity: 1; transform: scale(1.2); }
      75% { opacity: 0.8; }
      100% { opacity: 0; transform: scale(0.6); }
    }
    @keyframes rvFiveWrap {
      0% { opacity: 0; transform: translate(-50%, -50%); }
      10% { opacity: 1; }
      65% { opacity: 1; transform: translate(-50%, -60%); }
      100% { opacity: 0; transform: translate(-50%, -110%); }
    }
    .rv-carry { position: absolute; top: -1.5rem; right: -0.8rem; width: 22px; z-index: 5; line-height: 0; }
    .rv-carry svg { width: 100%; height: auto; image-rendering: pixelated; }
    @media (prefers-reduced-motion: reduce) { .rv-item, .rv-five, .rv-special, .rv-pop *, .rv-twinkle { animation: none; } }

    /* THE MIXER — hype meter + chain, docked in the dead space right of the bar
       (Trym's placement: on the floor itself, no scrolling to see your numbers) */
    .rv-mixer {
      position: absolute; right: 8px; bottom: 8px; z-index: 600; pointer-events: none;
      background: rgba(13, 11, 20, 0.88); border: 3px solid #2f2250; padding: 6px 8px;
      font-size: 0.6rem; font-weight: 800; letter-spacing: 0.08em; color: #b388ff;
    }
    .rv-mixer__row { display: flex; align-items: center; gap: 6px; }
    .rv-mixer__bar { display: flex; gap: 2px; }
    .rv-mixer__seg { width: 7px; height: 13px; background: #241a38; }
    .rv-mixer__seg.on { background: #b388ff; }
    .rv-mixer__seg.on:nth-child(n+6) { background: #ffe135; }
    .rv-mixer__seg.on:nth-child(n+10) { background: #ff4d9d; }
    .rv-mixer--peak { border-color: #ffe135; animation: rvMixerPeak 0.5s steps(2) infinite; }
    @keyframes rvMixerPeak { 50% { border-color: #ff4d9d; } }
    .rv-mixer__chain { margin-top: 4px; color: #ffe135; }
    .rv-mixer__chain[hidden] { display: none; }
    /* hype mode: the whole floor sees you peak (effect travels the outfit pipe;
       this glow is the local cherry) */
    .rv-raver.rv-hypemode canvas { filter: drop-shadow(0 0 10px #ffe135) drop-shadow(0 0 18px #ff4d9d); }
    /* sparkle runs: your personal pellet trail — pure chase fuel */
    .rv-pellet {
      position: absolute; width: 7px; height: 7px; margin: -3.5px 0 0 -3.5px;
      background: #ffe135; transform: rotate(45deg); z-index: 8; pointer-events: none;
      box-shadow: 0 0 6px rgba(255, 225, 53, 0.8);
      animation: rvPelletBob 0.7s steps(2) infinite;
    }
    @keyframes rvPelletBob { 50% { transform: rotate(45deg) scale(1.35); } }
    .rv-pellet--got { animation: rvPelletGot 0.4s steps(3) forwards; }
    @keyframes rvPelletGot { 100% { transform: rotate(45deg) scale(2.4); opacity: 0; } }
    @media (prefers-reduced-motion: reduce) { .rv-pellet, .rv-mixer--peak { animation: none; } }

    .rv-zoom {
      position: absolute; top: 8px; right: 8px; z-index: 600;
      background: rgba(13, 11, 20, 0.85); color: #fffdf5; border: 3px solid #ffe135;
      font-size: 0.72rem; font-weight: 800; letter-spacing: 0.04em; padding: 0.45rem 0.6rem;
      cursor: pointer; touch-action: manipulation; -webkit-tap-highlight-color: transparent; user-select: none;
    }
    .rv-zoom:hover { background: #ffe135; color: #111; }
    /* first-night tip: how to move — fades on the first step or after a few seconds */
    .rv-tip {
      position: absolute; left: 50%; bottom: 16%; transform: translateX(-50%); z-index: 650;
      max-width: 86%; text-align: center; pointer-events: none;
      background: #fffdf5; color: #111; border: 3px solid #111; box-shadow: 3px 3px 0 #000;
      font-size: 0.72rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase;
      line-height: 1.5; padding: 0.5rem 0.7rem;
      opacity: 1; transition: opacity 0.6s ease;
    }
    .rv-tip--fade { opacity: 0; }
    /* pickup/earn banner: SLIM and at the BOTTOM — the old top box covered the
       exact spot you tap to walk toward the DJ, and ate the taps (Trym, iOS) */
    .rv-glowtoast {
      position: absolute; left: 50%; bottom: 10px; transform: translateX(-50%); z-index: 700;
      max-width: 94%; text-align: center; font-size: 0.72rem; line-height: 1.4;
      background: rgba(23, 18, 31, 0.94); color: #fffdf5; border: 2px solid #39ff14;
      box-shadow: 0 0 10px rgba(57, 255, 20, 0.4); padding: 0.35rem 0.75rem;
      pointer-events: none;
    }
    .rv-glowtoast b { color: #39ff14; }

    .rv-raver { position: absolute; transform: translate(-50%, -50%); line-height: 0; transition: left 0.18s linear, top 0.18s linear; }
    .rv-raver canvas { transition: transform 0.15s ease; }
    .rv-floor { cursor: pointer; touch-action: manipulation; }
    .rv-raver canvas { image-rendering: pixelated; }
    .rv-raver--me canvas { filter: drop-shadow(0 0 6px #ffe135); }
    .rv-you {
      position: absolute; top: -1.3rem; left: 50%; transform: translateX(-50%);
      background: #ffe135; color: #111; font-size: 0.62rem; font-weight: 800;
      line-height: 1.2; /* .rv-raver zeroes line-height for the canvas — restore it or the tag collapses to a sliver */
      padding: 0.14rem 0.45rem; letter-spacing: 0.06em; text-transform: uppercase;
    }
    .rv-emote {
      position: absolute; left: 50%; top: 0; font-size: 1.5rem; line-height: 1;
      animation: rvFloat 1.9s ease-out forwards; pointer-events: none;
    }
    .rv-emote--heart { color: #ff4d6d; }
    .rv-emote--confetti { color: #4db8ff; }
    .rv-emote--banana { font-size: 1.3rem; }
    @keyframes rvFloat { from { transform: translate(-50%, 0); opacity: 1; } to { transform: translate(-50%, -70px); opacity: 0; } }

    /* THE DROP flashes above the DJ — it's the stage's moment */
    .rv-dropflash {
      position: absolute; left: 0; right: 0; top: 4px; display: grid; place-items: center;
      pointer-events: none; z-index: 600;
    }
    .rv-dropflash[hidden] { display: none; } /* our display:grid beats the UA [hidden] rule — the text was stuck ON permanently */
    .rv-dropflash span {
      font-family: "Archivo Black", sans-serif; font-size: clamp(1.3rem, 4.5vw, 2.4rem);
      color: #ffe135; -webkit-text-stroke: 2px #111; animation: rvDropPulse 0.5s steps(2) infinite;
    }
    @keyframes rvDropPulse { 50% { transform: scale(1.06) rotate(-2deg); color: #ff4d6d; } }

    .rv-hud {
      display: flex; align-items: center; justify-content: space-between; gap: 0.8rem;
      background: #17121f; border-top: 4px solid #ffe135; padding: 0.7rem 0.9rem; flex-wrap: wrap;
      touch-action: manipulation; /* no iOS double-tap zoom when mashing emotes */
    }
    .rv-emotes { display: flex; gap: 0.5rem; }
    .rv-emote-btn {
      background: #0d0b14; color: #fffdf5; border: 3px solid #ffe135; cursor: pointer;
      font-size: 1.2rem; line-height: 1; padding: 0.55rem 0.9rem; border-radius: 2px;
      min-width: 48px; min-height: 48px;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent; user-select: none;
    }
    .rv-emote-btn:hover { background: #ffe135; }
    .rv-emote-btn--fire { border-color: #ff9e2c; }
    .rv-emote-btn--fire:hover { background: #ff9e2c; }
    .rv-stage-btn {
      background: #ffe135; color: #111; border: 3px solid #111; cursor: pointer;
      font-weight: 800; font-size: 0.78rem; letter-spacing: 0.04em; padding: 0.55rem 0.8rem;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent; user-select: none;
    }
    .rv-stage-btn[disabled] { background: #0d0b14; color: #b388ff; border-color: #b388ff; cursor: default; }
    .rv-more { font-size: 0.8rem; opacity: 0.7; }
    .rv-emote--fire { color: #ff9e2c; font-size: 1.7rem; }
    .rv-emote svg { width: 24px; height: auto; image-rendering: pixelated; }

    @media (max-width: 640px) {
      .rv-booth { min-height: 138px; }
