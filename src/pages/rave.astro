---
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelIcon from '../components/PixelIcon.astro';

const title = 'The Banana Rave — everyone dances together';
const description = 'A live dance floor where every visitor’s custom banana dances in perfect sync. Join the rave, drop an emote, outlast the others.';

// pyro fountains: two-frame tall pixel flames (Pillow-authored, scratchpad
// pyro.py) — both frames stacked per fountain, CSS flips between them
const PYRO_FRAMES = '<svg class="rv-pyro__a" viewBox="0 0 9 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="0" width="1" height="1" fill="#ffe135"/><rect x="3" y="1" width="2" height="1" fill="#ffe135"/><rect x="3" y="2" width="1" height="1" fill="#ffe135"/><rect x="4" y="2" width="1" height="1" fill="#ff9128"/><rect x="2" y="3" width="1" height="1" fill="#ffe135"/><rect x="3" y="3" width="2" height="1" fill="#ff9128"/><rect x="6" y="3" width="1" height="1" fill="#ffe135"/><rect x="2" y="4" width="1" height="1" fill="#ffe135"/><rect x="3" y="4" width="2" height="1" fill="#ff9128"/><rect x="5" y="4" width="1" height="1" fill="#ffe135"/><rect x="7" y="4" width="1" height="1" fill="#ffe135"/><rect x="1" y="5" width="1" height="1" fill="#ffe135"/><rect x="2" y="5" width="4" height="1" fill="#ff9128"/><rect x="6" y="5" width="2" height="1" fill="#ffe135"/><rect x="1" y="6" width="1" height="1" fill="#ffe135"/><rect x="2" y="6" width="1" height="1" fill="#ff9128"/><rect x="3" y="6" width="1" height="1" fill="#fffdf5"/><rect x="4" y="6" width="3" height="1" fill="#ff9128"/><rect x="7" y="6" width="1" height="1" fill="#ffe135"/><rect x="1" y="7" width="1" height="1" fill="#ffe135"/><rect x="2" y="7" width="1" height="1" fill="#ff9128"/><rect x="3" y="7" width="2" height="1" fill="#fffdf5"/><rect x="5" y="7" width="2" height="1" fill="#ff9128"/><rect x="7" y="7" width="1" height="1" fill="#ffe135"/><rect x="0" y="8" width="1" height="1" fill="#ffe135"/><rect x="1" y="8" width="1" height="1" fill="#ff9128"/><rect x="2" y="8" width="3" height="1" fill="#fffdf5"/><rect x="5" y="8" width="3" height="1" fill="#ff9128"/><rect x="8" y="8" width="1" height="1" fill="#ffe135"/><rect x="0" y="9" width="1" height="1" fill="#ffe135"/><rect x="1" y="9" width="1" height="1" fill="#ff9128"/><rect x="2" y="9" width="4" height="1" fill="#fffdf5"/><rect x="6" y="9" width="2" height="1" fill="#ff9128"/><rect x="8" y="9" width="1" height="1" fill="#ffe135"/><rect x="0" y="10" width="1" height="1" fill="#ffe135"/><rect x="1" y="10" width="1" height="1" fill="#ff9128"/><rect x="2" y="10" width="4" height="1" fill="#fffdf5"/><rect x="6" y="10" width="2" height="1" fill="#ff9128"/><rect x="8" y="10" width="1" height="1" fill="#ffe135"/><rect x="1" y="11" width="1" height="1" fill="#ff9128"/><rect x="2" y="11" width="4" height="1" fill="#fffdf5"/><rect x="6" y="11" width="2" height="1" fill="#ff9128"/><rect x="1" y="12" width="1" height="1" fill="#ff9128"/><rect x="2" y="12" width="4" height="1" fill="#fffdf5"/><rect x="6" y="12" width="1" height="1" fill="#ff9128"/><rect x="1" y="13" width="1" height="1" fill="#e83b3b"/><rect x="2" y="13" width="4" height="1" fill="#fffdf5"/><rect x="6" y="13" width="1" height="1" fill="#e83b3b"/><rect x="1" y="14" width="2" height="1" fill="#e83b3b"/><rect x="3" y="14" width="2" height="1" fill="#fffdf5"/><rect x="5" y="14" width="2" height="1" fill="#e83b3b"/><rect x="2" y="15" width="4" height="1" fill="#e83b3b"/></svg><svg class="rv-pyro__b" viewBox="0 0 9 16" shape-rendering="crispEdges" xmlns="http://www.w3.org/2000/svg"><rect x="4" y="0" width="1" height="1" fill="#ffe135"/><rect x="4" y="1" width="2" height="1" fill="#ffe135"/><rect x="4" y="2" width="1" height="1" fill="#ff9128"/><rect x="5" y="2" width="1" height="1" fill="#ffe135"/><rect x="2" y="3" width="1" height="1" fill="#ffe135"/><rect x="4" y="3" width="2" height="1" fill="#ff9128"/><rect x="6" y="3" width="1" height="1" fill="#ffe135"/><rect x="1" y="4" width="1" height="1" fill="#ffe135"/><rect x="3" y="4" width="1" height="1" fill="#ffe135"/><rect x="4" y="4" width="2" height="1" fill="#ff9128"/><rect x="6" y="4" width="1" height="1" fill="#ffe135"/><rect x="1" y="5" width="2" height="1" fill="#ffe135"/><rect x="3" y="5" width="4" height="1" fill="#ff9128"/><rect x="7" y="5" width="1" height="1" fill="#ffe135"/><rect x="1" y="6" width="1" height="1" fill="#ffe135"/><rect x="2" y="6" width="3" height="1" fill="#ff9128"/><rect x="5" y="6" width="1" height="1" fill="#fffdf5"/><rect x="6" y="6" width="1" height="1" fill="#ff9128"/><rect x="7" y="6" width="1" height="1" fill="#ffe135"/><rect x="1" y="7" width="1" height="1" fill="#ffe135"/><rect x="2" y="7" width="2" height="1" fill="#ff9128"/><rect x="4" y="7" width="2" height="1" fill="#fffdf5"/><rect x="6" y="7" width="1" height="1" fill="#ff9128"/><rect x="7" y="7" width="1" height="1" fill="#ffe135"/><rect x="0" y="8" width="1" height="1" fill="#ffe135"/><rect x="1" y="8" width="3" height="1" fill="#ff9128"/><rect x="4" y="8" width="3" height="1" fill="#fffdf5"/><rect x="7" y="8" width="1" height="1" fill="#ff9128"/><rect x="8" y="8" width="1" height="1" fill="#ffe135"/><rect x="0" y="9" width="1" height="1" fill="#ffe135"/><rect x="1" y="9" width="2" height="1" fill="#ff9128"/><rect x="3" y="9" width="4" height="1" fill="#fffdf5"/><rect x="7" y="9" width="1" height="1" fill="#ff9128"/><rect x="8" y="9" width="1" height="1" fill="#ffe135"/><rect x="0" y="10" width="1" height="1" fill="#ffe135"/><rect x="1" y="10" width="2" height="1" fill="#ff9128"/><rect x="3" y="10" width="4" height="1" fill="#fffdf5"/><rect x="7" y="10" width="1" height="1" fill="#ff9128"/><rect x="8" y="10" width="1" height="1" fill="#ffe135"/><rect x="1" y="11" width="2" height="1" fill="#ff9128"/><rect x="3" y="11" width="4" height="1" fill="#fffdf5"/><rect x="7" y="11" width="1" height="1" fill="#ff9128"/><rect x="2" y="12" width="1" height="1" fill="#ff9128"/><rect x="3" y="12" width="4" height="1" fill="#fffdf5"/><rect x="7" y="12" width="1" height="1" fill="#ff9128"/><rect x="2" y="13" width="1" height="1" fill="#e83b3b"/><rect x="3" y="13" width="4" height="1" fill="#fffdf5"/><rect x="7" y="13" width="1" height="1" fill="#e83b3b"/><rect x="2" y="14" width="2" height="1" fill="#e83b3b"/><rect x="4" y="14" width="2" height="1" fill="#fffdf5"/><rect x="6" y="14" width="2" height="1" fill="#e83b3b"/><rect x="3" y="15" width="4" height="1" fill="#e83b3b"/></svg>';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'The Banana Rave',
  url: 'https://trymstene.com/rave/',
  applicationCategory: 'EntertainmentApplication',
  operatingSystem: 'Web',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  creator: { '@id': 'https://trymstene.com/#trym' },
  description: 'A realtime dance floor for custom dancing bananas, from the creator of the original 1999 GIF.',
};

const raveFaq = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Is the banana rave really live?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Every banana on the floor is a real visitor, right now. The only characters who are not visitors are staff — Barty the bartender and the DJ — and they have jobs.' } },
    { '@type': 'Question', name: 'Why does everyone dance in perfect sync?', acceptedAnswer: { '@type': 'Answer', text: 'There is only one song and it never stops. Every banana on Earth dances on the same wall-clock beat — join from two devices and watch them match.' } },
    { '@type': 'Question', name: 'Do I need an account to join the rave?', acceptedAnswer: { '@type': 'Answer', text: 'No account, no cost. Your banana walks in as you dressed it in the builder — or a fresh one is generated for you.' } },
    { '@type': 'Question', name: 'What is a nightshift at the banana rave?', acceptedAnswer: { '@type': 'Answer', text: 'Barty always needs a hand with some little chore between the songs — sweeping peels, fetching the lost vinyl, calming the monkey. Finish his requests and he stamps your nightshift; five shifts make you a regular.' } },
    { '@type': 'Question', name: 'What can I earn at the banana rave?', acceptedAnswer: { '@type': 'Answer', text: 'Badges on your banana pass, permanent gear like the glowstick (30 minutes on the floor) and the golden banana trophy, the fire emote from the stage, and — after five nightshifts — your own stool at the bar.' } },
  ],
};

// the floor guide — thumbnails are the ACTUAL in-game sprites, rasterised by
// tools/build-rave-guide.py straight from the source (rerun it if art changes)
const G = '/assets/rave-guide/';
const GUIDE = [
  { img: 'barty', name: 'Barty, the bartender', text: 'Runs the bar, never sleeps. Calls HAPPY HOUR every 5th minute (first banana to the counter wins the beer), mixes specials in between — and always needs a hand with some little chore. Help him and he stamps your nightshift.' },
  { img: 'jelly', name: 'Jelly drops', text: 'It rains jelly on this floor — watch it fall from the rig, land with a wobble, and wait. Hoover it up to fill the JELLY meter; when she’s full, you know what time it is: your own personal drop, spent whenever you like.' },
  { img: 'vinyl', name: 'The lost vinyl', text: 'The DJ keeps losing records. Every 7 minutes one lands somewhere on the floor — carry it back to the booth and the whole club gets a bonus drop, courtesy of you.' },
  { img: 'goldbanana', name: 'The golden banana', text: 'Every half hour, once, somewhere: the golden one. The finder gets the trophy in their hand and “The Golden One” badge on their pass — and for the whole floor, it rains golden bananas.' },
  { img: 'beer', name: 'Happy hour & the specials', text: 'Every 5th minute Barty yells and pours ONE beer — first banana to the counter carries it for all to see. Between happy hours: rotating specials. The daiquiri gives you disco legs, the milkshake goes straight to the hips, and the water… the water takes EVERYTHING off. Barty insists.' },
  { img: 'cable', name: 'The loose cable', text: 'The rig’s wiring is older than Barty (nothing is older than Barty). Grab the live end to tidy the hazard — you’ll shock-blink like a cartoon, and brushing past friends zaps them too.' },
  { img: 'sauce', name: 'Hot sauce', text: 'A bottle of the house burner lands on the floor every few minutes. Drink it and your footsteps catch fire for a while. Completely safe. Probably.' },
  { img: 'pizza', name: 'Club snacks', text: 'The conveyor drops something chaseable every ~75 seconds. Grab a slice and your banana holds it high; the whole box rides the other glove (and pays a meal of jelly). Candy? A sugar rush — you’ll shake it off. Literally.' },
  { img: 'balloon', name: 'The balloon', text: 'Catch it and up you go: sealed inside, frozen mid-pose, drifting over the floor faster than anyone can dance. It deflates after a minute. Gravity is a rule, not a law.' },
  { img: 'broom', name: 'The broom & the mess', text: 'Peels and puddles pile up on a nightshift. Grab the broom from the counter and sweep — every swept peel is jelly too. The floor remembers who cleans it.' },
  { img: 'monkey', name: 'The monkey', text: 'The staff pet. Shows up on certain nights, steals things (famously: the bottle), keeps its distance when chased. Theatrical, never malicious. Mostly.' },
  { img: 'glowstick', name: 'The glowstick', text: 'Survive 30 minutes on the floor and the neon glowstick is yours forever — it pumps with the beat in your banana’s glove, here and in the builder.' },
  { img: 'stool', name: 'Your stool', text: 'Finish all five of Barty’s nightshifts and become a regular: your own stool at the counter’s end, forever. Click it, sit down, watch the floor. Nobody else gets one.' },
  { img: 'star', name: 'The gold star', text: 'Grab it and THE ENTOURAGE arrives: two copies of you replaying your every step, half a beat behind. A conga line of yourself. Stop moving and they walk right into you.' },
  { img: 'boots', name: 'Moon boots', text: 'One small step for banana. Big lunar hops with a proper squash on every landing — fifteen seconds of low gravity on a crowded dance floor.' },
  { img: 'gel', name: 'The jello cube', text: 'Eat the wobble, become the wobble: your whole banana goes jelly-legged, wobbling from the feet up. On this floor, that’s practically a religious experience.' },
  { img: 'sparkler', name: 'The sparkler', text: 'Write your name on the night. A white-hot ribbon of light follows wherever you walk, spitting golden sparks as it burns out behind you.' },
  { img: 'magnet', name: 'The jelly magnet', text: 'For twelve seconds the floor’s jelly wants YOU — every loose drop slides across the boards straight into your banana, and fresh jelly keeps raining. Pure harvest.' },
  { img: 'vhs', name: 'The VHS tape', text: 'Tracking error. Your banana glitches like a tape that’s been rewound one time too many — slices shear sideways, a white band rolls through, then it recovers. Then it doesn’t.' },
  { img: 'mystery', name: '…and the rest', text: 'Many other items and drinks turn up when they feel like it — mirror shards, lost phones, ice cubes, things Barty won’t put on the menu. Hang around and see. They don’t wait long: five seconds, then poof.' },
];
---
<BaseLayout
  title={title}
  description={description}
  ogTitle="The Banana Rave 🪩"
  ogDescription="Every visitor's banana, dancing together in perfect sync. Right now. Join the floor."
  ogImage="https://trymstene.com/assets/og/builder.png"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(raveFaq)} />
  <!-- perf: the dance sheet is otherwise only discovered after the JS bundle
       parses (a full network waterfall); ?v must match SHEET_SRC in banana-engine.js -->
  <link rel="preload" as="image" href="/assets/banana-dance.png?v=6" slot="head" />
  <!-- perf: warm DNS+TCP+TLS to the presence worker before the WS handshake -->
  <link rel="preconnect" href="https://banana-rave.trymstene.workers.dev" slot="head" />
  <style is:inline slot="head">
    /* the whole page lives in the dark — the guide sections below the floor
       continue the hall, and no paper background can ever peek out the bottom */
    body { background: #0d0b14; }
    /* ---- the guide below the floor ---- */
    .rvg { max-width: 880px; margin: 0 auto; padding: 1rem 0 3rem; color: #fffdf5; }
    .rvg__block { margin-top: 3.2rem; }
    .rvg__kicker { color: #ff4d9d; font-weight: 800; font-size: 0.75rem; letter-spacing: 0.14em; text-transform: uppercase; margin: 0 0 0.4rem; }
    .rvg__block h2 { font-family: "Archivo Black", sans-serif; color: #ffe135; font-size: clamp(1.4rem, 4vw, 2rem); margin: 0 0 0.9rem; }
    .rvg__block p, .rvg__list li { line-height: 1.65; font-size: 0.98rem; }
    .rvg__block a { color: #ffe135; }
    .rvg__sub { opacity: 0.75; font-size: 0.9rem !important; }
    .rvg__list { padding-left: 1.1rem; display: grid; gap: 0.55rem; }
    .rvg__list--clock { list-style: none; padding-left: 0; }
    .rvg__list--clock li { border-left: 4px solid #ffe135; padding-left: 0.8rem; }
    .rvg__grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); margin-top: 1.4rem; }
    .rvg__card { background: #17121f; border: 3px solid #ffe135; box-shadow: 6px 6px 0 #000; padding: 1rem; }
    .rvg__thumb { height: 84px; display: flex; align-items: center; justify-content: center; margin-bottom: 0.6rem; }
    .rvg__thumb img { image-rendering: pixelated; max-height: 84px; max-width: 120px; width: auto; height: auto; }
    .rvg__card h3 { font-family: "Archivo Black", sans-serif; font-size: 0.95rem; color: #ffe135; margin: 0 0 0.4rem; text-align: center; }
    .rvg__card p { margin: 0; font-size: 0.86rem; line-height: 1.55; opacity: 0.92; }
    .rvg__faq h3 { font-family: "Archivo Black", sans-serif; font-size: 1rem; color: #ffe135; margin: 1.3rem 0 0.3rem; }
    .rvg__faq p { margin: 0; }
    .rvg__doors { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.2rem; }
    .rvg__doors a { border: 3px solid #ffe135; padding: 0.6rem 0.9rem; font-weight: 800; font-size: 0.9rem; text-decoration: none; color: #ffe135; background: #17121f; box-shadow: 4px 4px 0 #000; }
    .rvg__doors a:hover { background: #ffe135; color: #111; }
    @media (max-width: 940px) { .rvg { padding-inline: 1.2rem; } }
    /* isolate = nothing inside the rave (raver z-indexes, drop flash) can ever
       paint over the sticky nav / slide menu (iOS Safari bug Trym caught) */
    .rv-hall { background: #0d0b14; color: #fffdf5; padding: 1.6rem 1rem 2.5rem; position: relative; isolation: isolate; z-index: 0; }
    .rv-head { max-width: 1100px; margin: 0 auto 1rem; display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.6rem 1.4rem; }
    .rv-head h1 { margin: 0; font-size: clamp(1.6rem, 5vw, 2.6rem); color: #ffe135; }
    .rv-live { color: #37d67a; font-weight: 700; }
    .rv-status { font-size: 0.85rem; opacity: 0.85; }
    .rv-sub { max-width: 1100px; margin: 0 auto 1.2rem; font-size: 0.92rem; opacity: 0.75; }

    .rv-stagewrap { max-width: 1100px; margin: 0 auto; display: grid; gap: 1rem; grid-template-columns: 1fr; }
    @media (min-width: 980px) { .rv-stagewrap { grid-template-columns: 1fr 240px; align-items: start; } }

    /* the floor: pixel checkerboard that pulses */
    .rv-club { position: relative; border: 4px solid #ffe135; box-shadow: 8px 8px 0 #000; overflow: hidden; }
    /* the stage: Sentry-style DJ desk front-centre, speakers flanking,
       earned companions dancing on a line behind the DJ */
    .rv-booth { position: relative; background: #17121f; border-bottom: 4px solid #0d0b14; min-height: 164px; }
    .rv-stage {
      position: absolute; left: 0; right: 0; bottom: 42px;
      display: flex; justify-content: center; align-items: flex-end; gap: 10px; z-index: 1;
    }
    .rv-stage .rv-raver { position: relative; transform: none; left: auto; top: auto; }
    .rv-stage__gap { flex: none; width: 104px; } /* the DJ stands here — keep the middle clear */
    .rv-stage .rv-raver canvas { width: 58px !important; height: 58px !important; }
    /* stage members glow under the rig — being up there has to LOOK special */
    .rv-stage .rv-raver canvas { filter: drop-shadow(0 0 7px #ffe135) !important; }
    .rv-djgroup { position: absolute; left: 50%; bottom: 0; transform: translateX(-50%); width: 150px; z-index: 2; }
    .rv-djgroup canvas { width: 96px; height: 96px; display: block; margin: 0 auto -36px; position: relative; z-index: 1; }
    .rv-desk {
      position: relative; z-index: 2; height: 40px;
      background: #241a38; border: 3px solid #0d0b14; box-shadow: inset 0 4px 0 #2f2250;
    }
    .rv-desk::before, .rv-desk::after { content: ''; position: absolute; top: 7px; width: 6px; height: 6px; background: #b388ff; box-shadow: 0 10px 0 #37d67a; }
    .rv-desk::before { left: 8px; }
    .rv-desk::after { right: 8px; }
    .rv-desk__label {
      position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
      background: #ffe135; color: #111; font-weight: 800; font-size: 0.58rem;
      letter-spacing: 0.08em; padding: 0.18rem 0.45rem; text-transform: uppercase; white-space: nowrap;
    }
    .rv-speaker { position: absolute; bottom: 0; width: 50px; height: 68px; z-index: 2; shape-rendering: crispEdges; }
    .rv-speaker--l { left: calc(50% - 134px); }
    .rv-speaker--r { right: calc(50% - 134px); }
    body.rv-drop .rv-speaker { animation: rvPump 0.24s steps(2) infinite; transform-origin: bottom center; }
    @keyframes rvPump { 50% { transform: scaleY(1.07) scaleX(1.05); } }
    @media (prefers-reduced-motion: reduce) {
      body.rv-drop .rv-speaker, .rv-mnote, .rv-beam, .rv-dropflash span { animation: none; }
      .rv-pyro { display: none !important; }
      .rv-mnote { opacity: 0.5; }
    }

    /* stage production: notes drift from the speakers; beams sweep always;
       pyro fountains fire during THE DROP (which now flashes ABOVE the DJ) */
    .rv-mnote { /* NOT .rv-note — that's the panel's text note */
      position: absolute; bottom: 44px; font-size: 0.95rem; color: #b388ff; opacity: 0;
      z-index: 3; pointer-events: none; animation: rvNote 2.6s linear infinite;
    }
    .rv-mnote--1 { left: calc(50% - 152px); }
    .rv-mnote--2 { left: calc(50% - 118px); color: #4db8ff; animation-delay: 1.2s; }
    .rv-mnote--3 { right: calc(50% - 152px); animation-delay: 0.6s; }
    .rv-mnote--4 { right: calc(50% - 118px); color: #4db8ff; animation-delay: 1.8s; }
    @keyframes rvNote {
      0% { transform: translateY(0); opacity: 0; }
      15% { opacity: 1; }
      100% { transform: translateY(-48px); opacity: 0; }
    }
    .rv-beam {
      position: absolute; top: 0; width: 44px; height: 100%; z-index: 0; pointer-events: none;
      background: linear-gradient(rgba(255, 225, 53, 0.14), transparent 80%);
      clip-path: polygon(38% 0, 62% 0, 100% 100%, 0 100%);
      transform-origin: 50% 0; animation: rvBeam 3.4s steps(7) infinite alternate;
    }
    .rv-beam--l { left: 16%; }
    .rv-beam--r { right: 16%; animation-delay: 1.7s; }
    body.rv-drop .rv-beam { animation-duration: 0.5s; background: linear-gradient(rgba(255, 77, 109, 0.3), transparent 80%); }
    @keyframes rvBeam { from { transform: rotate(-26deg); } to { transform: rotate(26deg); } }
    /* pyro fountains: two-frame pixel flames (the old 6px gradient columns
       read as glitches, not fire — Trym). Frames flip = flicker; the whole
       flame bursts up from the floor on the drop. */
    .rv-pyro {
      position: absolute; bottom: 0; width: 34px; height: 60px; z-index: 1; pointer-events: none;
      display: none; transform-origin: bottom;
      filter: drop-shadow(0 0 8px rgba(255, 145, 40, 0.55));
    }
    .rv-pyro svg { position: absolute; inset: 0; width: 100%; height: 100%; image-rendering: pixelated; }
    .rv-pyro__a { animation: rvTwinkleFlip 0.26s steps(1) infinite; }
    .rv-pyro__b { animation: rvTwinkleFlip 0.26s steps(1) infinite; animation-delay: -0.13s; }
    body.rv-drop .rv-pyro { display: block; animation: rvPyro 0.5s steps(4) infinite; }
    .rv-pyro--1 { left: 7%; }
    /* the inner pair anchors just OUTSIDE the speakers (which are centre-
       anchored) — %-positions put them BEHIND the speakers on narrow booths */
    .rv-pyro--2 { left: calc(50% - 172px); animation-delay: 0.15s; }
    .rv-pyro--3 { right: calc(50% - 172px); animation-delay: 0.3s; }
    .rv-pyro--4 { right: 7%; animation-delay: 0.1s; }
    @media (max-width: 640px) {
      /* a 375px booth holds TWO flames comfortably — four is a crowd */
      .rv-pyro--2, .rv-pyro--3 { display: none !important; }
    }
    @keyframes rvPyro {
      0% { transform: scaleY(0.35); }
      60% { transform: scaleY(1); }
      100% { transform: scaleY(0.8); }
    }
    /* THE EQ WALL: pixel equalizer bars along the back wall — the dead space
       behind the DJ becomes club dressing that dances (honest furniture, never
       fake guests). Hard-stop gradient bands = pixel look; red + frantic on
       the drop. */
    .rv-eq {
      position: absolute; left: 50%; transform: translateX(-50%); bottom: 46px;
      width: min(420px, 76%); height: 44px; z-index: 0; pointer-events: none;
      display: flex; align-items: flex-end; justify-content: center; gap: 6px; opacity: 0.9;
    }
    .rv-eq span {
      flex: 1; max-width: 10px; height: 100%; transform-origin: bottom;
      background: linear-gradient(to top, #2f2250 0 45%, #b388ff 45% 78%, #78ebff 78% 100%);
      animation: rvEq 0.8s steps(4) infinite;
    }
    .rv-eq span:nth-child(2n) { animation-duration: 0.62s; background: linear-gradient(to top, #2f2250 0 50%, #4db8ff 50% 82%, #f0f0fa 82% 100%); }
    .rv-eq span:nth-child(3n) { animation-delay: -0.25s; }
    .rv-eq span:nth-child(4n) { animation-duration: 0.94s; animation-delay: -0.5s; }
    .rv-eq span:nth-child(5n) { animation-delay: -0.65s; }
    @keyframes rvEq {
      0%, 100% { transform: scaleY(0.22); }
      30% { transform: scaleY(0.8); }
      55% { transform: scaleY(0.45); }
      80% { transform: scaleY(1); }
    }
    body.rv-drop .rv-eq span { animation-duration: 0.3s; background: linear-gradient(to top, #451d66 0 45%, #ff4d6d 45% 78%, #ffe135 78% 100%); }
    @media (prefers-reduced-motion: reduce) { .rv-eq span { animation: none; transform: scaleY(0.45); } .rv-pyro svg { animation: none; } .rv-pyro__b { opacity: 0; } }

    .rv-floor { position: relative; height: min(62vh, 560px); overflow: hidden; background: #161022; }
    /* the world layer: ravers + checkerboard live here so the camera (translate+scale)
       moves the floor WITH the crowd; screen-space chrome (drop flash, zoom btn) stays outside */
    .rv-world {
      position: absolute; inset: 0; transform-origin: 0 0;
      background:
        repeating-conic-gradient(#161022 0% 25%, #1d1530 0% 50%) 0 0 / 96px 96px;
      image-rendering: pixelated;
      will-change: transform; /* the follow-cam pans this layer every frame — keep it on the compositor */
    }
    body.rv-drop .rv-world {
      background:
        repeating-conic-gradient(#2a1650 0% 25%, #451d66 0% 50%) 0 0 / 96px 96px;
      animation: rvStrobe 0.24s steps(2) infinite;
    }
    @keyframes rvStrobe { 50% { filter: hue-rotate(140deg) brightness(1.25); } }
    @media (prefers-reduced-motion: reduce) { body.rv-drop .rv-world { animation: none; } }
    /* the bar, tucked into the BOTTOM-LEFT corner of the world — down = nearer, so
       you "come up to the bar" by dancing toward the viewer. Only the top of the
       countertop peeks in (the rest bleeds off the corner). Barty — full
       bottom-of-floor dancer size — stands on the NEAR side of the counter,
       mirrored to face the stage; the floor edge crops his lower half. */
    /* z 300 > any raver (they cap at 100 + y = ~192): a banana overlapping the bar
       is standing further away on the floor, so the counter must cover it */
    .rv-bar { position: absolute; left: -18px; bottom: -52px; width: 205px; z-index: 300; pointer-events: none; }
    .rv-counter { display: block; width: 100%; height: auto; position: relative; z-index: 2; }
    /* Barty is ABSOLUTE — fully independent of the counter. He was in flow before,
       so raising him shrank the bottom-anchored block and the DESK sank instead
       (Trym caught it in devtools: the desk followed him). top adjusts ONLY him. */
    #rvBarman {
      position: absolute; top: -91px; left: 14px; width: 150px; height: 150px;
      z-index: 3; image-rendering: pixelated;
    }
    /* beer at HALF size — 32px read as "a bucket of beer" next to Barty (Trym);
       top keeps its bottom seated on the countertop band (nudged 2px up) */
    .rv-counterbeer { position: absolute; width: 18px; height: auto; left: 62%; top: -10px; z-index: 4; }
    .rv-counterbeer--quest { left: 44%; filter: drop-shadow(0 0 5px rgba(255, 225, 53, 0.6)); } /* the house pour glows a little — it's YOURS */
    /* Barty's special of the window: the cocktail sits where the beer sits —
       38% landed ON Barty and overflowed him (Trym, iOS). Beer + special never
       show at the same time (happy hour vs specials window), so they share the
       spot. NO bob — drinks on a counter SIT (only floor items dance). */
    .rv-special { position: absolute; width: 26px; left: 62%; top: -28px; z-index: 4; line-height: 0; filter: drop-shadow(0 0 6px rgba(120, 235, 255, 0.5)); }
    .rv-special[hidden] { display: none; }
    .rv-special svg { width: 100%; height: auto; image-rendering: pixelated; }
    .rv-bubble {
      position: absolute; bottom: calc(100% + 54px); left: 46%; transform: translateX(-50%);
      min-width: 150px; max-width: 210px; z-index: 5; text-align: center;
      background: #fffdf5; color: #111; border: 3px solid #111; box-shadow: 3px 3px 0 #000;
      font-size: 0.58rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase;
      line-height: 1.5; padding: 0.4rem 0.5rem;
    }
    /* stepped pixel tail pointing down at Barty (two shrinking steps, no rotation) */
    .rv-bubble::before {
      content: ''; position: absolute; top: 100%; left: 30px; width: 14px; height: 6px;
      background: #fffdf5; border-left: 3px solid #111; border-right: 3px solid #111;
    }
    .rv-bubble::after {
      content: ''; position: absolute; top: calc(100% + 6px); left: 34px; width: 6px; height: 6px;
      background: #fffdf5; border-left: 3px solid #111; border-right: 3px solid #111; border-bottom: 3px solid #111;
    }
    /* quest bubbles go YELLOW — Barty means business; white stays chatter */
    .rv-bubble--quest, .rv-bubble--quest::before, .rv-bubble--quest::after { background: #ffe135; }
    /* the under-the-breath bubble: smaller, dimmer — the dark drip lands a
       beat after the cheer, stand-up timing */
    .rv-bubble--mutter { font-size: 0.5rem; color: #55524a; background: #eae7db; min-width: 110px; }
    .rv-bubble--mutter::before, .rv-bubble--mutter::after { background: #eae7db; }
    /* phones: Barty pipes down a notch — the bubbles ate too much floor */
    @media (max-width: 640px) {
      .rv-bubble { font-size: 0.52rem; max-width: 180px; }
      .rv-bubble--mutter { font-size: 0.46rem; }
    }

    /* floor life: light trails, the wandering spotlight, the lost vinyl */
    .rv-trails { position: absolute; inset: 0; width: 100%; height: 100%; z-index: 5; pointer-events: none; image-rendering: pixelated; }
    .rv-spot {
      position: absolute; width: 200px; height: 160px; transform: translate(-50%, -50%);
      z-index: 8; pointer-events: none;
      background: radial-gradient(closest-side, rgba(255, 225, 53, 0.3), rgba(255, 225, 53, 0.12) 55%, transparent 72%);
    }
    .rv-spot[hidden] { display: none; }
    .rv-lit canvas { filter: drop-shadow(0 0 10px #ffe135) drop-shadow(0 0 3px #fffdf5); }
    .rv-raver--me.rv-lit canvas { filter: drop-shadow(0 0 6px #ffe135) drop-shadow(0 0 12px #fffdf5); }
    /* floor items (vinyl, hot sauce): a soft glow + beat-bob so they beg to be grabbed */
    .rv-item {
      position: absolute; width: 36px; height: 36px; transform: translate(-50%, -50%);
      z-index: 9; image-rendering: pixelated; pointer-events: none;
      filter: drop-shadow(0 0 7px rgba(255, 225, 53, 0.45));
      animation: rvItemBob 0.8s steps(2) infinite;
    }
    .rv-item--tall { width: 26px; height: 39px; }
    .rv-item--gold { width: 28px; height: 49px; filter: drop-shadow(0 0 10px rgba(255, 225, 53, 0.85)) drop-shadow(0 0 3px #fffdf5); } /* 8:14 — the v3 upright banana with its pointy stem */
    .rv-item svg { width: 100%; height: 100%; }
    /* conveyor item sizes by kind (sprites have different aspect ratios) */
    .rv-item[data-kind="sauce"], .rv-item[data-kind="fizz"], .rv-item[data-kind="balloon"] { width: 26px; height: 39px; }
    .rv-item[data-kind="zap"] { width: 28px; height: 39px; } /* the loose cable is 10:14 */
    .rv-item[data-kind="candy"] { width: 38px; height: 26px; }
    .rv-item[data-kind="pizza"] { width: 32px; height: 32px; }
    .rv-item[data-kind="zap"] { filter: drop-shadow(0 0 8px rgba(120, 235, 255, 0.7)); }
    /* the twinkle: the next item announces its spot 4s early — race it.
       CYAN, not yellow: in pellet-gold it read as an uncollectable pellet */
    /* the SPAWN TWINKLE: a real two-frame pixel star (✚ ↔ ✕ = the spin) with
       a cyan glow and a grow-pulse — "something's landing HERE". CYAN so it
       never impersonates a gold pellet. */
    .rv-twinkle {
      position: absolute; width: 22px; height: 22px; margin: -11px 0 0 -11px;
      z-index: 8; pointer-events: none;
      filter: drop-shadow(0 0 7px rgba(120, 235, 255, 0.85));
      animation: rvTwinklePulse 0.9s steps(3) infinite;
    }
    .rv-twinkle[hidden] { display: none; }
    .rv-twinkle svg { position: absolute; inset: 0; width: 100%; height: 100%; image-rendering: pixelated; }
    .rv-twinkle__a { animation: rvTwinkleFlip 0.36s steps(1) infinite; }
    .rv-twinkle__b { animation: rvTwinkleFlip 0.36s steps(1) infinite; animation-delay: -0.18s; }
    @keyframes rvTwinkleFlip { 0%, 49% { opacity: 1; } 50%, 100% { opacity: 0; } }
    @keyframes rvTwinklePulse { 50% { transform: scale(1.28); } }
    /* THE NIGHT's chores: litter + puddles lie FLAT (no bob — they're mess,
       not prizes); swept things spin away under the broom */
    .rv-chore { position: absolute; transform: translate(-50%, -50%); z-index: 6; pointer-events: none; }
    .rv-chore svg { display: block; image-rendering: pixelated; }
    .rv-chore--peel svg { width: 54px; height: auto; }
    .rv-chore--puddle svg { width: 44px; height: 20px; opacity: 0.9; }
    .rv-chore--swept { animation: rvSwept 0.5s steps(4) forwards; }
    @keyframes rvSwept { 100% { transform: translate(-50%, -50%) scale(0.15) rotate(120deg); opacity: 0; } }
    /* THE MONKEY: staff pet, theatrical guest — never a fake visitor */
    .rv-monkey { position: absolute; transform: translate(-50%, -50%); width: 54px; pointer-events: none; }
    .rv-monkey svg { width: 100%; height: auto; image-rendering: pixelated; }
    .rv-monkey--calm svg { filter: drop-shadow(0 0 6px #ffe135); }
    .rv-monkey--off { transition: opacity 0.8s ease, transform 0.8s ease; opacity: 0; }
    /* the regular's stool (N5's privilege) + the broom leaning on the counter */
    .rv-stool { position: absolute; transform: translate(-50%, -50%); width: 34px; pointer-events: auto; cursor: pointer; touch-action: manipulation; -webkit-tap-highlight-color: transparent; }
    .rv-stool svg { width: 100%; height: auto; image-rendering: pixelated; }
    .rv-broomprop { position: absolute; width: 15px; left: 84%; top: -48px; z-index: 4; line-height: 0; filter: drop-shadow(0 0 5px rgba(255, 214, 80, 0.5)); }
    .rv-broomprop svg { width: 100%; height: auto; image-rendering: pixelated; }
    /* THE WAVE hop (applied inline with per-banana delay) + chain glow + zap glow */
    @keyframes rvWaveHop { 30% { transform: translateY(-20px); } 60% { transform: translateY(-3px); } }
    /* TONIGHT's stats — the braggable, screenshottable numbers. The divider
       gives the section its own room; it was breathing down the board's neck */
    .rv-panel .rv-panel__h2 { margin-top: 1.5rem; padding-top: 1.1rem; border-top: 3px solid rgba(255, 225, 53, 0.3); } /* .rv-panel h2 outranks a lone class — this was WHY it sat squeezed */
    .rv-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 0.45rem 0.7rem; font-size: 0.78rem; }
    .rv-stats span { color: #b8b3c7; }
    .rv-stats b { color: #ffe135; font-size: 0.95rem; margin-right: 0.3rem; }
    /* the club clock — the headline of the night, a row of its own */
    .rv-stats .rv-stats__time { grid-column: 1 / -1; color: #ff4d9d; font-weight: 800; font-size: 0.85rem; margin-bottom: 0.15rem; }
    .rv-stats .rv-stats__time b { color: #ff4d9d; font-size: 1.05rem; }
    .rv-share-btn {
      margin-top: 0.7rem; width: 100%; background: #17121f; color: #ffe135;
      border: 3px solid #ffe135; font-weight: 800; font-size: 0.8rem; padding: 0.5rem 0;
      cursor: pointer; touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .rv-share-btn:hover { background: #ffe135; color: #111; }
    .rv-sharemodal {
      position: fixed; inset: 0; z-index: 2000; display: flex; align-items: center; justify-content: center;
      background: rgba(6, 4, 12, 0.82); padding: 1rem;
    }
    .rv-sharemodal[hidden] { display: none; }
    .rv-sharemodal__box {
      position: relative; max-width: min(88vw, 520px); width: 100%;
      background: #17121f; border: 4px solid #ffe135; box-shadow: 10px 10px 0 #000; padding: 0.9rem;
    }
    .rv-sharemodal__card canvas { display: block; width: 100%; height: auto; image-rendering: auto; border: 2px solid #000; }
    .rv-sharemodal__row { display: flex; gap: 0.5rem; margin-top: 0.7rem; flex-wrap: wrap; }
    .rv-sharemodal__row .rv-share-btn { flex: 1; margin-top: 0; min-width: 130px; }
    .rv-sharemodal__close {
      position: absolute; top: -18px; right: -18px; width: 40px; height: 40px;
      background: #ffe135; color: #111; border: 3px solid #111; font-weight: 800; font-size: 1rem; cursor: pointer;
      box-shadow: 3px 3px 0 #000; touch-action: manipulation;
    }
    /* the +1 that floats off a picked jelly */
    .rv-plus {
      position: absolute; transform: translate(-50%, -50%); z-index: 400; pointer-events: none;
      font-weight: 800; font-size: 0.95rem; color: #ffe135;
      text-shadow: 1px 1px 0 #000, -1px 1px 0 #000, 1px -1px 0 #000, -1px -1px 0 #000;
      animation: rvPlusUp 0.9s ease-out forwards;
    }
    @keyframes rvPlusUp {
      0% { opacity: 0; transform: translate(-50%, -50%) scale(0.6); }
      18% { opacity: 1; transform: translate(-50%, -80%) scale(1.15); }
      100% { opacity: 0; transform: translate(-50%, -190%) scale(1); }
    }
    .rv-raver.rv-chainglow canvas { filter: drop-shadow(0 0 8px #ffd23f) drop-shadow(0 0 16px #ff9128); }
    .rv-raver.rv-zapfx canvas { filter: drop-shadow(0 0 7px #78ebff); }
    /* THE BALLOON RIDE: sealed inside a big translucent balloon, frozen on the
       calm frame, floating — the keyframes carry the centring translate so the
       bob never fights the wrap's base transform */
    .rv-raver.rv-balloonfx { animation: rvBalloonFloat 2.4s ease-in-out infinite; }
    @keyframes rvBalloonFloat {
      0%, 100% { transform: translate(-50%, -50%); }
      50% { transform: translate(-50%, calc(-50% - 12px)); }
    }
    .rv-raver.rv-balloonfx::after {
      content: ''; position: absolute; inset: -4% 10% 4% 10%; border-radius: 50%;
      border: 3px solid rgba(255, 130, 180, 0.85);
      background: radial-gradient(circle at 32% 22%, rgba(255, 255, 255, 0.35) 0 9%, rgba(255, 140, 190, 0.14) 55%, rgba(255, 77, 157, 0.22));
      pointer-events: none;
    }
    .rv-raver.rv-balloonfx::before {
      /* the knot under the balloon */
      content: ''; position: absolute; left: 50%; bottom: -2%; width: 10px; height: 10px;
      background: rgba(255, 130, 180, 0.9); transform: translateX(-50%) rotate(45deg);
      pointer-events: none;
    }
    /* BUBBLEGUM FIZZ: the whole banana goes on a bubbly spin cycle — a full
       360 while it dances, inflating and deflating like gum mid-chew (Trym:
       the bubbles alone were underwhelming). Transform only, on the CANVAS
       so the wrap keeps its floor position. */
    .rv-raver.rv-fizzfx canvas { animation: rvFizzSpin 1.9s linear infinite; }
    @keyframes rvFizzSpin {
      0%   { transform: rotate(0deg) scale(1); }
      25%  { transform: rotate(90deg) scale(1.14); }
      50%  { transform: rotate(180deg) scale(0.92); }
      75%  { transform: rotate(270deg) scale(1.16); }
      100% { transform: rotate(360deg) scale(1); }
    }
    @media (prefers-reduced-motion: reduce) { .rv-raver.rv-fizzfx canvas { animation: none; } }
    /* MOON BOOTS: big lunar hops on the wrap — crouch, float up, squash the
       landing (the keyframes carry the centring translate, balloon-style) */
    .rv-raver.rv-bootsfx { animation: rvMoonHop 0.85s ease-in-out infinite; }
    @keyframes rvMoonHop {
      0%, 100% { transform: translate(-50%, -50%) scale(1, 1); }
      12% { transform: translate(-50%, -50%) scale(1.1, 0.85); }
      45% { transform: translate(-50%, calc(-50% - 42px)) scale(0.94, 1.1); }
      78% { transform: translate(-50%, -50%) scale(1, 1); }
      88% { transform: translate(-50%, -50%) scale(1.14, 0.82); }
    }
    /* JELLY LEGS: the whole banana wobbles like jello, anchored at the feet */
    .rv-raver.rv-wobblefx canvas { transform-origin: 50% 92%; animation: rvJellyWobble 0.5s ease-in-out infinite; }
    @keyframes rvJellyWobble {
      0%, 100% { transform: skewX(-7deg) scaleY(0.97); }
      50% { transform: skewX(7deg) scaleY(1.03); }
    }
    @media (prefers-reduced-motion: reduce) { .rv-raver.rv-bootsfx, .rv-raver.rv-wobblefx canvas { animation: none; } }
    /* ---- THE MENU's costume effects (one class per fx, 10s moments) ---- */
    /* paparazzi: the flash keeps going off — BIGGER (Trym round 2): brighter
       pop + a white radial flashbang behind the banana on the same clock */
    .rv-raver.rv-flashfx canvas { animation: rvFlashPop 1.4s steps(1) infinite; }
    @keyframes rvFlashPop { 0%, 88% { filter: none; } 89%, 100% { filter: brightness(3) drop-shadow(0 0 26px #ffffff); } }
    .rv-raver.rv-flashfx::before {
      content: ''; position: absolute; inset: -30%; pointer-events: none;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.85) 0 14%, rgba(255, 255, 255, 0.25) 34%, transparent 55%);
      opacity: 0; animation: rvFlashBang 1.4s steps(1) infinite;
    }
    @keyframes rvFlashBang { 0%, 88% { opacity: 0; } 89%, 100% { opacity: 1; } }
    /* the off-menu milkshake: PROPERLY THICC now (Trym: "fun fat banana") —
       half again as wide, jiggling on the hips */
    .rv-raver.rv-thicc { animation: rvThicc 0.7s ease-in-out infinite; }
    @keyframes rvThicc {
      0%, 100% { transform: translate(-50%, -50%) scale(1.42, 0.96); }
      50% { transform: translate(-50%, -50%) scale(1.55, 0.92); }
    }
    /* sugar rush: rapidly shaking off ALL the sugar (canvas jitter, transform only) */
    .rv-raver.rv-sugarfx canvas { animation: rvSugarShake 0.12s steps(2) infinite; }
    @keyframes rvSugarShake {
      0%, 100% { transform: translate(-3px, 0) rotate(-3deg); }
      50% { transform: translate(3px, -2px) rotate(3deg); }
    }
    /* flaming potassium: the flare-up glow — a STATIC filter class flipped by
       JS on a flicker clock (never keyframe filter on banana canvases — iOS
       bakes it; the shock-blink lesson) */
    .rv-raver.rv-flamehot canvas { filter: drop-shadow(0 0 9px #ff9128) drop-shadow(0 0 20px #e8542c); }
    @media (prefers-reduced-motion: reduce) { .rv-raver.rv-thicc, .rv-raver.rv-sugarfx canvas, .rv-raver.rv-flashfx::before { animation: none; } }
    /* blue lagoon: cool cyan aura */
    .rv-raver.rv-lagoonglow canvas { filter: drop-shadow(0 0 8px #4db8ff); }
    /* water: clean, clear, hydrated */
    .rv-raver.rv-waterglow canvas { filter: drop-shadow(0 0 7px #e8f6ff); }
    /* espresso martini: the caffeine jitter */
    .rv-raver.rv-jitter { animation: rvJitter 0.16s steps(2) infinite; }
    @keyframes rvJitter {
      0%, 100% { transform: translate(calc(-50% - 2px), -50%); }
      50% { transform: translate(calc(-50% + 2px), calc(-50% - 1px)); }
    }
    /* piña colada: the sway — the floor is a hammock */
    .rv-raver.rv-sway { animation: rvSway 1.7s ease-in-out infinite; }
    @keyframes rvSway {
      0%, 100% { transform: translate(-50%, -50%) rotate(-7deg); }
      50% { transform: translate(-50%, -50%) rotate(7deg); }
    }
    /* THE SMOKE POOF: expired items + leaving ravers exit in a puff, never a blink */
    .rv-poof { position: absolute; transform: translate(-50%, -50%); width: 36px; pointer-events: none; }
    .rv-poof span { position: absolute; inset: 0; opacity: 0; }
    .rv-poof svg { width: 100%; height: auto; image-rendering: pixelated; }
    .rv-poof__1 { animation: rvPoofStep 0.75s steps(1) forwards; }
    .rv-poof__2 { animation: rvPoofStep 0.75s steps(1) 0.25s forwards; }
    .rv-poof__3 { animation: rvPoofStep 0.75s steps(1) 0.5s forwards; }
    @keyframes rvPoofStep { 0% { opacity: 1; } 33%, 100% { opacity: 0; } }
    /* the cartoon electrocution: JS flips these STATIC classes — deliberately
       NO keyframes: iOS baked the animation's black frame into the composited
       layer and kept it long after the class was gone (the permanent-skeleton
       bug); plain class flips end in a plain style change, nothing can stick */
    .rv-raver.rv-shock canvas { filter: brightness(0) drop-shadow(0 0 5px #78ebff); }
    .rv-raver.rv-shockflash canvas { filter: brightness(2.8) saturate(0) drop-shadow(0 0 14px #78ebff); }
    @media (prefers-reduced-motion: reduce) {
      .rv-raver.rv-shock canvas, .rv-raver.rv-shockflash canvas { filter: drop-shadow(0 0 7px #78ebff); }
    }
    @keyframes rvItemBob { 50% { transform: translate(-50%, -62%) scale(1.1); } }
    /* pickup juice: a pixel ring + four stars burst where the item was grabbed */
    .rv-pop { position: absolute; width: 60px; height: 60px; transform: translate(-50%, -50%); z-index: 520; pointer-events: none; }
    .rv-pop__ring {
      position: absolute; inset: 16px; border: 4px solid #ffe135;
      animation: rvPopRing 0.55s steps(4) forwards;
    }
    .rv-pop__s {
      position: absolute; left: 50%; top: 50%; width: 6px; height: 6px; margin: -3px 0 0 -3px;
      background: #fffdf5; box-shadow: 0 0 6px #ffe135;
      animation: rvPopStar 0.75s steps(5) forwards;
    }
    @keyframes rvPopRing {
      0% { transform: scale(0.35); opacity: 1; }
      70% { transform: scale(1.15); opacity: 0.8; }
      100% { transform: scale(1.35); opacity: 0; }
    }
    @keyframes rvPopStar {
      0% { transform: translate(0, 0); opacity: 1; }
      100% { transform: translate(var(--dx), var(--dy)); opacity: 0; }
    }
    /* the fistbump: two gloves slide in, BUMP (pixel spark), drift up and fade */
    .rv-five { position: absolute; width: 74px; height: 40px; transform: translate(-50%, -50%); z-index: 500; pointer-events: none; animation: rvFiveWrap 1.5s steps(6) forwards; }
    .rv-five span { position: absolute; left: 50%; top: 50%; width: 32px; line-height: 0; }
    .rv-five svg { width: 100%; height: auto; image-rendering: pixelated; filter: drop-shadow(0 0 4px #ffe135); }
    .rv-five__l { animation: rvBumpL 0.8s steps(4) forwards; }
    .rv-five__r { animation: rvBumpR 0.8s steps(4) forwards; }
    .rv-five::after { /* the impact star — a crisp pixel plus, no glyphs */
      content: ''; position: absolute; left: 50%; top: 50%; width: 6px; height: 6px; margin: -3px 0 0 -3px;
      background: #ffe135; box-shadow: 0 -9px #ffe135, 0 9px #ffe135, -9px 0 #ffe135, 9px 0 #ffe135, 0 0 8px #ffe135;
      opacity: 0; animation: rvBumpSpark 1.5s steps(3) forwards;
    }
    @keyframes rvBumpL {
      0% { transform: translate(-34px, -50%); }
      45% { transform: translate(-27px, -50%); }
      55% { transform: translate(-30px, -50%); }
      100% { transform: translate(-28px, -50%); }
    }
    @keyframes rvBumpR {
      0% { transform: translate(6px, -50%) scaleX(-1); }
      45% { transform: translate(-1px, -50%) scaleX(-1); }
      55% { transform: translate(2px, -50%) scaleX(-1); }
      100% { transform: translate(0px, -50%) scaleX(-1); }
    }
    @keyframes rvBumpSpark {
      0%, 40% { opacity: 0; transform: scale(0.4); }
      50% { opacity: 1; transform: scale(1.2); }
      75% { opacity: 0.8; }
      100% { opacity: 0; transform: scale(0.6); }
    }
    @keyframes rvFiveWrap {
      0% { opacity: 0; transform: translate(-50%, -50%); }
      10% { opacity: 1; }
      65% { opacity: 1; transform: translate(-50%, -60%); }
      100% { opacity: 0; transform: translate(-50%, -110%); }
    }
    @media (prefers-reduced-motion: reduce) { .rv-item, .rv-five, .rv-pop *, .rv-twinkle, .rv-twinkle svg { animation: none; } .rv-twinkle .rv-twinkle__b { opacity: 0; } }

    /* THE MIXER — hype meter + chain, docked in the dead space right of the bar
       (Trym's placement: on the floor itself, no scrolling to see your numbers) */
    .rv-mixer {
      position: absolute; right: 8px; bottom: 8px; z-index: 600; pointer-events: none;
      background: rgba(13, 11, 20, 0.88); border: 3px solid #2f2250; padding: 6px 8px;
      font-size: 0.6rem; font-weight: 800; letter-spacing: 0.08em; color: #b388ff;
    }
    .rv-mixer__row { display: flex; align-items: center; gap: 6px; }
    .rv-mixer__bar { display: flex; gap: 2px; }
    .rv-mixer__seg { width: 7px; height: 13px; background: #241a38; }
    .rv-mixer__seg.on { background: #b388ff; }
    .rv-mixer__seg.on:nth-child(n+6) { background: #ffe135; }
    .rv-mixer__seg.on:nth-child(n+10) { background: #ff4d9d; }
    .rv-mixer--peak { border-color: #ffe135; animation: rvMixerPeak 0.5s steps(2) infinite; }
    @keyframes rvMixerPeak { 50% { border-color: #ff4d9d; } }
    /* CHARGED: the meter DISAPPEARS and the whole box becomes THE button —
       a frozen full meter with a tiny TAP tag read as "why isn't the meter
       working?" (Trym). Tap it, the drop fires, the meter comes back. */
    .rv-mixer--charged {
      border-color: #111; background: #ffe135; color: #111;
      cursor: pointer; pointer-events: auto; touch-action: manipulation;
      -webkit-tap-highlight-color: transparent; user-select: none;
      animation: rvTapNudge 0.8s ease-in-out infinite;
    }
    .rv-mixer--charged .rv-mixer__row, .rv-mixer--charged .rv-mixer__lvl { display: none; }
    /* LEVEL: the lifetime bar under the jelly meter — REP fills it forever
       (the WHY build: a bar that's always almost full is the oldest trick) */
    .rv-mixer__lvl { display: flex; align-items: center; gap: 6px; margin-top: 4px; color: #ffe135; }
    .rv-mixer__lvlbar { flex: 1; min-width: 60px; height: 7px; background: #241a38; overflow: hidden; }
    .rv-mixer__lvlbar i { display: block; height: 100%; width: 0; background: #ffe135; transition: width 0.4s ease; }
    .rv-mixer__lvl--pop { animation: rvLvlPop 0.9s steps(3); }
    .rv-mixer__lvl--pop .rv-mixer__lvlbar { box-shadow: 0 0 6px #ffe135, 0 0 16px #ffe135; }
    .rv-mixer__lvl--pop span:first-child { color: #fffdf5; text-shadow: 0 0 8px #ffe135; }
    @keyframes rvLvlPop { 33% { transform: scale(1.3); } 66% { transform: scale(0.95); } }
    /* the level-up moment: pixel arrow + LVL N riding up off YOUR banana */
    .rv-lvlup {
      position: absolute; transform: translate(-50%, -50%); z-index: 650; pointer-events: none;
      display: flex; align-items: center; gap: 6px;
      font-weight: 800; font-size: 1.1rem; color: #ffe135; letter-spacing: 0.04em;
      text-shadow: 1px 1px 0 #000, -1px 1px 0 #000, 1px -1px 0 #000, -1px -1px 0 #000, 0 0 12px rgba(255, 225, 53, 0.8);
      animation: rvLvlUpFloat 1.85s ease-out forwards;
    }
    .rv-lvlup svg { width: 22px; height: 25px; image-rendering: pixelated; filter: drop-shadow(0 0 6px rgba(255, 225, 53, 0.9)); animation: rvLvlArrow 0.4s steps(2) infinite; }
    @keyframes rvLvlUpFloat {
      0% { opacity: 0; transform: translate(-50%, -30%) scale(0.5); }
      12% { opacity: 1; transform: translate(-50%, -70%) scale(1.35); }
      26% { transform: translate(-50%, -85%) scale(1); }
      80% { opacity: 1; }
      100% { opacity: 0; transform: translate(-50%, -230%) scale(1); }
    }
    @keyframes rvLvlArrow { 50% { transform: translateY(-3px); } }
    /* club titles on the roster — earned status, gold and quiet */
    .rv-title { font-style: normal; color: #ffe135; font-size: 0.62rem; letter-spacing: 0.06em; margin-left: 6px; opacity: 0.85; }
    .rv-mixer--charged::after { content: '🍌 JELLY TIME!'; display: block; padding: 4px 2px; font-size: 0.66rem; }
    @keyframes rvTapNudge { 50% { transform: translateY(-3px); } }
    /* the tour's close-up: screen-space UI can't be camera-zoomed, so the
       meter itself steps forward — and UP, clear of the tap-to-continue band
       (they shared the bottom row on mobile) */
    .rv-mixer--tour { transform: translateY(-64px) scale(1.55); transform-origin: 100% 100%; transition: transform 0.45s ease; box-shadow: 0 0 26px rgba(255, 225, 53, 0.45); }
    /* THE NIGHT: the quest log gets its own panel, top-left — the classic HUD
       spot for "what am I doing?", away from the meter it merely feeds */
    .rv-quest { /* same height as the zoom button opposite — the top row is symmetric */
      position: absolute; top: 8px; left: 8px; z-index: 600; max-width: 190px;
      box-sizing: border-box; min-height: 44px;
      display: flex; flex-direction: column; justify-content: center;
      background: rgba(13, 11, 20, 0.88); border: 3px solid #ffe135; padding: 6px 9px 7px;
    }
    .rv-quest[hidden] { display: none; }
    .rv-quest__k { display: block; font-size: 0.54rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; color: #ffe135; margin-bottom: 3px; }
    .rv-quest__row { display: flex; align-items: center; gap: 6px; font-size: 0.66rem; font-weight: 800; color: #fffdf5; line-height: 1.35; }
    /* progressive disclosure on small screens: a new job shows itself, then
       tucks behind the TONIGHT chip — tap toggles. The floor view wins. */
    .rv-quest--min .rv-quest__row { display: none; }
    .rv-quest--min .rv-quest__k { margin-bottom: 0; }
    @media (max-width: 640px) {
      .rv-quest { cursor: pointer; touch-action: manipulation; -webkit-tap-highlight-color: transparent; }
      .rv-quest__k::after { content: ' ▾'; }
      .rv-quest--min .rv-quest__k::after { content: ' ▸'; }
    }
    /* desktop: one horizontal bar (TONIGHT · job) — exactly the zoom button's
       44px, so the floor's top row is symmetric (Trym's rule) */
    @media (min-width: 641px) {
      .rv-quest { flex-direction: row; align-items: center; gap: 9px; max-width: none; }
      .rv-quest__k { margin-bottom: 0; }
      .rv-quest__row { white-space: nowrap; }
    }
    .rv-qbox { flex: none; width: 9px; height: 9px; border: 2px solid #ffe135; background: #241a38; }
    .rv-qbox.done { background: #39ff14; border-color: #39ff14; }
    /* hype mode: the whole floor sees you peak (effect travels the outfit pipe;
       this glow is the local cherry) */
    .rv-raver.rv-hypemode canvas { filter: drop-shadow(0 0 10px #ffe135) drop-shadow(0 0 18px #ff4d9d); }
    /* sparkle runs: your personal pellet trail — pure chase fuel */
    .rv-pellet { /* a JELLY DROP — spilled jelly, hoovered into the meter */
      position: absolute; width: 15px; height: 15px; margin: -7.5px 0 0 -7.5px;
      z-index: 8; pointer-events: none;
      filter: drop-shadow(0 0 6px rgba(255, 77, 157, 0.75));
      /* jelly RAINS from the rig (Trym: "where does the jelly come from?") —
         each pellet falls in from above and lands with a squash, THEN jiggles.
         --pd = the per-pellet stagger; the bob waits out its own landing. */
      animation: rvPelletDrop 0.5s cubic-bezier(0.3, 0, 0.55, 1.2) var(--pd, 0s) backwards,
                 rvPelletBob 0.7s steps(2) calc(var(--pd, 0s) + 0.5s) infinite;
    }
    .rv-pellet svg { width: 100%; height: 100%; image-rendering: pixelated; display: block; }
    @keyframes rvPelletDrop {
      0% { opacity: 0; transform: translateY(-52px); }
      12% { opacity: 1; }
      68% { transform: translateY(0) scale(1, 1); }
      84% { transform: scale(1.35, 0.65); }
      100% { transform: scale(1, 1); }
    }
    @keyframes rvPelletBob { 50% { transform: scale(1.18, 0.88); } } /* jelly JIGGLES */
    .rv-pellet--got { animation: rvPelletGot 0.4s steps(3) forwards; }
    @keyframes rvPelletGot { 100% { transform: scale(2.1); opacity: 0; } }
    @media (prefers-reduced-motion: reduce) { .rv-pellet, .rv-mixer--peak { animation: none; } }

    .rv-zoom {
      position: absolute; top: 8px; right: 8px; z-index: 600;
      display: flex; align-items: center; justify-content: center; gap: 6px;
      box-sizing: border-box; min-height: 44px;
      background: rgba(13, 11, 20, 0.85); color: #fffdf5; border: 3px solid #ffe135;
      font-size: 0.72rem; font-weight: 800; letter-spacing: 0.04em; padding: 0.45rem 0.6rem;
      cursor: pointer; touch-action: manipulation; -webkit-tap-highlight-color: transparent; user-select: none;
    }
    .rv-zoom svg { width: 16px; height: auto; image-rendering: pixelated; display: block; }
    .rv-zoom:hover { background: #ffe135; color: #111; }

    /* THE TOUR — z 800 beats everything; the highlight's giant box-shadow IS
       the dark overlay (clipped by the club's overflow:hidden). All controls
       follow the site's yellow pixel-button language. */
    .rv-tour { position: absolute; inset: 0; z-index: 800; cursor: pointer; }
    /* the highlight is a SPOTLIGHT POOL: a round cutout with a feathered edge
       (the blur on the giant dim shadow) that fades smoothly into the dark —
       generous and soft, so dead-on centering stops mattering (Trym: the hard
       square "highlights well when it's not symmetrical") */
    .rv-tour__hl {
      position: absolute; pointer-events: none;
      border-radius: 50%;
      box-shadow: 0 0 56px 9999px rgba(8, 6, 14, 0.82);
      transition: all 0.45s ease;
    }
    .rv-tour__hl[hidden] { display: none; }
    /* the big line rides an anchor set by JS: above YOUR banana on step 1,
       centred over the floor on step 2 — never "somewhere in the club" */
    .rv-tour__big {
      position: absolute; transform: translateX(-50%); text-align: center;
      pointer-events: none; max-width: 94%; width: max-content;
    }
    .rv-tour__big[hidden] { display: none; }
    .rv-tour__big span {
      display: block; font-family: "Archivo Black", sans-serif; font-size: clamp(1.5rem, 6vw, 2.9rem);
      color: #ffe135; -webkit-text-stroke: 2px #111; text-shadow: 4px 4px 0 #000; line-height: 1.15;
    }
    .rv-tour__big small { display: block; margin-top: 0.5rem; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: #fffdf5; text-shadow: 2px 2px 0 #000; }
    .rv-tour__box {
      position: absolute; max-width: 250px; pointer-events: none;
      background: #fffdf5; color: #111; border: 3px solid #111; box-shadow: 4px 4px 0 #000;
      padding: 0.6rem 0.8rem; font-size: 0.74rem; line-height: 1.5;
    }
    .rv-tour__box[hidden] { display: none; }
    .rv-tour__box::before { /* the pixel arrow: side + x-position set per target by JS */
      content: ''; position: absolute; left: var(--ax, 26px); width: 12px; height: 12px; background: #ffe135; border: 3px solid #111;
    }
    .rv-tour__box[data-side="below"]::before { top: -9px; }
    .rv-tour__box[data-side="above"]::before { bottom: -9px; }
    .rv-tour__box[data-side="none"]::before { display: none; }
    .rv-tour__title { margin: 0 0 0.2rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.06em; font-size: 0.72rem; background: #ffe135; display: inline-block; padding: 0.08rem 0.35rem; }
    .rv-tour__text { margin: 0; }
    /* the control band: ONE centred row just above the HUD (bottom offset set
       by JS) — "tap to continue" bounces, skip sits quietly beside it. House
       yellow pixel buttons, never glued to a screen edge, can never overlap. */
    .rv-tour__band {
      position: absolute; left: 0; right: 0; bottom: 76px;
      display: flex; justify-content: center; align-items: center; gap: 10px;
      pointer-events: none;
    }
    .rv-tour__next {
      margin: 0;
      background: #ffe135; color: #111; border: 3px solid #111; box-shadow: 3px 3px 0 #000;
      font-size: 0.7rem; font-weight: 800; letter-spacing: 0.05em; text-transform: uppercase;
      padding: 0.5rem 0.9rem;
      animation: rvTourNext 1.4s steps(2) infinite;
    }
    @keyframes rvTourNext { 50% { transform: translateY(-4px); } }
    .rv-tour__skip {
      background: #fffdf5; color: #111; border: 3px solid #111; box-shadow: 3px 3px 0 #000;
      font-size: 0.62rem; font-weight: 800; letter-spacing: 0.04em; text-transform: uppercase;
      padding: 0.5rem 0.6rem; cursor: pointer; pointer-events: auto;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent;
    }
    .rv-tour__skip:hover { background: #ffe135; }
    /* during the WHOLE tour: no chase-ables spawning mid-lesson, and no OTHER
       visitors either — the tutorial is about THE PLAYER and the staff, and a
       stranger dancing through "THIS IS YOU" breaks the premise (Trym) */
    .rv-floor.rv-tourclean #rvItem, .rv-floor.rv-tourclean #rvVinyl, .rv-floor.rv-tourclean #rvGold,
    .rv-floor.rv-tourclean #rvRun, .rv-floor.rv-tourclean #rvTwinkle, .rv-floor.rv-tourclean #rvSpot,
    .rv-floor.rv-tourclean .rv-raver:not(.rv-raver--me),
    .rv-floor.rv-tourclean #rvChores, .rv-floor.rv-tourclean .rv-monkey { visibility: hidden; }
    /* steps 1–2 only: meters off too — furniture and staff, nothing else */
    .rv-floor.rv-tourfocus .rv-mixer, .rv-floor.rv-tourfocus .rv-quest { visibility: hidden; }
    .rv-world--tour { transition: transform 0.85s ease; }
    /* THE BIG MOMENT: pixel type over the floor for session-defining beats
       (the nightshift stamp-out) — same register as the tour's THIS IS YOU */
    .rv-bigmoment {
      position: absolute; left: 50%; top: 26%; transform: translateX(-50%); z-index: 650;
      width: max-content; max-width: 94%; text-align: center; pointer-events: none;
      animation: rvBigIn 0.3s steps(3);
    }
    .rv-bigmoment b {
      display: block; font-family: "Archivo Black", sans-serif;
      font-size: clamp(1.4rem, 5.5vw, 2.6rem); line-height: 1.15;
      color: #ffe135; -webkit-text-stroke: 2px #111; text-shadow: 4px 4px 0 #000;
    }
    .rv-bigmoment small {
      display: block; margin-top: 0.45rem; font-size: 0.8rem; font-weight: 800;
      letter-spacing: 0.1em; text-transform: uppercase; color: #fffdf5; text-shadow: 2px 2px 0 #000;
    }
    .rv-bigmoment--out { animation: rvBigOut 0.5s steps(4) forwards; }
    @keyframes rvBigIn { 0% { transform: translateX(-50%) scale(0.6); opacity: 0; } 100% { transform: translateX(-50%) scale(1); opacity: 1; } }
    @keyframes rvBigOut { 100% { transform: translateX(-50%) translateY(-24px); opacity: 0; } }
    @media (prefers-reduced-motion: reduce) { .rv-bigmoment, .rv-bigmoment--out { animation: none; } }

    /* pickup/earn banners: TOP BAND, between the quest chip and the zoom
       button (Trym v3: the bottom stack covered the LVL meter + Barty's
       bubbles). pointer-events: none throughout, so the old top-box
       tap-eating bug (why they once moved down) cannot return. On phones the
       centre gap up there is too narrow — they drop just below the row. */
    .rv-toasts {
      position: absolute; left: 50%; top: 8px; transform: translateX(-50%); z-index: 700;
      display: flex; flex-direction: column; align-items: center; gap: 5px;
      max-width: min(94%, calc(100% - 250px)); width: max-content; pointer-events: none;
    }
    @media (max-width: 640px) { .rv-toasts { top: 60px; max-width: 94%; } }
    .rv-glowtoast {
      max-width: 100%; text-align: center; font-size: 0.72rem; line-height: 1.4;
      background: rgba(23, 18, 31, 0.94); color: #fffdf5; border: 2px solid #39ff14;
      box-shadow: 0 0 10px rgba(57, 255, 20, 0.4); padding: 0.35rem 0.75rem;
      pointer-events: none;
    }
    .rv-glowtoast b { color: #39ff14; }

    .rv-raver { position: absolute; transform: translate(-50%, -50%); line-height: 0; transition: left 0.18s linear, top 0.18s linear; }
    /* YOUR banana echoes input at frame rate — the 0.18s glide (needed to
       smooth remote 150ms packets) only added ~180ms of input lag here */
    .rv-raver--me { transition: none; }
    .rv-raver canvas { transition: transform 0.15s ease; }
    .rv-floor { cursor: pointer; touch-action: manipulation; }
    .rv-raver canvas { image-rendering: pixelated; }
    .rv-raver--me canvas { filter: drop-shadow(0 0 6px #ffe135); }
    .rv-emote {
      position: absolute; left: 50%; top: 0; font-size: 1.5rem; line-height: 1;
      animation: rvFloat 1.9s ease-out forwards; pointer-events: none;
    }
    .rv-emote--heart { color: #ff4d6d; }
    .rv-emote--confetti { color: #4db8ff; }
    .rv-emote--banana { font-size: 1.3rem; }
    @keyframes rvFloat { from { transform: translate(-50%, 0); opacity: 1; } to { transform: translate(-50%, -70px); opacity: 0; } }

    /* THE DROP flashes above the DJ — it's the stage's moment */
    .rv-dropflash {
      position: absolute; left: 0; right: 0; top: 4px; display: grid; place-items: center;
      pointer-events: none; z-index: 600;
    }
    .rv-dropflash[hidden] { display: none; } /* our display:grid beats the UA [hidden] rule — the text was stuck ON permanently */
    .rv-dropflash span {
      font-family: "Archivo Black", sans-serif; font-size: clamp(1.3rem, 4.5vw, 2.4rem);
      color: #ffe135; -webkit-text-stroke: 2px #111; animation: rvDropPulse 0.5s steps(2) infinite;
    }
    @keyframes rvDropPulse { 50% { transform: scale(1.06) rotate(-2deg); color: #ff4d6d; } }

    /* the HUD: ONE centred cluster — reactions, the stage, the tour replay.
       The stage is a peer of the emotes now, not the marquee act (it looked
       like the main feature and it isn't — Trym). */
    .rv-hud {
      position: relative;
      display: flex; align-items: center; justify-content: center; gap: 0.6rem;
      background: #17121f; border-top: 4px solid #ffe135; padding: 0.7rem 0.9rem; flex-wrap: wrap;
      touch-action: manipulation; /* no iOS double-tap zoom when mashing emotes */
    }
    .rv-emotes { display: flex; gap: 0.5rem; }
    .rv-emote-btn {
      background: #0d0b14; color: #fffdf5; border: 3px solid #ffe135; cursor: pointer;
      font-size: 1.2rem; line-height: 1; padding: 0.55rem 0.9rem; border-radius: 2px;
      min-width: 48px; min-height: 48px;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent; user-select: none;
    }
    .rv-emote-btn:hover { background: #ffe135; }
    .rv-emote-btn--fire { border-color: #ff9e2c; }
    .rv-emote-btn--fire:hover { background: #ff9e2c; }
    .rv-stage-btn {
      background: #0d0b14; color: #fffdf5; border: 3px solid #ffe135; cursor: pointer;
      font-weight: 800; font-size: 0.7rem; letter-spacing: 0.04em; padding: 0.55rem 0.8rem;
      min-height: 48px;
      touch-action: manipulation; -webkit-tap-highlight-color: transparent; user-select: none;
    }
    .rv-stage-btn:hover:not([disabled]) { background: #ffe135; color: #111; }
    .rv-stage-btn[disabled] { color: #b388ff; border-color: #4a3b6b; cursor: default; }
    /* inline-flex centring: the pixel ? is a display:block svg, and a block
       box never text-align-centres in a button — on mobile the emote row's
       zero horizontal padding parked it at the left edge (Trym's catch) */
    .rv-tourbtn { flex: 0 0 auto !important; display: inline-flex; align-items: center; justify-content: center; border-color: #4a3b6b; opacity: 0.85; font-size: 0.95rem; }
    /* the sound toggle: dim speaker when muted, gold + pulsing waves when live */
    .rv-soundbtn svg { width: 16px; }
    .rv-soundbtn:not(.rv-soundbtn--on) svg rect[class] { opacity: 0.25; }
    .rv-soundbtn--on { border-color: #ffe135; opacity: 1; }
    .rv-soundbtn--on svg rect { fill: #ffe135; }
    .rv-soundbtn--on .rv-soundbtn__w1 { animation: rvWave1 0.8s steps(1) infinite; }
    .rv-soundbtn--on .rv-soundbtn__w2 { animation: rvWave1 0.8s steps(1) 0.26s infinite; }
    .rv-soundbtn--on .rv-soundbtn__w3 { animation: rvWave1 0.8s steps(1) 0.53s infinite; }
    @keyframes rvWave1 { 0%, 60% { opacity: 1; } 61%, 100% { opacity: 0.2; } }
    .rv-tourbtn:hover { background: #b388ff; opacity: 1; }
    .rv-tourbtn svg { width: 13px; height: auto; image-rendering: pixelated; display: block; }
    .rv-more { position: absolute; right: 0.9rem; bottom: 0.3rem; font-size: 0.7rem; opacity: 0.6; }
    /* the stage exclusive reads BIG — it's the point of being up there */
    .rv-emote--fire { color: #ff9e2c; font-size: 2.3rem; }
    .rv-emote svg { width: 24px; height: auto; image-rendering: pixelated; }

    @media (max-width: 640px) {
      .rv-booth { min-height: 138px; }
      .rv-djgroup { width: 120px; }
      .rv-djgroup canvas { width: 78px; height: 78px; margin-bottom: -30px; }
      .rv-desk { height: 34px; }
      .rv-speaker { width: 34px; height: 48px; }
      .rv-speaker--l { left: calc(50% - 102px); }
      .rv-speaker--r { right: calc(50% - 102px); }
      .rv-stage { bottom: 36px; gap: 6px; }
