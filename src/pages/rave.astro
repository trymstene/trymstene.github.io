      .rv-djgroup canvas { width: 78px; height: 78px; margin-bottom: -30px; }
      .rv-desk { height: 34px; }
      .rv-speaker { width: 34px; height: 48px; }
      .rv-speaker--l { left: calc(50% - 102px); }
      .rv-speaker--r { right: calc(50% - 102px); }
      .rv-stage { bottom: 36px; gap: 6px; }
      .rv-stage__gap { width: 84px; }
      .rv-stage .rv-raver canvas { width: 46px !important; height: 46px !important; }
      .rv-emotes { flex: 1; }
      .rv-emote-btn { flex: 1; padding: 0.75rem 0; font-size: 1.4rem; }
      .rv-stage-btn { flex-basis: 100%; }
    }

    .rv-panel { border: 4px solid #ffe135; background: #17121f; box-shadow: 8px 8px 0 #000; padding: 1rem; }
    .rv-panel h2 { margin: 0 0 0.6rem; font-size: 1rem; color: #ffe135; }
    .rv-panel ol { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.45rem; font-size: 0.85rem; }
    .rv-panel li { display: flex; justify-content: space-between; gap: 0.6rem; }
    .rv-panel li b { color: #ffe135; }
    .rv-panel li.rv-me span { color: #ffe135; }
    .rv-panel .rv-door { margin-top: 1rem; }
    .rv-door a { display: block; text-align: center; background: #ffe135; color: #111; font-weight: 800; padding: 0.7rem 0.6rem; text-decoration: none; border: 3px solid #111; }
    .rv-door a:hover { transform: translateY(-2px); }
    .rv-note { font-size: 0.75rem; opacity: 0.65; margin-top: 0.8rem; }
