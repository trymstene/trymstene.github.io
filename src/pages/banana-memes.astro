---
// THE BANANA GALLERY hub — /banana-memes/ owns the "banana memes" query
// (18.1K/mo). Giphy model: this page is the collection, every item below has
// its own indexable page, tags are query-first landing pages. Items live in
// src/data/gallery.json (tools/build-gallery.py maintains it from
// public/assets/gallery-bananas/).
import BaseLayout from '../layouts/BaseLayout.astro';
import PixelIcon from '../components/PixelIcon.astro';
import items from '../data/gallery.json';
import { TAGS, MIN_TAG_ITEMS } from '../data/gallery-tags.js';

const SITE = 'https://trymstene.com';
const stickers = items.filter((i) => i.kind === 'sticker');
const gifs = items.filter((i) => i.kind === 'gif');

// community lane: approved visitor submissions live in the share worker's R2;
// pulled at build (worker down = they're simply absent until the next build)
const WORKER = 'https://banana-share.trymstene.workers.dev';
let community = [];
try {
  const res = await fetch(WORKER + '/gallery/approved');
  if (res.ok) community = (await res.json()).sort((a, b) => b.approved - a.approved);
} catch (e) {}

// ONE grid, first-class citizens (Trym: same visibility, not shoved to the
// bottom): editorial + community merge into a common card shape, community
// spread EVENLY through the grid — visible early without dominating
const cards = items.map((i) => ({
  href: `/banana-memes/${i.id}/`,
  img: `/assets/gallery-bananas/${i.file}`,
  w: i.w, h: i.h,
  title: i.title,
  kind: i.kind,
  community: false,
  sub: i.kind === 'sticker' ? '✂ sticker' : '🎞 gif',
  search: `${i.title} ${i.caption} ${i.tags.join(' ')} ${i.kind}`.toLowerCase(),
  tags: i.tags.join(' '),
}));
const commCards = community.map((c) => ({
  href: `/banana-memes/by/${c.slug}/`,
  img: `${WORKER}/gallery/gif/${c.slug}.gif`,
  w: undefined, h: undefined,
  title: c.title,
  kind: c.transparent ? 'sticker' : 'gif',
  community: true,
  by: c.by || 'a banana fan',
  sub: `🍌 by ${c.by || 'a banana fan'}`,
  search: `${c.title} ${c.by || ''} community ${(c.tags || []).join(' ')} ${c.transparent ? 'sticker' : 'gif'}`.toLowerCase(),
  tags: (c.tags || []).join(' '),
}));
if (commCards.length) {
  const step = Math.ceil((cards.length + 1) / (commCards.length + 1));
  commCards.forEach((c, n) => cards.splice(Math.min(step * (n + 1) + n, cards.length), 0, c));
}

const tagCount = {};
items.forEach((i) => i.tags.forEach((t) => { tagCount[t] = (tagCount[t] || 0) + 1; }));
const liveTags = Object.keys(TAGS).filter((t) => (tagCount[t] || 0) >= MIN_TAG_ITEMS);

// title stays OFF the exact phrase "dancing banana gif" — that belongs to
// /dancing-banana-gif-meme/ (the money page); this hub owns "banana memes"
const title = 'Banana Memes & Stickers — Free, from the Banana\'s Creator';
const description = `${cards.length} free banana memes: captioned meme GIFs and transparent stickers by the creator of the original 1999 Dancing Banana — plus the best from the community. Download and share, no watermark.`;

const galleryLD = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': SITE + '/banana-memes/#gallery',
  name: 'Banana Memes',
  url: SITE + '/banana-memes/',
  description,
  creator: { '@id': SITE + '/#trym' },
  hasPart: {
    '@type': 'ItemList',
    itemListElement: cards.map((c, n) => ({
      '@type': 'ListItem', position: n + 1,
      url: SITE + c.href, name: c.title,
    })),
  },
};
const crumbLD = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Dancing Banana GIF', item: SITE + '/dancing-banana-gif-meme/' },
    { '@type': 'ListItem', position: 2, name: 'Banana Memes', item: SITE + '/banana-memes/' },
  ],
};
---
<BaseLayout
  title={title}
  description={description}
  ogTitle="Banana Memes 🍌"
  ogDescription="Free dancing banana memes & transparent stickers, straight from the banana's creator."
  ogImage={`${SITE}/assets/gallery-posters/monday-again.png`}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(galleryLD)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(crumbLD)} />
  <style is:inline slot="head">
    .gm-wrap { max-width: 1100px; margin: 0 auto; padding: 1.6rem 1rem 2.5rem; }
    .gm-head h1 { margin: 0 0 0.3rem; }
    .gm-head p { margin: 0 0 1.2rem; opacity: 0.8; max-width: 64ch; }
    .gm-filters { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin-bottom: 0.8rem; }
    .gm-filters a, .gm-filters span.gm-chip {
      border: 3px solid var(--ink); background: var(--paper); padding: 0.35rem 0.7rem;
      font-weight: 700; font-size: 0.82rem; text-decoration: none; color: var(--ink);
    }
    .gm-filters a[aria-current="page"] { background: var(--ink); color: var(--banana); }
    .gm-filters a:hover { background: var(--banana); }
    .gm-tagrow { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 1rem; }
    .gm-tagrow a {
      font-size: 0.74rem; font-weight: 700; text-decoration: none; color: var(--ink);
      border: 2px solid var(--ink); padding: 0.2rem 0.55rem; background: var(--paper);
    }
    .gm-tagrow a:hover { background: var(--banana); }
    .gm-tagrow a[aria-current="page"] { background: var(--ink); color: var(--banana); }
    .gm-search { margin: 0 0 1.2rem; }
    .gm-search input {
      width: 100%; max-width: 420px; border: 3px solid var(--ink); background: var(--paper);
      padding: 0.55rem 0.8rem; font: inherit; font-weight: 700;
    }
    .gm-grid { display: grid; gap: 1rem; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); }
    .gm-card {
      display: block; text-decoration: none; color: var(--ink);
      border: var(--line); background: var(--paper); box-shadow: var(--shadow);
      padding: 0.7rem 0.7rem 0.6rem;
    }
    .gm-card:hover { background: var(--banana); }
    .gm-card .gm-img {
      display: flex; align-items: center; justify-content: center; aspect-ratio: 1;
      border: 3px solid var(--ink); background: #fff; overflow: hidden;
    }
    .gm-card .gm-img--sticker {
      background: repeating-conic-gradient(#f4f1e8 0% 25%, #e4e0d2 0% 50%) 0 0 / 22px 22px;
    }
    .gm-card img { max-width: 88%; max-height: 88%; height: auto; }
    .gm-card h2 { font-size: 0.95rem; margin: 0.55rem 0 0.1rem; }
    .gm-card .gm-kind { font-size: 0.68rem; font-weight: 800; letter-spacing: 0.07em; text-transform: uppercase; opacity: 0.55; }
    /* community byline: "by" stays a quiet label, the NAME gets the banana
       highlight — ink on yellow, unambiguous and high-contrast */
    .gm-kind--by { opacity: 1; }
    .gm-byname {
      display: inline-block; background: var(--banana); color: var(--ink);
      border: 2px solid var(--ink); padding: 0.05em 0.4em; margin-left: 0.15em;
      font-weight: 800; transform: rotate(-1deg);
    }
    .gm-cta {
      margin-top: 2.4rem; border: var(--line); background: var(--ink); color: var(--paper);
      box-shadow: var(--shadow); padding: 1.2rem 1.3rem;
    }
    .gm-cta h2 { margin: 0 0 0.4rem; font-size: 1.15rem; color: var(--banana); }
    .gm-cta p { margin: 0 0 0.9rem; font-size: 0.92rem; opacity: 0.9; max-width: 62ch; }
    .gm-about { max-width: 68ch; margin-top: 2.4rem; border-top: var(--line); padding-top: 1.5rem; }
    .gm-about h2 { font-size: 1.25rem; margin: 1.2rem 0 0.5rem; }
    .gm-about p { line-height: 1.6; }
  </style>

  <div class="gm-wrap">
    <div class="gm-head">
      <p class="kicker">The gallery</p>
      <h1>banana memes &amp; stickers</h1>
      <p>
        {cards.length} free banana memes by the person who made the original
        <a href="/dancing-banana-gif-meme/">1999 Dancing Banana GIF</a> — plus the best
        from the community. Captioned meme GIFs and transparent stickers, free to download
        and drop in any chat. No watermark, no sign-up.
      </p>
    </div>

    <!-- real <a> hrefs = the SEO pages stay crawlable + internally linked;
         JS intercepts clicks and filters IN PLACE (Trym: don't bounce people
         to a new page), pushState keeps the URL shareable/refreshable -->
    <div class="gm-filters" id="gmKinds" role="navigation" aria-label="Categories">
      <a href="/banana-memes/" data-kind="" aria-current="page">All ({cards.length})</a>
      <a href="/banana-memes/stickers/" data-kind="sticker">Stickers ({cards.filter((c) => c.kind === 'sticker').length})</a>
      <a href="/banana-memes/gifs/" data-kind="gif">GIFs ({cards.filter((c) => c.kind === 'gif').length})</a>
      {commCards.length > 0 && <a href="/banana-memes/by/" data-kind="community">🍌 Community ({commCards.length})</a>}
    </div>
    <div class="gm-tagrow" id="gmTags" role="navigation" aria-label="Tags">
      {liveTags.map((t) => <a href={`/banana-memes/${t}/`} data-tag={t}>#{t}</a>)}
    </div>

    <div class="gm-search">
      <input id="gmSearch" type="search" placeholder="🔍 search the bananas…" aria-label="Search banana memes" />
    </div>

    <div class="gm-grid" id="gmGrid">
      {cards.map((c, n) => (
        <a class="gm-card" href={c.href} data-kind={c.kind} data-tags={c.tags}
           data-community={c.community ? '1' : undefined} data-search={c.search}>
          <div class={`gm-img${c.kind === 'sticker' ? ' gm-img--sticker' : ''}`}>
            <img src={c.img} width={c.w} height={c.h}
                 loading={n < 6 ? 'eager' : 'lazy'}
                 alt={`${c.title} — ${c.community ? `a custom dancing banana by ${c.by}` : (c.kind === 'sticker' ? 'transparent dancing banana sticker' : 'dancing banana meme GIF')}`} />
          </div>
          <h2>{c.title}</h2>
          {c.community
            ? <span class="gm-kind gm-kind--by">🍌 by <b class="gm-byname">{c.by}</b></span>
            : <span class="gm-kind">{c.sub}</span>}
        </a>
      ))}
    </div>

    <div class="gm-cta">
      <h2>Want a banana that's 100% yours?</h2>
      <p>
        Dress the dancing banana yourself — hats, shades, captions — and download it free,
        <strong>then submit it to this gallery</strong> — the banana guy hangs the best ones.
        Or draw a whole new creature, pixel by pixel, in the Forge.
      </p>
      <a class="btn btn--light" href="/make-a-banana/" data-place="gallery">
        <PixelIcon name="palette" /> Make your own banana →
      </a>
      <a class="btn btn--light" href="/forge/" data-place="gallery">⚒ Open the Pixel Forge</a>
    </div>

    <section class="gm-about">
      <h2>What is this?</h2>
      <p>
        In 1999 I drew a dancing banana and it became one of the most-shared GIFs on the internet.
        This gallery is the banana's official meme collection — every GIF and sticker here is made
        by me, its original creator, and every one is free. Transparent-background bananas are
        <strong>stickers</strong> (they float over any chat), captioned ones are <strong>GIFs</strong>.
      </p>
      <p>
        Looking for the community's versions instead? Browse the
        <a href="/dancing-banana-remixes/">community remix gallery</a> — 266 bananas drawn by
        the internet since 1999. Want yours printed?
        The <a href="/make-a-banana/">banana builder</a> puts your design on real stickers and tees.
      </p>
    </section>
  </div>

  <script>
    // in-place filtering over the grid; the chip hrefs stay real (SEO pages
    // keep their links) but clicks filter here + pushState the matching URL,
    // so refresh/share lands on the static page and back/forward just works
    const inp = document.getElementById('gmSearch');
    const cards = [...document.querySelectorAll('#gmGrid .gm-card')];
    const kindLinks = [...document.querySelectorAll('#gmKinds a')];
    const tagLinks = [...document.querySelectorAll('#gmTags a')];
    const state = { q: '', kind: '', tag: '' };

    function apply() {
      cards.forEach((c) => {
        const okQ = !state.q || c.dataset.search.includes(state.q);
        const okK = !state.kind
          || (state.kind === 'community' ? c.dataset.community === '1' : c.dataset.kind === state.kind);
        const okT = !state.tag || c.dataset.tags.split(' ').includes(state.tag);
        c.style.display = okQ && okK && okT ? '' : 'none';
      });
      kindLinks.forEach((a) => {
        if ((a.dataset.kind || '') === state.kind && !state.tag) a.setAttribute('aria-current', 'page');
        else a.removeAttribute('aria-current');
      });
      tagLinks.forEach((a) => {
        if (a.dataset.tag === state.tag) a.setAttribute('aria-current', 'page');
        else a.removeAttribute('aria-current');
      });
    }
    function urlFor() {
      if (state.tag) return `/banana-memes/${state.tag}/`;
      if (state.kind === 'community') return '/banana-memes/by/';
      if (state.kind) return `/banana-memes/${state.kind === 'sticker' ? 'stickers' : 'gifs'}/`;
      return '/banana-memes/';
    }
    function stateFrom(path) {
      const seg = (path.match(/^\/banana-memes\/([a-z0-9-]+)\/$/) || [])[1] || '';
      state.kind = seg === 'stickers' ? 'sticker' : seg === 'gifs' ? 'gif' : seg === 'by' ? 'community' : '';
      state.tag = (seg && !state.kind) ? seg : '';
    }
    kindLinks.forEach((a) => a.addEventListener('click', (e) => {
      e.preventDefault();
      state.kind = a.dataset.kind || '';
      state.tag = '';
      history.pushState({}, '', a.getAttribute('href'));
      apply();
    }));
    tagLinks.forEach((a) => a.addEventListener('click', (e) => {
      e.preventDefault();
      // clicking the active tag clears it
      state.tag = state.tag === a.dataset.tag ? '' : a.dataset.tag;
      state.kind = '';
      history.pushState({}, '', state.tag ? a.getAttribute('href') : '/banana-memes/');
      apply();
    }));
    window.addEventListener('popstate', () => { stateFrom(location.pathname); apply(); });
    inp.addEventListener('input', () => { state.q = inp.value.trim().toLowerCase(); apply(); });
  </script>
</BaseLayout>
