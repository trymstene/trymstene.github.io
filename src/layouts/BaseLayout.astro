---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// One <head> to rule them all. Pages pass SEO props; extra <head> tags
// (JSON-LD schema, hreflang) go through the named "head" slot.
const {
  title,
  description,
  canonical,
  lang = 'en',
  ogType = 'website',
  ogImage = 'https://trymstene.com/assets/og/default.png',
  robots = 'index,follow,max-image-preview:large',
  showFooter = true,
} = Astro.props;
// our generated banners are always 1200x630; external/custom images vary
const ogIsBanner = ogImage.includes('/assets/og/');

const ogDescription = Astro.props.ogDescription ?? description;
const ogTitle = Astro.props.ogTitle ?? title;
const ogLocale = Astro.props.ogLocale;
const site = 'https://trymstene.com';
const canonicalURL = canonical ?? new URL(Astro.url.pathname, site).href;
---
<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="google-site-verification" content="aI-qTkBS_ACkw7mXPWsadMKDL6ASRH6QY5dtVw-84lI" />

    <meta property="og:type" content={ogType} />
    {ogLocale && <meta property="og:locale" content={ogLocale} />}
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    {ogIsBanner && <meta property="og:image:width" content="1200" />}
    {ogIsBanner && <meta property="og:image:height" content="630" />}
    <meta property="og:image:alt" content={ogTitle} />
    <meta property="og:site_name" content="Trym Stene — the banana guy" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- self-hosted fonts: no third-party round trips (perf + GDPR) -->
    <link rel="preload" href="/fonts/spacegrotesk-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/archivoblack-400-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="stylesheet" href="/css/fonts.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot name="banner" />
    <Nav />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    {showFooter && <Footer />}
    <script src="/js/main.js" is:inline></script>
  </body>
</html>
