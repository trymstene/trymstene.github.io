const { name, size = '1.25em' } = Astro.props;
const map = ICONS[name];
if (!map) throw new Error(`PixelIcon: unknown icon "${name}"`);
const rows = map.trim().split('\n').map((r) => r.trimEnd());
const w = Math.max(...rows.map((r) => r.length));
const mono = rows.some((r) => r.includes('M'));
const depth = mono ? 0 : 1;

// extrusion layer: silhouette runs offset (+1,+1) unit in deep ink
const silRuns = [];
if (depth) {
  rows.forEach((row, y) => {
    let x = 0;
    while (x < row.length) {
      if (!(row[x] in PALETTE)) { x++; continue; }
      const x0 = x;
      while (x < row.length && row[x] in PALETTE) x++;
      silRuns.push({ x: (x0 + depth) * 10, y: (y + depth) * 10, w: (x - x0) * 10 });
    }
  });
}
// colour layer
const runs = [];
rows.forEach((row, y) => {
  let x = 0;
  while (x < row.length) {
    const ch = row[x];
    if (!(ch in PALETTE)) { x++; continue; }
    const x0 = x;
    while (x < row.length && row[x] === ch) x++;
    runs.push({ x: x0 * 10, y: y * 10, w: (x - x0) * 10, fill: PALETTE[ch] });
  }
});
---
<svg
  class="pxi"
  viewBox={`0 0 ${(w + depth) * 10} ${(rows.length + depth) * 10}`}
  style={`width:${size};height:${size};`}
  shape-rendering="crispEdges"
  aria-hidden="true"
>
  {silRuns.map((r) => <rect x={r.x} y={r.y} width={r.w} height="10" fill={PALETTE.K} />)}
  {runs.map((r) => <rect x={r.x} y={r.y} width={r.w} height="10" fill={r.fill} />)}
</svg>
