---
// 3D pixel-art emoji icons (v3, per Trym's reference): chunky charcoal
// outlines (not black — stays visible on dark buttons), fresh Material-ish
// colours, and an auto-generated extrusion — the glyph's silhouette offset
// one unit down-right in deep ink, drawn underneath, gives every icon the
// same isometric-lite depth. ASCII maps on a 10-unit grid → crispEdges SVG
// rects. Letter M = currentColor for mono UI glyphs (burger/close), which
// also skip the extrusion.
const PALETTE = {
  T: '#37474f', // charcoal outline
  K: '#1d272c', // deep ink: pips, extrusion
  W: '#ffffff',
  L: '#eceff1', // light grey
  G: '#b0bec5', // mid grey
  R: '#ef5350', // coral red
  S: '#c62828', // dark red
  Y: '#ffca28', // amber
  O: '#f9a825', // dark amber
  H: '#ffe082', // light amber
  C: '#4dd0e1', // cyan
  U: '#0097a7', // dark cyan
  E: '#b2ebf2', // light cyan
  Z: '#42a5f5', // blue
  X: '#1976d2', // dark blue
  N: '#66bb6a', // green
  V: '#2e7d32', // dark green
  P: '#f06292', // pink
  B: '#8d6e63', // brown
  D: '#5d4037', // dark brown
  A: '#bcaaa4', // light brown
  M: 'currentColor',
};

const ICONS = {
