---
// Pixel-art emoji icons, drawn as ASCII maps on a 10-unit grid and rendered
// as crispEdges SVG rects — coloured reimaginations of the stock emojis they
// replaced (🍌 ☕ 🎨 🎲 🔗 💬 🏷️ 🌍 📝 💾 ⚡ ❤️ ✨), on the same palette as the
// banana sprite (tools/pixel-assets.py). The letter M renders as currentColor
// for the mono UI glyphs (burger/close) that must adapt to the button colour.
const PALETTE = {
  K: '#111111', // ink black (outline)
  G: '#484848', // dark grey
  L: '#cdd3db', // light grey
  W: '#ffffff', // white
  R: '#e22020', // red
  Y: '#f2c200', // gold
  O: '#c49a00', // darker gold shade
  P: '#ff4d6d', // hot pink
  C: '#4db8ff', // blue
  N: '#3aa655', // leaf green
  B: '#8a5a2b', // brown
  D: '#5a3618', // dark brown
  M: 'currentColor',
};

const ICONS = {
  banana: `
......KK.
.....KDK.
....KYYK.
...KYYOK.
..KYYYOK.
.KYYYOK..
.KYYOK...
KYYYOK...
KYYOK....
.KKK.....`,
  coffee: `
..K..K....
.K..K.....
..K..K....
KKKKKKKK..
KDDDDDDKK.
KWWWWWWK.K
KWWWWWWKKK
.KWWWWK...
KKKKKKKK..`,
  palette: `
...KKKKKK...
..KBBBBBBK..
.KBRRBBCCBK.
.KBRRBBCCBK.
KBBBBBBBBBBK
KBYYBBBKKBBK
KBYYBBBKKBBK
.KBBBBBBBBK.
.KBNNBBBBBK.
..KBNNBBBK..
...KKKKKK...`,
  dice: `
KKKKKKKKK
KWWWWWWWK
KWKKWWWWK
KWKKWWWWK
KWWWKWWWK
KWWWWKKWK
KWWWWKKWK
KWWWWWWWK
KKKKKKKKK`,
  link: `
.KKK..KKK.
KCCCKKCCCK
KC.CKKC.CK
KCCCKKCCCK
.KKK..KKK.`,
  download: `
KKKKKKKKKK
KCCCWWCCCK
KCCCWWCCCK
KCWWWWWWCK
KCCWWWWCCK
KCCCWWCCCK
KCCCCCCCCK
KKKKKKKKKK`,
  chat: `
KKKKKKKKKK
KCCCCCCCCK
KCWCWCWCCK
KCCCCCCCCK
KKKKKKKKKK
.KCK......
.KK.......`,
  tag: `
KKKKKKK..
KYYYYYKK.
KYYYYYYKK
KYKKYYYYK
KYKKYYYYK
KYYYYYYYK
KKKKKKKKK`,
  globe: `
..KKKKK..
.KNNCCNK.
KCNNCNNCK
KCCNNCNCK
KCNNCCCCK
.KCCNNCK.
..KKKKK..`,
  note: `
KKKKKKK..
KWWWWWK..
KWGGGWKK.
KWWWWKYYK
KWGGKYYK.
KWWKYYK..
KWKDDK...
KKKKK....`,
  floppy: `
KKKKKKKK.
KCCWWCCKK
KCCWWCCCK
KCCCCCCCK
KCKKKKKCK
KCKWWWKCK
KCKWWWKCK
KKKKKKKKK`,
  bolt: `
....KKKK.
...KYYYK.
..KYYYK..
.KYYYYKKK
KKYYYYYYK
KKKKYYYK.
...KYYK..
..KYYK...
..KYK....
..KK.....`,
  heart: `
.KK..KK.
KRRKKRRK
KRWRRRRK
KRRRRRRK
.KRRRRK.
..KRRK..
...KK...`,
  sparkle: `
...KK...
..KYYK..
.KYYYYK.
KYYWYYYK
.KYYYYK.
..KYYK..
...KK...`,
  burger: `
MMMMMMMMM
MMMMMMMMM
.........
MMMMMMMMM
MMMMMMMMM
.........
MMMMMMMMM
MMMMMMMMM`,
  close: `
MM.....MM
MMM...MMM
.MMM.MMM.
..MMMMM..
...MMM...
..MMMMM..
.MMM.MMM.
MMM...MMM
MM.....MM`,
};

const { name, size = '1em' } = Astro.props;
const map = ICONS[name];
if (!map) throw new Error(`PixelIcon: unknown icon "${name}"`);
const rows = map.trim().split('\n').map((r) => r.trimEnd());
const w = Math.max(...rows.map((r) => r.length));
const runs = [];
rows.forEach((row, y) => {
  let x = 0;
  while (x < row.length) {
    const ch = row[x];
    if (!(ch in PALETTE)) { x++; continue; }
    const x0 = x;
    while (x < row.length && row[x] === ch) x++;
    runs.push({ x: x0 * 10, y: y * 10, w: (x - x0) * 10, fill: PALETTE[ch] });
  }
});
---
<svg
  class="pxi"
  viewBox={`0 0 ${w * 10} ${rows.length * 10}`}
  style={`width:${size};height:${size};`}
  shape-rendering="crispEdges"
  aria-hidden="true"
>
  {runs.map((r) => <rect x={r.x} y={r.y} width={r.w} height="10" fill={r.fill} />)}
</svg>
