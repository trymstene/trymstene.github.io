KKK...KKK
.KKK.KKK.
..KKKKK..
...KKK...
..KKKKK..
.KKK.KKK.
KKK...KKK
KK.....KK`,
};

const { name, size = '1em' } = Astro.props;
const map = ICONS[name];
if (!map) throw new Error(`PixelIcon: unknown icon "${name}"`);
const rows = map.trim().split('\n').map((r) => r.trimEnd());
const w = Math.max(...rows.map((r) => r.length));
const runs = [];
rows.forEach((row, y) => {
  let x = 0;
  while (x < row.length) {
    if (row[x] !== 'K') { x++; continue; }
    const x0 = x;
    while (x < row.length && row[x] === 'K') x++;
    runs.push({ x: x0 * 10, y: y * 10, w: (x - x0) * 10 });
  }
});
---
<svg
  class="pxi"
  viewBox={`0 0 ${w * 10} ${rows.length * 10}`}
  style={`width:${size};height:${size};`}
  shape-rendering="crispEdges"
  fill="currentColor"
  aria-hidden="true"
>
  {runs.map((r) => <rect x={r.x} y={r.y} width={r.w} height="10" />)}
</svg>
