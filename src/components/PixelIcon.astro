---
// Monochrome pixel-art icons, drawn as ASCII maps on a 10-unit grid and
// rendered as crispEdges SVG rects in currentColor — so they inherit the
// button/text colour automatically (yellow on dark buttons, ink on light).
// Same visual language as the banana sprite (tools/pixel-assets.py).
const ICONS = {
