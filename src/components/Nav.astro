---
// Canonical site navigation — the single source of truth for every page.
// Banana-world verbs only; Trym-side links live in the footer + /me. Mobile = slide-in (js/main.js).
import PixelIcon from './PixelIcon.astro';
import PixelArtIcon from './PixelArtIcon.astro';
---
<header class="nav">
  <a class="nav__brand" href="/">TRYM<span>STENE</span></a>
  <button class="nav__toggle" aria-label="Menu" aria-expanded="false">
    <span class="nav__ic nav__ic--open"><PixelIcon name="burger" /></span>
    <span class="nav__ic nav__ic--close"><PixelIcon name="close" /></span>
  </button>
  <nav class="nav__links">
    <div class="nav__group nav__group--banana">
      <a href="/dancing-banana-gif-meme/">Download</a>
      <a href="/make-a-banana/" data-place="nav">Make a Banana</a>
      <a href="/forge/">Pixel Forge</a>
      <a href="/rave/">Join the Rave</a>
      {/* nav says "Banana Gallery" (the place); SEO metadata keeps "Banana
          Memes" (the query) — Trym's call, avoids gallery-vs-memes confusion */}
      <a href="/banana-memes/">Banana Gallery</a>
      <a href="/shop/">Banana Shop</a>
      <a class="nav__pass" href="/pass/" title="Your banana pass"><PixelArtIcon name="card" size="17px" /> My Pass</a>
    </div>
  </nav>
  <div class="nav__backdrop"></div>
</header>
<style>
  /* pass link: keep the pixel icon on the same line as the label */
  .nav__pass { display: inline-flex; align-items: center; gap: 0.35rem; }
</style>
